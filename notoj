def draw(stdscr, notes, state):
    stdscr.erase()

    h, w = stdscr.getmaxyx()

    if h < 3 or w < MIN_W_ERROR:
        try:
            stdscr.addnstr(0, 0, "window too narrow", w)
        except curses.error:
            pass
        stdscr.refresh()
        return

    show_preview = (w - w // 2 - 5) >= MIN_PREVIEW_W
    if show_preview:
        natural_list_w = w // 2 - 2
        list_w = min(natural_list_w, LIST_MAX_W)
        mid = list_w + 2
        preview_w = w - mid - 5
    else:
        mid = None
        list_w = w - 1
        preview_w = 0

    show_date = list_w >= SHOW_DATE_MIN
    show_ago  = list_w >= SHOW_AGO_MIN
    show_tags = list_w >= SHOW_TAGS_MIN

    conflicts = find_conflicts()
    conflict_badge = f" | [{len(conflicts)} conflict(s)]" if conflicts else ""
    header = (
        f"notes | filter:{state['q']} | "
        f"sort:{state['sort']} {'🞃' if state['rev'] else '🞁'}"
        f"{conflict_badge}"
    )

    stdscr.addnstr(0, 0, header, w - 1)

    visible = notes[state["off"]:state["off"] + h - 3]
    tokens = state["q"].lower().split() if state["q"].strip() else []

    # ----------------------------
    # LEFT PANE
    # ----------------------------

    for i, n in enumerate(visible):
        y = i + 1

        attr_title = curses.color_pair(1) | curses.A_BOLD
        attr_date = curses.color_pair(2)
        attr_tag = curses.color_pair(3)

        selected = (i == state["cur"] - state["off"])
        if selected:
            attr_title |= curses.A_REVERSE

        if is_recent(n):
            attr_title |= curses.A_UNDERLINE

        t = title(n)
        tg = tags(n)

        hi_title = curses.color_pair(5) | curses.A_BOLD | (curses.A_REVERSE if selected else 0)
        title_w = min(28, list_w)
        t_clip = t[:title_w]
        draw_line_highlighted(stdscr, y, 0, t_clip, title_w, attr_title, hi_title, tokens)
        pad = title_w - len(t_clip)
        if pad > 0:
            try:
                stdscr.addnstr(y, len(t_clip), " " * pad, pad, attr_title)
            except curses.error:
                pass

        if show_date:
            m = fmt(n.get("modificationDate"))
            stdscr.addnstr(y, 30, LRM + m, min(16, list_w - 30), attr_date)

        if show_ago:
            a = ago(n.get("modificationDate"))
            stdscr.addnstr(y, 50, LRM + f"({a})", min(10, list_w - 50), attr_date)

        if show_tags:
            stdscr.addnstr(y, 62, tg, list_w - 62, attr_tag)

    # ----------------------------
    # RIGHT PANE (preview)
    # ----------------------------

    if show_preview:
        for y in range(1, h - 1):
            stdscr.addch(y, mid, curses.ACS_VLINE)

        cur_idx = state["cur"]

        if 0 <= cur_idx < len(notes):
            cur = notes[cur_idx]

            lines = content(cur).split("\n")

            start = state["p_scroll"]
            end = start + h - 3

            for i, line in enumerate(lines[start:end]):
                if i >= h - 3:
                    break

                safe = line.expandtabs(4).replace("\n", "")[:preview_w - 1]

                draw_line_highlighted(
                    stdscr, i + 1, mid + 1, safe, preview_w - 1,
                    curses.color_pair(4),
                    curses.color_pair(5) | curses.A_BOLD,
                    tokens,
                )

    conflict_hint = " | c conflicts" if conflicts else ""
    footer = (
        f"s sort | r reverse order | / search | ⮐ open | e edit | n new | d trash | u undo{conflict_hint} | q quit"
    )

    stdscr.addnstr(h - 1, 0, footer, w - 1)

    stdscr.refresh()


# ----------------------------
# Main loop
# ----------------------------

def run(stdscr):
    git_init()
    curses.curs_set(0)
    init_colors()
    stdscr.timeout(2000)

    state = {
        "cur": 0,
        "off": 0,
        "p_scroll": 0,
        "q": "",
        "sort": "modified",
        "rev": True,
        "search_mode": False,
    }

    notes = load()
    snap = file_snapshot(NOTES_DIR)
    searcher = FullScanSearcher()
    searcher.update(notes)

    saved = load_cursor()
    if saved:
        state["_restore_path"] = saved

    def refresh_notes():
        nonlocal notes, snap
        new_snap = file_snapshot(NOTES_DIR)
        notes, _ = incremental_update(notes, snap, new_snap)
        snap = new_snap
        searcher.update(notes)

    while True:
        filtered = searcher.search(state["q"])
        if not state["q"]:
            filtered = sort_notes(filtered, state["sort"], state["rev"])

        # Restore cursor to a specific note after external reload
        restore_path = state.pop("_restore_path", None)
        if restore_path is not None:
            for i, n in enumerate(filtered):
                if n["path"] == restore_path:
                    state["cur"] = i
                    break
            else:
                state["cur"] = 0

        h, _ = stdscr.getmaxyx()
        clamp_scroll(state, filtered, h)

        draw(stdscr, filtered, state)

        k = stdscr.getch()

        # ----------------------------
        # Quit
        # ----------------------------

        if k == -1:
            new_snap = file_snapshot(NOTES_DIR)
            notes, changed = incremental_update(notes, snap, new_snap)
            if changed:
                snap = new_snap
                searcher.update(notes)
                cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
                state["_restore_path"] = cur_path
                git_commit("sync: external changes")

        # ----------------------------
        # Quit
        # ----------------------------

        elif k == ord("q"):
            if 0 <= state["cur"] < len(filtered):
                save_cursor(filtered[state["cur"]]["path"])
            break

        # ----------------------------
        # Open note
        # ----------------------------

        elif k in [10, 13] and filtered:
            open_note(filtered[state["cur"]])
            refresh_notes()

        elif k == ord("e") and filtered:
            open_note(filtered[state["cur"]], end=True)
            refresh_notes()

        # ----------------------------
        # Incremental search mode
        # ----------------------------

        elif k == 27 and not state["search_mode"] and state["q"]:
            cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
            state["q"] = ""
            state["cur"] = 0
            state["off"] = 0
            state["p_scroll"] = 0
            if cur_path:
                state["_restore_path"] = cur_path

        elif state["search_mode"]:
            if k == 27:  # ESC
                state["search_mode"] = False

            elif k in [10, 13]:
                if state["q"].strip():
                    new_note_with_title(state["q"].strip())
                    refresh_notes()
                    state["q"] = ""
                    state["cur"] = 0
                    state["off"] = 0
                    state["p_scroll"] = 0
                state["search_mode"] = False

            elif k == curses.KEY_DOWN:
                state["cur"] += 1
                state["p_scroll"] = 0

            elif k == curses.KEY_UP:
                state["cur"] -= 1
                state["p_scroll"] = 0

            elif k in [curses.KEY_BACKSPACE, 127, 8]:
                state["q"] = state["q"][:-1]
                state["cur"] = 0
                state["off"] = 0

            elif 32 <= k <= 126:
                state["q"] += chr(k)
                state["cur"] = 0
                state["off"] = 0

            continue

        # ----------------------------
        # Enter search mode
        # ----------------------------

        elif k == ord("/"):
            state["search_mode"] = True
            state["q"] = ""
            state["cur"] = 0
            state["off"] = 0

        # ----------------------------
        # Navigation
        # ----------------------------

        elif k in [ord("j"), curses.KEY_DOWN]:
            state["cur"] += 1
            state["p_scroll"] = 0

        elif k in [ord("k"), curses.KEY_UP]:
            state["cur"] -= 1
            state["p_scroll"] = 0

        elif k == ord("G"):
            state["cur"] = len(filtered) - 1
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        elif k == ord("g"):
            nxt = stdscr.getch()

            if nxt == ord("g"):
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                clamp_scroll(state, filtered, h)

        # Ctrl-f
        elif k == 6:
            state["cur"] += h - 4
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # Ctrl-b
        elif k == 2:
            state["cur"] -= h - 4
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # Ctrl-d
        elif k == 4:
            state["cur"] += max(1, (h - 4) // 2)
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # Ctrl-u
        elif k == 21:
            state["cur"] -= max(1, (h - 4) // 2)
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # ----------------------------
        # Preview scrolling
        # ----------------------------

        elif k == curses.KEY_NPAGE:
            state["p_scroll"] += 5

        elif k == curses.KEY_PPAGE:
            state["p_scroll"] = max(0, state["p_scroll"] - 5)

        # ----------------------------
        # Trash note
        # ----------------------------

        elif k == ord("d") and filtered:
            cur = state["cur"]
            trash_note(filtered[cur])
            refresh_notes()
            state["cur"] = cur
            state["p_scroll"] = 0

        # ----------------------------
        # Sort mode
        # ----------------------------

        elif k == ord("s"):
            idx = SORTS.index(state["sort"])
            state["sort"] = SORTS[(idx + 1) % len(SORTS)]

        # reverse sort
        elif k == ord("r"):
            state["rev"] = not state["rev"]

        # undo trash
        elif k == ord("u"):
            if undo_trash():
                refresh_notes()

        # new note
        elif k == ord("n"):
            new_note()
            refresh_notes()
            state["cur"] = 0
            state["off"] = 0
            state["p_scroll"] = 0

        # resolve conflict
        elif k == ord("c"):
            conflicts = find_conflicts()
            if conflicts:
                original, conflict = conflicts[0]
                resolve_conflict(original, conflict)
                refresh_notes()


def load_notes_dir():
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as f:
            for line in f:
                if line.startswith("notes_dir="):
                    return os.path.expanduser(line.split("=", 1)[1].strip())
    except FileNotFoundError:
        pass
    return None


def save_notes_dir(path):
    os.makedirs(os.path.dirname(CONFIG_FILE), exist_ok=True)
    with open(CONFIG_FILE, "w", encoding="utf-8") as f:
        f.write(f"notes_dir={path}\n")


def prompt_notes_dir(current=None):
    default = current or os.path.expanduser("~/notes")
    if current:
        print(f"notoj: notes directory not found: {current}")
    else:
        print("notoj: no notes directory configured.")
    while True:
        print(f"Notes directory [{default}]: ", end="", flush=True)
        ans = input().strip()
        path = os.path.expanduser(ans if ans else default)
        if os.path.isdir(path):
            return path
        print(f"  '{path}' does not exist. Create it? [y/N] ", end="", flush=True)
        if input().strip().lower() == "y":
            os.makedirs(path)
            return path


def offer_simplenote_import(notes_dir):
    if glob.glob(os.path.join(notes_dir, "*.md")):
        return

    script = os.path.join(SCRIPT_DIR, "simplenote_convert_to_md.py")
    if not os.path.exists(script):
        return

    print("Notes directory is empty. Import from a Simplenote export? [y/N] ", end="", flush=True)
    if input().strip().lower() != "y":
        return

    print("Path to Simplenote export directory: ", end="", flush=True)
    export_dir = os.path.expanduser(input().strip())
    if not os.path.isdir(export_dir):
        print(f"  '{export_dir}' not found, skipping import.")
        return

    subprocess.run([sys.executable, script, export_dir, notes_dir])


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print(HELP)
        sys.exit(0)

    saved = load_notes_dir()
    if saved and os.path.isdir(saved):
        NOTES_DIR = saved
    else:
        NOTES_DIR = prompt_notes_dir(saved)
        save_notes_dir(NOTES_DIR)

    TRASH_DIR = os.path.join(NOTES_DIR, ".trash")
    STATE_FILE = os.path.join(NOTES_DIR, ".notoj_state")

    offer_simplenote_import(NOTES_DIR)

    curses.wrapper(run)
