# Config (~/.config/notoj/config) — simple `key = value` lines, # comments.
# ----------------------------

CONFIG_FILE = os.path.expanduser("~/.config/notoj/config")

_config_cache = None


def _read_config():
    """Parse the config file into a {key: value} dict (cached). Lines are
    `key = value`; blank lines and lines starting with `#` are ignored."""
    global _config_cache
    if _config_cache is None:
        _config_cache = {}
        try:
            with open(CONFIG_FILE, "r", encoding="utf-8") as f:
                for line in f:
                    s = line.strip()
                    if not s or s.startswith("#") or "=" not in s:
                        continue
                    k, v = s.split("=", 1)
                    _config_cache[k.strip()] = v.strip()
        except FileNotFoundError:
            pass
    return _config_cache


def config_get(key, default=None):
    v = _read_config().get(key)
    return default if v is None else v


def config_bool(key, default=False):
    v = config_get(key)
    return default if v is None else v.strip().lower() in ("1", "true", "yes", "on")


# --- Key-binding helpers ----------------------------------------------------
# Actions are named (see KEYMAP). A binding is a single key written as one
# character, a name (enter/tab/space/esc), or Ctrl-<letter>. Users rebind with
# `key.<action> = <key>`; this is a TRUE remap — the default stops triggering
# the action unless something is still bound to it.
_KEY_NAMED = {"enter": 10, "return": 10, "tab": 9, "space": 32,
              "esc": 27, "escape": 27}


def _label_to_keycode(label):
    """A key label / config value -> keycode, or None if not a single key."""
    s = (label or "").strip()
    low = s.lower()
    if low in _KEY_NAMED:
        return _KEY_NAMED[low]
    if low.startswith("ctrl-") and len(low) == 6:
        return ord(low[5].upper()) & 0x1f
    if len(s) == 1:
        return ord(s)
    return None


def _keycode_to_label(kc):
    """Keycode -> display label for the help screen."""
    special = {10: "Enter", 13: "Enter", 9: "Tab", 32: "Space", 27: "ESC"}
    if kc in special:
        return special[kc]
    if 1 <= kc <= 26:
        return "Ctrl-" + chr(kc + 96)
    if 32 < kc < 127:
        return chr(kc)
    return "?"


def action_keycode(action, default_label):
    """Effective keycode for an action: the `key.<action>` config override if
    it parses to a single key, else the action's default."""
    v = config_get("key." + action)
    if v:
        kc = _label_to_keycode(v)
        if kc is not None:
            return kc
    return _label_to_keycode(default_label)


# Two-key chord actions: default binding is two characters (prefix + suffix);
# remappable to a different 2-key chord via key.<action> = <two chars>.
CHORD_DEFAULTS = {"goto_top": "gg", "dups_view": "gd",
                  "trash_view": "gt", "resurface": "gr"}
CHORD_ACTIONS = set(CHORD_DEFAULTS)


def chord_binding(action):
    """The effective two-character chord for a chord action (spaces ignored;
    falls back to the default if the config value isn't exactly two keys)."""
    v = (config_get("key." + action) or "").replace(" ", "").strip()
    return v if len(v) == 2 else CHORD_DEFAULTS[action]


def build_chord_dispatch():
    """({(kc1, kc2): action}, {prefix_kc, …}) from the chord bindings."""
    chords = {}
    for action in CHORD_DEFAULTS:
        b = chord_binding(action)
        chords[(ord(b[0]), ord(b[1]))] = action
    return chords, {c1 for c1, _c2 in chords}


def action_label(action, default_label):
    """Effective key label for the help screens (chord actions show 'g t')."""
    if action in CHORD_ACTIONS:
        return " ".join(chord_binding(action))
    return _keycode_to_label(action_keycode(action, default_label))


def key_matches(k, kc):
    """True if keypress k triggers keycode kc (Enter accepts both CR and LF)."""
    if kc in (10, 13):
        return k in (10, 13)
    return k == kc


def build_key_dispatch():
    """{action: effective_keycode} for every remappable single-key KEYMAP row
    (chord actions are handled separately, via build_chord_dispatch)."""
    return {action: action_keycode(action, label)
            for _, entries in KEYMAP
            for action, label, _desc in entries
            if action and action not in CHORD_ACTIONS}


