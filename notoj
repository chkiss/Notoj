# Explicit field sorts cycled by `s`. The default sort, "relevance", is the
# smart contextual order (best matches while searching, else each view's
# natural order); `s` steps out of it into these fields.
SORTS = ["title", "created", "modified"]

MIN_W_ERROR   = 20   # below this: show error, refuse to draw
MIN_PREVIEW_W = 20   # collapse preview when it would be narrower than this
LIST_MAX_W    = 80   # cap list panel here; extra space goes to preview
# List columns: title (0, 28w) | 2sp | date (30, 16w) | 1sp | ago (47) | 2sp | tags
COL_DATE = 30
COL_AGO  = 47
SHOW_DATE_MIN = 38   # min list_w to start showing the modification date (col 30 + ~8)
SHOW_AGO_MIN  = 53   # min list_w to start showing the relative date     (col 47 + ~6)
# Tags have no fixed threshold: they appear as soon as one column fits past the
# (aligned) date+relative-date block — see draw().

TAG_PROMPT = "add tags (space-separated): "
SCHED_PROMPT = "resurface when (e.g. 2w, 3mo, 1y, 2026-12-01, someday): "

TRASH_EDIT_NOTICE = [
    "This note is in the trash.",
    "",
    "Editing it restores it: saving any change in Vim moves the note",
    "out of the trash and back into your notes.",
    "Quitting Vim without saving (:q!) leaves it in the trash.",
