HELP_KEY_W = 12   # description column starts at 4 (indent) + this


def build_help(width=None):
    """The --help text, rendered from KEYMAP; long descriptions wrap to the
    terminal width with continuation lines under the description column."""
    if width is None:
        width = shutil.get_terminal_size((80, 24)).columns
    desc_w = max(20, width - 4 - HELP_KEY_W)
    lines = ["notoj — keyboard-driven terminal notes", "",
             "Usage: notoj [--help]", "", "Keybindings:"]
    for section, entries in KEYMAP:
        lines.append(f"  {section}")
        for action, key, desc in entries:
            label = action_label(action, key) if action else key
            first, *rest = textwrap.wrap(desc, desc_w)
            lines.append(f"    {label:<{HELP_KEY_W}}{first}")
            lines.extend(f"    {'':<{HELP_KEY_W}}{r}" for r in rest)
        lines.append("")
    lines.append("Notes live in the directory set in ~/.config/notoj/config.")
    return "\n".join(lines) + "\n"


