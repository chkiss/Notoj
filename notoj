def check_rename(n):
    """After editing: always update modified date; rename file if first line changed."""
    path = n["path"]
    if not os.path.exists(path):
        return

    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return

    if not text.startswith("---\n"):
        return

    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return

    body = text[fm_end + 5:]
    if body.startswith("\n"):
        body = body[1:]

    new_first_line = ""
    for line in body.split("\n"):
        s = line.strip()
        if s:
            new_first_line = s[:TITLE_MAX]
            break

    title_changed = bool(new_first_line) and new_first_line != n.get("title", "")
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    new_yaml_lines = []
    title_written = False
    for line in text[4:fm_end].splitlines():
        if line.startswith("title:") and title_changed:
            new_yaml_lines.append(f"title: {yaml_scalar(new_first_line)}")
            title_written = True
        elif line.startswith("modified:"):
            new_yaml_lines.append(f"modified: {now_iso}")
        else:
            new_yaml_lines.append(line)
            if line.startswith("id:") and title_changed and not title_written:
                new_yaml_lines.append(f"title: {yaml_scalar(new_first_line)}")
                title_written = True

    new_text = "---\n" + "\n".join(new_yaml_lines) + text[fm_end:]

    if title_changed:
        new_stem = slugify(new_first_line)
        new_path = os.path.join(NOTES_DIR, new_stem + ".md")
        if os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(path):
            i = 2
            while os.path.exists(new_path):
                new_path = os.path.join(NOTES_DIR, f"{new_stem} ({i}).md")
                i += 1
    else:
        new_path = path

    atomic_write(path, new_text)

    if new_path != path:
        os.rename(path, new_path)

    sync_hashtags(new_path)


def open_note(n, end=False):
    curses.endwin()
    cmd = ["vim", n["path"]] if not end else ["vim", "-c", "normal G", n["path"]]
    subprocess.call(cmd)
    check_rename(n)
    git_commit(f"edit: {title(n)}")



def trash_note(n):
    os.makedirs(TRASH_DIR, exist_ok=True)

    base = os.path.basename(n["path"])
    dest = os.path.join(TRASH_DIR, base)

    if os.path.exists(dest):
        stem, ext = os.path.splitext(base)
        i = 2
        while os.path.exists(dest):
            dest = os.path.join(TRASH_DIR, f"{stem} ({i}){ext}")
            i += 1

    os.rename(n["path"], dest)
    git_commit(f"trash: {title(n)}")


def undo_trash():
    if not os.path.exists(TRASH_DIR):
        return False

    candidates = [
        (os.path.getmtime(p), p)
        for p in glob.glob(os.path.join(TRASH_DIR, "*.md"))
        if os.path.isfile(p)
    ]

    if not candidates:
        return False

    candidates.sort(reverse=True)

    src = candidates[0][1]
    dst = os.path.join(NOTES_DIR, os.path.basename(src))

    if os.path.exists(dst):
        stem, ext = os.path.splitext(os.path.basename(src))
        i = 2
        while os.path.exists(dst):
            dst = os.path.join(NOTES_DIR, f"{stem} ({i}){ext}")
            i += 1

    try:
        os.rename(src, dst)
        git_commit(f"restore: {os.path.splitext(os.path.basename(dst))[0]}")
        return True
    except Exception:
        return False


def finalize_new_note(tmp_path):
    try:
        with open(tmp_path, "r", encoding="utf-8") as f:
            text = f.read()
    except FileNotFoundError:
        return None

    if not text.startswith("---\n"):
        os.unlink(tmp_path)
        return None

    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        os.unlink(tmp_path)
        return None

    body = text[fm_end + 5:]
    if body.startswith("\n"):
        body = body[1:]

    first_line = ""
    for line in body.split("\n"):
        s = line.strip()
        if s:
            first_line = s[:TITLE_MAX]
            break

    if not first_line:
        os.unlink(tmp_path)
        return None

    # Rewrite frontmatter: insert title: after id:, update modified:
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    new_yaml_lines = []
    for line in text[4:fm_end].splitlines():
        if line.startswith("modified:"):
            new_yaml_lines.append(f"modified: {now_iso}")
        else:
            new_yaml_lines.append(line)
            if line.startswith("id:"):
                new_yaml_lines.append(f"title: {yaml_scalar(first_line)}")

    new_text = "---\n" + "\n".join(new_yaml_lines) + text[fm_end:]

    stem = slugify(first_line)
    dest = os.path.join(NOTES_DIR, stem + ".md")
    if os.path.exists(dest):
        i = 2
        while os.path.exists(dest):
            dest = os.path.join(NOTES_DIR, f"{stem} ({i}).md")
            i += 1

    with open(tmp_path, "w", encoding="utf-8") as f:
        f.write(new_text)
    os.rename(tmp_path, dest)
    sync_hashtags(dest)
    git_commit(f"add: {first_line}")
    return dest


def new_note():
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    key = uuid.uuid4().hex
    frontmatter = (
        f"---\n"
        f"id: {key}\n"
        f"created: {now_iso}\n"
        f"modified: {now_iso}\n"
        f"version: 1\n"
        f"tags: []\n"
        f"---\n"
    )
    tmp_path = os.path.join(NOTES_DIR, f".new_{key}.md")
    with open(tmp_path, "w", encoding="utf-8") as f:
        f.write(frontmatter + "\n")

    curses.endwin()
    subprocess.call(["vim", "-c", "normal G", "-c", "startinsert", tmp_path])
    return finalize_new_note(tmp_path)


