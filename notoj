def confirm_screen(stdscr, lines):
    """Full-screen interstitial. Returns True to proceed (Enter / y), False to
    cancel (ESC / n / q)."""
    stdscr.timeout(-1)   # block for the answer; the main loop resets this
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    for i, line in enumerate(lines):
        if i + 1 >= h - 1:
            break
        try:
            stdscr.addnstr(i + 1, 2, line, max(1, w - 3),
                           curses.A_BOLD if i == 0 else curses.A_NORMAL)
        except curses.error:
            pass
    stdscr.refresh()
    while True:
        k = stdscr.getch()
        if k in (10, 13, ord("y"), ord("Y")):
            return True
        if k in (27, ord("n"), ord("N"), ord("q")):
            return False



_footer_band = False   # set in init_colors when the terminal can tint the bar


def init_colors():
    global _footer_band
    curses.start_color()
    curses.use_default_colors()

    amber = 214 if curses.COLORS >= 256 else curses.COLOR_YELLOW
    curses.init_pair(1, amber, -1)                # amber (titles, recent dates)
    curses.init_pair(2, curses.COLOR_RED, -1)     # dates
    curses.init_pair(3, curses.COLOR_GREEN, -1)   # tags
    curses.init_pair(4, curses.COLOR_CYAN, -1)    # preview
    curses.init_pair(5, curses.COLOR_GREEN, -1)   # search match

    # Footer status bar: default fg over a gray band, distinct enough to read
    # as the screen's bottom edge so every row above it can hold content.
    if curses.COLORS >= 256:
        curses.init_pair(10, -1, 239)
        _footer_band = True


def footer_attr():
    """Attr for the footer bar (row h-1): gray band, or reverse video — the
    classic status-line look — without 256 colors."""
    if _footer_band:
        return curses.color_pair(10)
    return curses.A_REVERSE


def fit_hints(segments, width):
    """Build the footer from (priority, text) hint segments, joined by two
    spaces. When it doesn't fit, drop whole segments — highest priority
    number first, rightmost first within a tie — instead of letting the
    right edge truncate mid-hint. Empty texts are skipped."""
    segs = [(pri, txt) for pri, txt in segments if txt]
    while True:
        s = "  ".join(t for _, t in segs)
        if len(s) <= width or len(segs) <= 1:
            return s
        worst = max(p for p, _ in segs)
        for i in range(len(segs) - 1, -1, -1):
            if segs[i][0] == worst:
                del segs[i]
                break


def draw_line_highlighted(stdscr, y, x, text, max_w, base_attr, hi_attr, tokens):
    """Render text at (y, x), switching to hi_attr on token match substrings."""
    if not tokens or not text:
        stdscr.addnstr(y, x, text, max_w, base_attr)
        return
    pos = 0
    col = x
    rem = max_w
    tl = text.lower()
    while pos < len(text) and rem > 0:
        best = None
        for tok in tokens:
            idx = tl.find(tok, pos)
            if idx != -1 and (best is None or idx < best[0]):
                best = (idx, tok)
        if best is None:
            stdscr.addnstr(y, col, text[pos:], rem, base_attr)
            break
        mi, tok = best
        if mi > pos:
            n = min(mi - pos, rem)
            stdscr.addnstr(y, col, text[pos:mi], n, base_attr)
            col += n
            rem -= n
            pos = mi
        if rem <= 0:
            break
        n = min(len(tok), rem)
        stdscr.addnstr(y, col, text[mi:mi + len(tok)], n, hi_attr)
        col += n
        rem -= n
        pos = mi + len(tok)


def clamp_scroll(state, filtered, height):
    max_idx = max(0, len(filtered) - 1)

    state["cur"] = max(0, min(state["cur"], max_idx))

    page_h = height - 3

    if state["cur"] < state["off"]:
        state["off"] = state["cur"]

    elif state["cur"] >= state["off"] + page_h:
        state["off"] = state["cur"] - page_h + 1


# ----------------------------
# Drawing
# ----------------------------

def draw(stdscr, notes, state):
    stdscr.erase()

    h, w = stdscr.getmaxyx()

    if h < 3 or w < MIN_W_ERROR:
        try:
            stdscr.addnstr(0, 0, "window too narrow", w)
        except curses.error:
            pass
        stdscr.refresh()
        return

    show_preview = (w - w // 2 - 5) >= MIN_PREVIEW_W
    if show_preview:
        natural_list_w = w // 2 - 2
        list_w = min(natural_list_w, LIST_MAX_W)
        mid = list_w + 2
        # Preview runs from mid+1 to the last column (w-1): no right margin,
        # mirroring the list starting flush at column 0 on the left.
        preview_w = w - (mid + 1)
    else:
        mid = None
        list_w = w - 1
        preview_w = 0

    show_date = list_w >= SHOW_DATE_MIN
    show_ago  = list_w >= SHOW_AGO_MIN

    conflicts = state.get("_conflicts", [])   # scanned on the idle tick, not per frame
    conflict_badge = f" | [{len(conflicts)} conflict(s)]" if conflicts else ""
    dup_badge = f" | [{len(state['_dups'])} dup(s) — gd]" if state.get("_dups") else ""
    loop_badge = f" | [{state['_loops_due']} loop(s) due — gr]" if state.get("_loops_due") else ""
    # The "filter:" field only shows while you're actually searching — same in
    # every view (notes / trash / duplicates / loops).
    filt = f" | filter:{state['q']}" if (state["q"] or state.get("search_mode")) else ""
    if state.get("tag_mode"):
        header = f"{TAG_PROMPT}{state['tag_input']}"
    elif state.get("sched_mode"):
        header = f"{SCHED_PROMPT}{state['sched_input']}"
    elif state.get("trash_mode"):
        sort = sort_label(state["sort"], state["rev"], state["q"], "modified 🞃", False)
        header = f"trash ({len(notes)} notes){filt} | sort:{sort}{conflict_badge}"
    elif state.get("dup_mode") is not None:
        sort = sort_label(state["sort"], state["rev"], state["q"], "grouped", True)
        header = f"duplicates ({len(notes)} notes){filt} | sort:{sort}{conflict_badge}"
    elif state.get("review_mode"):
        sort = sort_label(state["sort"], state["rev"], state["q"], "most stale first", True)
        header = f"resurface ({len(notes)} loop(s) due){filt} | sort:{sort}{conflict_badge}"
    else:
        sort = sort_label(state["sort"], state["rev"], state["q"], "modified 🞃", False)
        header = f"notes{filt} | sort:{sort}{conflict_badge}{dup_badge}{loop_badge}"

    stdscr.addnstr(0, 0, header, w - 1)

    visible = notes[state["off"]:state["off"] + h - 3]
    q_str = state["q"].strip()
    if q_str.startswith('"') and q_str.endswith('"') and len(q_str) > 2:
        tokens = [q_str[1:-1].lower()]
    else:
        tokens = q_str.lower().split() if q_str else []

    # Tags align in one column, 2 spaces past the widest date+relative-date
    # among the rows on screen (not the whole list), and appear as soon as a
    # single column of them fits.
    ago_strs = [f"({ago(n.get('modificationDate'))})" for n in visible]
    if show_ago:
        block_end = COL_AGO + max((len(a) for a in ago_strs), default=0)
    else:
        block_end = COL_DATE + 16   # date only (16-char timestamp)
    tag_col = block_end + 2

    # ----------------------------
    # LEFT PANE
    # ----------------------------

    for i, n in enumerate(visible):
        y = i + 1

        attr_title = curses.color_pair(1)
        attr_date = curses.color_pair(1) if is_recent(n) else curses.color_pair(2)
        attr_tag = curses.color_pair(3)

        selected = (i == state["cur"] - state["off"])
        if selected:
            attr_title |= curses.A_REVERSE

        t = title(n)
        tg = tags(n)

        hi_title = curses.color_pair(5) | (curses.A_REVERSE if selected else 0)
        title_w = min(28, list_w)
        t_clip = t[:title_w]
        draw_line_highlighted(stdscr, y, 0, t_clip, title_w, attr_title, hi_title, tokens)
        pad = title_w - len(t_clip)
        if pad > 0:
            try:
                stdscr.addnstr(y, len(t_clip), " " * pad, pad, attr_title)
            except curses.error:
                pass

        if show_date:
            m = fmt(n.get("modificationDate"))
            # +1 budget so the zero-width LRM doesn't clip the last char.
            stdscr.addnstr(y, COL_DATE, LRM + m, min(1 + len(m), list_w - COL_DATE), attr_date)

        if show_ago:
            ago_str = ago_strs[i]
            stdscr.addnstr(y, COL_AGO, LRM + ago_str, min(1 + len(ago_str), list_w - COL_AGO), attr_date)

        if show_date and tg and tag_col < list_w:
            stdscr.addnstr(y, tag_col, tg, list_w - tag_col, attr_tag)

    # ----------------------------
    # RIGHT PANE (preview)
    # ----------------------------

    if show_preview:
        for y in range(1, h - 1):
            stdscr.addch(y, mid, curses.ACS_VLINE)

        cur_idx = state["cur"]

        if 0 <= cur_idx < len(notes):
            cur = notes[cur_idx]

            lines = content(cur).split("\n")

            start = state["p_scroll"]
            end = start + h - 2

            for i, line in enumerate(lines[start:end]):
                if i >= h - 2:
                    break

                safe = line.expandtabs(4).replace("\n", "")[:preview_w]

                # Content now runs to the last column; guard against a wide
                # glyph landing on the edge (addnstr would raise on the wrap).
                try:
                    draw_line_highlighted(
                        stdscr, i + 1, mid + 1, safe, preview_w,
                        curses.color_pair(4),
                        curses.color_pair(5) | curses.A_BOLD,
                        tokens,
                    )
                except curses.error:
                    pass

    conflict_hint = " | c conflicts" if conflicts else ""
    hc = state.get("_hist_count", 0)
    hist_hint = (" | h/H hist" if hc >= 2 else "")
    if state.get("trash_mode"):
        footer = "gt exit trash | / search | ⮐ open | e edit | u restore | ESC clear/exit | q quit"
    elif state.get("dup_mode") is not None:
        footer = "gd exit duplicates | / search | ⮐ open | e edit | d trash | ESC clear/exit | q quit"
    elif state.get("review_mode"):
        footer = "ESC clear/exit | / search | ⮐ open | z snooze | S schedule | x done | d trash | u/^R undo/redo | q quit"
    else:
        retag_hint = " | . retag" if state.get("_last_tags") else ""
        footer = (
            f"s sort | r reverse order | / search | ⮐ open | e edit | n new | # tag{retag_hint} | d trash | u/^R undo/redo{hist_hint}{conflict_hint} | q quit"
        )

    stdscr.addnstr(h - 1, 0, footer, w - 1)

    if state["search_mode"] or state.get("tag_mode") or state.get("sched_mode"):
        if state.get("tag_mode"):
            cursor_col = min(len(TAG_PROMPT) + len(state["tag_input"]), w - 1)
        elif state.get("sched_mode"):
            cursor_col = min(len(SCHED_PROMPT) + len(state["sched_input"]), w - 1)
        else:
            # Place the cursor right after the query in the live "filter:" field,
            # wherever it sits in this view's header (notes / trash / dup / loops).
            anchor = header.find("filter:")
            base_col = anchor + len("filter:") if anchor >= 0 else 0
            cursor_col = min(base_col + len(state["q"]), w - 1)
        try:
            curses.curs_set(1)
        except curses.error:
            pass
        stdscr.move(0, cursor_col)
        stdscr.refresh()
        set_cursor_style(1)  # blinking block (DECSCUSR)
    else:
        curses.curs_set(0)
        set_cursor_style(0)  # restore terminal default
        stdscr.refresh()


# ----------------------------
# Main loop
# ----------------------------

def run(stdscr):
    git_init()
    curses.curs_set(0)
    init_colors()
    stdscr.timeout(2000)

    state = {
        "cur": 0,
        "off": 0,
        "p_scroll": 0,
        "q": "",
        "sort": "relevance",
        "rev": True,
        "search_mode": False,
        "tag_mode": False,
        "tag_input": "",
        "_last_tags": "",
        "dup_mode": None,
        "_dups": [],
        "trash_mode": False,
        "_trash": None,         # cached trash listing; None = reload on next draw
        "review_mode": False,
        "tagf": None,           # tag-filter view: {"tags": [...], "idx": -1|i}
        "_tags_ui": {"mode_i": 0},   # tags view sort mode, kept across visits
        "sched_mode": False,
        "sched_input": "",
        "_review": load_review(),
        "_loops_due": 0,
        "_undo": [],
        "_redo": [],
        "_hist_path": None,
        "_hist_count": 0,
        "_hist_dirty": False,
        "_hist_cache": {},      # path -> commit count (lazy; cleared on change)
        "_conflicts": [],
    }

    notes = load()
    snap = file_snapshot(NOTES_DIR)
    if prune_review(state["_review"], notes):
        save_review(state["_review"])
    state["_dups"] = find_duplicates(notes)
    state["_loops_due"] = len(find_loops(notes, state["_review"]))
    state["_conflicts"] = find_conflicts()

    saved = load_cursor()
    if saved:
        state["_restore_path"] = saved

    def refresh_notes():
        nonlocal notes, snap
        new_snap = file_snapshot(NOTES_DIR)
        notes, changed = incremental_update(notes, snap, new_snap)
        # incremental_update may rename files (title normalization), so after
        # a change re-snapshot — like the idle scan does — rather than keeping
        # pre-rename paths that would be reprocessed on the next tick.
        snap = file_snapshot(NOTES_DIR) if changed else new_snap
        state["_trash"] = None
        state["_dups"] = find_duplicates(notes)
        # Inline "#loop <when>" scheduling writes the review file from inside
        # the update pipeline, so reload it rather than trust the in-memory copy.
        state["_review"] = load_review()
        state["_loops_due"] = len(find_loops(notes, state["_review"]))
        state["_conflicts"] = find_conflicts()
        state["_hist_cache"].clear()   # commit counts may have changed
        if state["dup_mode"] is not None:
            state["dup_mode"] = state["_dups"]

    def record(act):
        """Push a fresh destructive action onto the undo stack; a new action
        invalidates the redo stack (standard undo/redo semantics)."""
        if act:
            state["_undo"].append(act)
            state["_redo"] = []

    def open_selected(note, end=False):
        """Open `note` in Vim. Trashed notes first get an interstitial saying
        that saving any change restores them from the trash."""
        if state["trash_mode"]:
            if confirm_screen(stdscr, TRASH_EDIT_NOTICE):
                restored = edit_trash_note(note, end=end)
                refresh_notes()
                state["_hist_path"] = None
                if restored:
                    state["_restore_path"] = restored
        else:
            record(open_note(note, end=end))
            refresh_notes()
            state["_hist_path"] = None
            state["_restore_path"] = note["path"]

    last_scan = time.monotonic()   # throttles the external-change / conflict scan
    SCAN_EVERY = 2.0

    while True:
        # Pick up terminal resizes live: ncurses won't refresh getmaxyx() on
        # its own between key presses, so poll the real size and resize when it
        # changes. This makes the list reflow (more/fewer columns) immediately.
        try:
            ts = os.get_terminal_size()
            if (ts.lines, ts.columns) != stdscr.getmaxyx():
                curses.resizeterm(ts.lines, ts.columns)
                stdscr.clear()  # force a full repaint (avoid stale cells on grow)
        except (curses.error, OSError):
            pass

        # Visible list = base(mode) -> filter by query -> order. Every view
        # flows through the same order_notes() so search and sort compose the
        # same way everywhere. `keep` = the view has its own order that the
        # "relevance" sort should preserve (loops staleness, dup grouping);
        # `natural` is how that order is labelled in the header.
        q = state["q"]
        if state["trash_mode"]:
            if state["_trash"] is None:
                state["_trash"] = load_trash()
            base, keep, natural = state["_trash"], False, "modified 🞃"
        elif state["dup_mode"] is not None:
            base, keep, natural = state["dup_mode"], True, "grouped"
        elif state["review_mode"]:
            base, keep, natural = find_loops(notes, state["_review"]), True, "most stale first"
        elif state["tagf"] is not None:
            base = filter_by_tags(notes, tagf_active(state["tagf"]))
            keep, natural = False, "modified 🞃"
        else:
            base, keep, natural = notes, False, "modified 🞃"

        filtered = order_notes(base, state["sort"], state["rev"], q, keep)

        # Restore cursor to a specific note after external reload
        restore_path = state.pop("_restore_path", None)
        if restore_path is not None:
            for i, n in enumerate(filtered):
                if n["path"] == restore_path:
                    state["cur"] = i
                    break
            else:
                state["cur"] = 0

        h, _ = stdscr.getmaxyx()
        clamp_scroll(state, filtered, h)

        # History (the "h/H hist" hint) is a ~100ms `git log --follow`, so don't
        # run it while moving — it would stall j/k. Use the cached count if we
        # have it; otherwise show no hint yet and compute it once we settle (an
        # idle tick below).
        cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
        if cur_path != state["_hist_path"]:
            state["_hist_path"] = cur_path
            if cur_path in state["_hist_cache"]:
                state["_hist_count"] = state["_hist_cache"][cur_path]
                state["_hist_dirty"] = False
            else:
                state["_hist_count"] = 0
                state["_hist_dirty"] = cur_path is not None

        draw(stdscr, filtered, state)

        # Poll quickly only while a history lookup is pending (so the hint
        # appears soon after you stop); otherwise idle at the slow scan cadence.
        stdscr.timeout(120 if state["_hist_dirty"] else 2000)
        k = stdscr.getch()

        # ----------------------------
        # Quit
        # ----------------------------

        if k == -1:
            # Settled on a note: now safe to compute its history count (cached).
            if state["_hist_dirty"]:
                state["_hist_dirty"] = False
                cp = state["_hist_path"]
                if cp:
                    rel = os.path.relpath(cp, NOTES_DIR)
                    r = subprocess.run(
                        ["git", "log", "--follow", "-2", "--format=%H", "--", rel],
                        cwd=NOTES_DIR, capture_output=True, text=True
                    )
                    cnt = sum(1 for x in r.stdout.strip().splitlines() if x)
                    state["_hist_cache"][cp] = cnt
                    if cp == state["_hist_path"]:
                        state["_hist_count"] = cnt

            # Scan for external changes / Syncthing conflicts at most every 2s
            # (the adaptive timeout can fire this branch as often as 120ms).
            if time.monotonic() - last_scan >= SCAN_EVERY:
                last_scan = time.monotonic()
                state["_trash"] = None   # pick up external trash changes too
                new_snap = file_snapshot(NOTES_DIR)
                notes, changed = incremental_update(notes, snap, new_snap)
                state["_conflicts"] = find_conflicts()
                if changed:
                    snap = file_snapshot(NOTES_DIR)
                    state["_dups"] = find_duplicates(notes)
                    state["_review"] = load_review()   # inline scheduling may have written it
                    state["_hist_cache"].clear()
                    if state["dup_mode"] is not None:
                        state["dup_mode"] = state["_dups"]
                    cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
                    state["_restore_path"] = cur_path
                    git_commit("sync: external changes")
                # Recompute the due-loop badge on every idle tick, not just on
                # file changes: in a long tmux session a loop can come due
                # purely by time passing.
                state["_loops_due"] = len(find_loops(notes, state["_review"]))

        # ----------------------------
        # Tag prompt mode (intercepts all keys while active)
        # ----------------------------

        elif state["tag_mode"]:
            if k == 27:  # ESC — cancel
                state["tag_mode"] = False
                state["tag_input"] = ""

            elif k in [10, 13]:  # Enter — apply
                if filtered and 0 <= state["cur"] < len(filtered):
                    note = filtered[state["cur"]]
                    new_tags = parse_tag_input(state["tag_input"])
                    if new_tags and add_tags(note["path"], new_tags):
                        state["_last_tags"] = state["tag_input"].strip()
                        refresh_notes()
                        state["_restore_path"] = note["path"]
                state["tag_mode"] = False
                state["tag_input"] = ""

            elif k in [curses.KEY_BACKSPACE, 127, 8]:
                state["tag_input"] = state["tag_input"][:-1]

            elif 32 <= k <= 126:
                state["tag_input"] += chr(k)

            continue

        # ----------------------------
        # Schedule prompt mode (intercepts all keys while active)
        # ----------------------------

        elif state["sched_mode"]:
            if k == 27:  # ESC — cancel
                state["sched_mode"] = False
                state["sched_input"] = ""

            elif k in [10, 13]:  # Enter — apply
                if filtered and 0 <= state["cur"] < len(filtered):
                    note = filtered[state["cur"]]
                    due = parse_when(state["sched_input"])
                    if due is not None:
                        schedule_loop(state["_review"], note["id"], due)
                        save_review(state["_review"])
                        refresh_notes()
                state["sched_mode"] = False
                state["sched_input"] = ""

            elif k in [curses.KEY_BACKSPACE, 127, 8]:
                state["sched_input"] = state["sched_input"][:-1]

            elif 32 <= k <= 126:
                state["sched_input"] += chr(k)

            continue

        # ----------------------------
        # Quit
        # ----------------------------

        elif k == ord("q") and not state["search_mode"]:
            if 0 <= state["cur"] < len(filtered):
                save_cursor(filtered[state["cur"]]["path"])
            break

        # ----------------------------
        # Open note
        # ----------------------------

        elif k in [10, 13] and filtered and not state["search_mode"]:
            open_selected(filtered[state["cur"]])

        elif k == ord("e") and filtered and not state["search_mode"]:
            open_selected(filtered[state["cur"]], end=True)

        # ----------------------------
        # Incremental search mode
        # ----------------------------

        elif k == 27 and not state["search_mode"] and (state["q"] or state["dup_mode"] is not None or state["trash_mode"] or state["review_mode"] or state["tagf"] is not None):
            cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
            if state["q"]:
                # First ESC: clear the search filter, stay in the current view
                # and fall back to its natural order (relevance with no query).
                state["q"] = ""
                state["sort"] = "relevance"
                if cur_path:
                    state["_restore_path"] = cur_path
            else:
                # Second ESC: leave the duplicates / trash / resurface view for
                # the notes list. (Trash paths don't exist there, so don't try
                # to keep the cursor on one.)
                was_trash = state["trash_mode"]
                state["dup_mode"] = None
                state["trash_mode"] = False
                state["review_mode"] = False
                state["sort"] = "relevance"
                if cur_path and not was_trash:
                    state["_restore_path"] = cur_path
            state["cur"] = 0
            state["off"] = 0
            state["p_scroll"] = 0

        elif state["search_mode"]:
            if k == 27:  # ESC
                state["search_mode"] = False

            elif k in [10, 13]:
                state["search_mode"] = False
                if filtered:
                    open_selected(filtered[state["cur"]])
                elif state["q"].strip() and not (
                        state["review_mode"] or state["dup_mode"] is not None
                        or state["trash_mode"] or state["tagf"] is not None):
                    # "no match -> create a note from the query" only makes
                    # sense in the plain notes view, not while filtering a
                    # loops / duplicates / trash subset.
                    dest = new_note_with_title(state["q"].strip())
                    refresh_notes()
                    state["q"] = ""
                    state["cur"] = 0
                    state["off"] = 0
                    state["p_scroll"] = 0
                    if dest:
                        state["_restore_path"] = dest

            elif k == curses.KEY_DOWN:
                state["cur"] += 1
                state["p_scroll"] = 0

            elif k == curses.KEY_UP:
                state["cur"] -= 1
                state["p_scroll"] = 0

            elif k in [curses.KEY_BACKSPACE, 127, 8]:
                state["q"] = state["q"][:-1]
                state["cur"] = 0
                state["off"] = 0

            elif 32 <= k <= 126:
                state["q"] += chr(k)
                state["cur"] = 0
                state["off"] = 0

            continue

        # ----------------------------
        # Enter search mode
        # ----------------------------

        elif k == ord("/"):
            # `/` filters the current view (notes, trash, duplicates, or loops);
            # it no longer drops you out of the special views. Searching selects
            # the relevance sort (best matches first) until you pick another.
            state["search_mode"] = True
            state["q"] = ""
            state["cur"] = 0
            state["off"] = 0
            state["sort"] = "relevance"

        # ----------------------------
        # Navigation
        # ----------------------------

        elif k in [ord("j"), curses.KEY_DOWN]:
            state["cur"] += 1
            state["p_scroll"] = 0

        elif k in [ord("k"), curses.KEY_UP]:
            state["cur"] -= 1
            state["p_scroll"] = 0

        elif k == ord("G"):
            state["cur"] = len(filtered) - 1
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        elif k == ord("g"):
            stdscr.timeout(1000)   # fixed window for the chord's second key
            nxt = stdscr.getch()   # (the loop resets the timeout next iteration)

            if nxt == ord("g"):
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                clamp_scroll(state, filtered, h)

            elif nxt == ord("d"):
                if state["dup_mode"] is not None:
                    state["dup_mode"] = None
                elif state["_dups"]:
                    state["dup_mode"] = state["_dups"]
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                state["sort"] = "relevance"

            elif nxt == ord("t"):
                state["trash_mode"] = not state["trash_mode"]
                state["_trash"] = None
                state["dup_mode"] = None
                state["review_mode"] = False
                state["tagf"] = None
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                state["sort"] = "relevance"

            elif nxt == ord("r"):
                state["review_mode"] = not state["review_mode"]
                state["dup_mode"] = None
                state["trash_mode"] = False
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                state["sort"] = "relevance"

        # Ctrl-f
        elif k == 6:
            state["cur"] += h - 4
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # Ctrl-b
        elif k == 2:
            state["cur"] -= h - 4
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # Ctrl-d
        elif k == 4:
            state["cur"] += max(1, (h - 4) // 2)
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # Ctrl-u
        elif k == 21:
            state["cur"] -= max(1, (h - 4) // 2)
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        # ----------------------------
        # Preview scrolling
        # ----------------------------

        elif k == curses.KEY_NPAGE:
            state["p_scroll"] += 5

        elif k == curses.KEY_PPAGE:
            state["p_scroll"] = max(0, state["p_scroll"] - 5)

        # ----------------------------
        # Trash note
        # ----------------------------

        elif k == ord("d") and filtered and not state["trash_mode"]:
            cur = state["cur"]
            note = filtered[cur]
            orig = note["path"]
            dest = trash_note(note)
            record({"kind": "trash", "orig": orig, "trash": dest})
            refresh_notes()
            state["cur"] = cur
            state["p_scroll"] = 0

        # ----------------------------
        # Resurface actions: snooze / mark done
        # ----------------------------

        elif k == ord("z") and state["review_mode"] and filtered:
            note = filtered[state["cur"]]
            snooze_loop(state["_review"], note["id"])
            save_review(state["_review"])
            refresh_notes()
            state["p_scroll"] = 0

        elif k == ord("S") and state["review_mode"] and filtered:
            state["sched_mode"] = True
            state["sched_input"] = ""

        elif k == ord("x") and state["review_mode"] and filtered:
            note = filtered[state["cur"]]
            mod_ts = note.get("modificationDate")
            if remove_tag(note["path"], LOOP_TAG):
                git_commit(f"close loop: {title(note)}")
                record({"kind": "loop", "path": note["path"], "mod": mod_ts})
                refresh_notes()
            state["p_scroll"] = 0

        # ----------------------------
        # Tag note ( # to enter tags, . to repeat last addition )
        # ----------------------------

        elif k == ord("#") and filtered and not state["trash_mode"]:
            state["tag_mode"] = True
            state["tag_input"] = ""

        elif k == ord(".") and filtered and state["_last_tags"] and not state["trash_mode"]:
            note = filtered[state["cur"]]
            new_tags = parse_tag_input(state["_last_tags"])
            if new_tags and add_tags(note["path"], new_tags):
                refresh_notes()
                state["_restore_path"] = note["path"]
                state["p_scroll"] = 0

        # ----------------------------
        # Sort mode
        # ----------------------------

        elif k == ord("s"):
            if state["sort"] in SORTS:
                idx = SORTS.index(state["sort"])
                state["sort"] = SORTS[(idx + 1) % len(SORTS)]
            else:  # leaving the default "relevance" sort
                state["sort"] = SORTS[0]

        # reverse sort
        elif k == ord("r"):
            state["rev"] = not state["rev"]

        # undo: reverse most-recent destructive action (trash, loop-close, or edit)
        elif k == ord("u"):
            if state["trash_mode"] and filtered and 0 <= state["cur"] < len(filtered):
                restore_note(filtered[state["cur"]])
                refresh_notes()
                state["cur"] = max(0, state["cur"] - 1)
            elif state["_undo"]:
                act = state["_undo"].pop()
                focus = undo_action(act)
                state["_redo"].append(act)
                refresh_notes()
                if focus:
                    state["_restore_path"] = focus
                state["p_scroll"] = 0
            elif undo_trash():  # legacy fallback for notes trashed before this session
                refresh_notes()

        # redo: re-apply most-recently-undone action (Ctrl-R)
        elif k == 18:
            if state["_redo"]:
                act = state["_redo"].pop()
                focus = redo_action(act)
                state["_undo"].append(act)
                refresh_notes()
                if focus:
                    state["_restore_path"] = focus
                state["p_scroll"] = 0

        # new note
        elif k == ord("n"):
            dest = new_note()
            refresh_notes()
            state["cur"] = 0
            state["off"] = 0
            state["p_scroll"] = 0
            if dest:
                state["_restore_path"] = dest

        # resolve conflict
        elif k == ord("c"):
            conflicts = find_conflicts()
            if conflicts:
                original, conflict = conflicts[0]
                resolve_conflict(original, conflict)
                refresh_notes()

        # history
        elif k == ord("h") and filtered:
            open_hist_last(filtered[state["cur"]])
            refresh_notes()

        elif k == ord("H") and filtered:
            hist_view(stdscr, filtered[state["cur"]])
            refresh_notes()


def load_notes_dir():
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as f:
            for line in f:
                if line.startswith("notes_dir="):
                    return os.path.expanduser(line.split("=", 1)[1].strip())
    except FileNotFoundError:
        pass
    return None


def save_notes_dir(path):
    os.makedirs(os.path.dirname(CONFIG_FILE), exist_ok=True)
    with open(CONFIG_FILE, "w", encoding="utf-8") as f:
        f.write(f"notes_dir={path}\n")


def prompt_notes_dir(current=None):
    default = current or os.path.expanduser("~/notes")
    if current:
        print(f"notoj: notes directory not found: {current}")
    else:
        print("notoj: no notes directory configured.")
    while True:
        print(f"Notes directory [{default}]: ", end="", flush=True)
        ans = input().strip()
        path = os.path.expanduser(ans if ans else default)
        if os.path.isdir(path):
            return path
        print(f"  '{path}' does not exist. Create it? [y/N] ", end="", flush=True)
        if input().strip().lower() == "y":
            os.makedirs(path)
            return path


def offer_simplenote_import(notes_dir):
    if glob.glob(os.path.join(notes_dir, "*.md")):
        return

    script = os.path.join(SCRIPT_DIR, "simplenote_convert_to_md.py")
    if not os.path.exists(script):
        return

    print("Notes directory is empty. Import from a Simplenote export? [y/N] ", end="", flush=True)
    if input().strip().lower() != "y":
        return

    print("Path to Simplenote export directory: ", end="", flush=True)
    export_dir = os.path.expanduser(input().strip())
    if not os.path.isdir(export_dir):
        print(f"  '{export_dir}' not found, skipping import.")
        return

    subprocess.run([sys.executable, script, export_dir, notes_dir])


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print(HELP)
        sys.exit(0)

    saved = load_notes_dir()
    if saved and os.path.isdir(saved):
        NOTES_DIR = saved
    else:
        NOTES_DIR = prompt_notes_dir(saved)
        save_notes_dir(NOTES_DIR)

    TRASH_DIR = os.path.join(NOTES_DIR, ".trash")
    STATE_FILE = os.path.join(NOTES_DIR, ".notoj_state")
    REVIEW_FILE = os.path.join(NOTES_DIR, ".notoj_review.json")
    os.environ["NOTOJ_NOTES_DIR"] = NOTES_DIR

    offer_simplenote_import(NOTES_DIR)

    try:
        curses.wrapper(run)
    finally:
        set_cursor_style(0)  # don't leave a blinking block in the shell
