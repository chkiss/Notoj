def title(n):
    t = n.get("title") or ""
    if not t:
        c = (n.get("content") or "").strip()
        t = c.split("\n")[0] if c else ""
    return t or "(untitled)"


def content(n):
    return n.get("content") or ""


def tags(n):
    return " ".join(n.get("tags") or [])


def is_recent(n):
    m = n.get("modificationDate", 0)
    return m and (datetime.now().timestamp() - float(m)) < 3600


