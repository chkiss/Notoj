# Main loop
# ----------------------------

def run(stdscr):
    git_init()
    curses.curs_set(0)
    init_colors()
    KEY = build_key_dispatch()   # {action: keycode}, with config rebindings
    CHORDS, CHORD_PREFIXES = build_chord_dispatch()   # 2-key chords (gg/gt/…)
    stdscr.timeout(2000)
    if hasattr(curses, "set_escdelay"):
        # Keep bare ESC snappy (default is up to 1s) and bound the window in
        # which an ESC+letter is gathered as a Meta/Alt chord in the filter.
        curses.set_escdelay(25)

    # Restore the undo/redo stacks from previous sessions, trimming the journal
    # first if it has grown large, then mark this session's start.
    compact_log()
    _undo0, _redo0 = load_undo()
    log_event({"t": "session", "ev": "launch", "sess": SESSION_ID})

    state = {
        "cur": 0,
        "off": 0,
        "p_scroll": 0,
        "q": "",
        "q_pos": 0,             # insertion-cursor index into q while searching
        "sort": "relevance",
        "rev": True,
        "search_mode": False,
        "tag_mode": False,
        "tag_input": "",
        "_last_tags": "",
        "dup_mode": None,
        "_dups": [],
        "trash_mode": False,
        "_trash": None,         # cached trash listing; None = reload on next draw
        "review_mode": False,
        "tagf": None,           # tag-filter view: {"tags": [...], "idx": -1|i}
        "_tags_ui": {"mode_i": 0},   # tags view sort mode, kept across visits
        "sched_mode": False,
        "sched_input": "",
        "_review": load_review(),
        "_loops_due": 0,
        "_undo": _undo0,
        "_redo": _redo0,
        # One-line amber status bar. Distinct messages for the current action
        # are pooled (deduped) and rotated through the single line with an
        # (i/n) counter rather than truncated or wrapped — see pool_msg().
        "_msg_pool": [],
        "_msg_idx": 0,
        "_msg_rot": 0.0,        # monotonic time of the last rotation
        "_xsess_armed": None,   # ("undo"|"redo", sess) while a cross-session prompt waits
        "_hist_path": None,
        "_hist_count": 0,
        "_hist_dirty": False,
        "_hist_cache": {},      # path -> commit count (lazy; cleared on change)
        "_conflicts": [],
        "_filter_cache": {},    # memoized rank/filter, rebuilt only on real input change
    }

    notes = load()
    snap = file_snapshot(NOTES_DIR)
    if prune_review(state["_review"], notes):
        save_review(state["_review"])
    state["_dups"] = find_duplicates(notes)
    state["_loops_due"] = len(find_loops(notes, state["_review"]))
    state["_conflicts"] = find_conflicts()

    saved = load_cursor()
    if saved:
        state["_restore_path"] = saved

    def refresh_notes():
        nonlocal notes, snap
        new_snap = file_snapshot(NOTES_DIR)
        notes, changed = incremental_update(notes, snap, new_snap)
        # incremental_update may rename files (title normalization), so after
        # a change re-snapshot — like the idle scan does — rather than keeping
        # pre-rename paths that would be reprocessed on the next tick.
        snap = file_snapshot(NOTES_DIR) if changed else new_snap
        state["_trash"] = None
        state["_dups"] = find_duplicates(notes)
        # Inline "#loop <when>" scheduling writes the review file from inside
        # the update pipeline, so reload it rather than trust the in-memory copy.
        state["_review"] = load_review()
        state["_loops_due"] = len(find_loops(notes, state["_review"]))
        state["_conflicts"] = find_conflicts()
        state["_hist_cache"].clear()   # commit counts may have changed
        if state["dup_mode"] is not None:
            state["dup_mode"] = state["_dups"]

    def push_msg(*texts):
        """Add status line(s) to the bar's pool for the current action, deduped.
        Several distinct messages share the one line and rotate (see pool_msg)
        rather than overwrite each other or overflow — so a long prompt is split
        into parts that cycle, never truncated."""
        for text in texts:
            if text and text not in state["_msg_pool"]:
                state["_msg_pool"].append(text)
        state["_msg_rot"] = time.monotonic()   # show the new message a full beat

    def clear_msgs():
        state["_msg_pool"] = []
        state["_msg_idx"] = 0

    def record(act):
        """Push a fresh destructive action onto the undo stack; a new action
        invalidates the redo stack (standard undo/redo semantics) and is
        journaled so it survives across sessions."""
        if act:
            act["sess"] = SESSION_ID
            state["_undo"].append(act)
            state["_redo"] = []
            log_event({"t": "act", "sess": SESSION_ID, "act": act})

    def undo_step():
        """Apply the top undo act. A stale note (changed underneath an edit) is
        skipped with a message, leaving the stacks untouched."""
        act = state["_undo"][-1]
        focus = undo_action(act, state["_review"])
        if focus is STALE:
            push_msg("undo skipped — note changed elsewhere since this edit")
            return
        state["_undo"].pop()
        state["_redo"].append(act)
        log_event({"t": "undo", "sess": SESSION_ID})
        refresh_notes()
        if focus:
            state["_restore_path"] = focus
        state["p_scroll"] = 0

    def redo_step():
        act = state["_redo"][-1]
        focus = redo_action(act, state["_review"])
        if focus is STALE:
            push_msg("redo skipped — note changed elsewhere since this edit")
            return
        state["_redo"].pop()
        state["_undo"].append(act)
        log_event({"t": "redo", "sess": SESSION_ID})
        refresh_notes()
        if focus:
            state["_restore_path"] = focus
        state["p_scroll"] = 0

    def xsess_arm(direction, sess):
        """Arm the cross-session confirmation and pool its message. The prompt is
        pushed as two parts — the situation and the controls — so on a narrow
        terminal they rotate through the bar instead of the single long line
        being clipped. Worded by whether the other session is a still-running
        instance or a finished previous one."""
        state["_xsess_armed"] = (direction, sess)
        clear_msgs()
        if session_alive(sess):
            push_msg(f"next change is from another running notoj — {direction} "
                     f"it anyway?",
                     "y to confirm, any other key cancels")
        else:
            push_msg(f"already at the oldest change of this session — {direction} "
                     f"from a previous session?",
                     "y/u to continue, any other key cancels")

    def xsess_step(direction):
        if direction == "undo" and state["_undo"]:
            undo_step()
        elif direction == "redo" and state["_redo"]:
            redo_step()

    def open_selected(note, end=False):
        """Open `note` in Vim. An active search query is carried into Vim so the
        matches are highlighted and the cursor lands on the first one (`n` cycles
        the rest). Trashed notes first get an interstitial saying that saving any
        change restores them from the trash."""
        search = vim_search_pattern(state["q"])
        if state["trash_mode"]:
            if confirm_screen(stdscr, TRASH_EDIT_NOTICE):
                restored = edit_trash_note(note, end=end, search=search)
                refresh_notes()
                state["_hist_path"] = None
                if restored:
                    state["_restore_path"] = restored
        else:
            record(open_note(note, end=end, search=search))
            refresh_notes()
            state["_hist_path"] = None
            state["_restore_path"] = note["path"]

    last_scan = time.monotonic()   # throttles the external-change / conflict scan
    SCAN_EVERY = 2.0

    while True:
        # Pick up terminal resizes live: ncurses won't refresh getmaxyx() on
        # its own between key presses, so poll the real size and resize when it
        # changes. This makes the list reflow (more/fewer columns) immediately.
        try:
            ts = os.get_terminal_size()
            if (ts.lines, ts.columns) != stdscr.getmaxyx():
                curses.resizeterm(ts.lines, ts.columns)
                stdscr.clear()  # force a full repaint (avoid stale cells on grow)
        except (curses.error, OSError):
            pass

        # Visible list = base(mode) -> filter by query -> order. Every view
        # flows through the same order_notes() so search and sort compose the
        # same way everywhere. `keep` = the view has its own order that the
        # "relevance" sort should preserve (loops staleness, dup grouping);
        # `natural` is how that order is labelled in the header.
        q = state["q"]
        # Resolve the lazily-loaded trash list up front so its identity is
        # stable in the cache key below (rather than flipping None->list mid-key).
        if state["trash_mode"] and state["_trash"] is None:
            state["_trash"] = load_trash()

        def compute_filtered():
            if state["trash_mode"]:
                base, keep = state["_trash"], False
            elif state["dup_mode"] is not None:
                base, keep = state["dup_mode"], True
            elif state["review_mode"]:
                base, keep = find_loops(notes, state["_review"]), True
            elif state["tagf"] is not None:
                base, keep = filter_by_tags(notes, tagf_active(state["tagf"])), False
            else:
                base, keep = notes, False
            return order_notes(base, state["sort"], state["rev"], q, keep)

        # Rank/filter only when an input that affects the list changes — not on
        # every j/k. id(notes) flips exactly when an incremental reload swaps in
        # a fresh list (it returns the same object when nothing changed), so it
        # is a free generation marker; the rest are the mode, sort and query.
        filter_key = (
            id(notes), state["sort"], state["rev"], q,
            state["trash_mode"], id(state["_trash"]),
            id(state["dup_mode"]), state["review_mode"], id(state["_review"]),
            tuple(tagf_active(state["tagf"])) if state["tagf"] is not None else None,
        )
        filtered = frame_cache(state["_filter_cache"], filter_key, compute_filtered)

        # Restore cursor to a specific note after external reload
        restore_path = state.pop("_restore_path", None)
        if restore_path is not None:
            for i, n in enumerate(filtered):
                if n["path"] == restore_path:
                    state["cur"] = i
                    break
            else:
                state["cur"] = 0

        h, w = stdscr.getmaxyx()
        clamp_scroll(state, filtered, h)

        # An editor/vimdiff launch failed because the program isn't installed:
        # surface it on the bar (the launch was swallowed, not crashed). Checked
        # here, before the draw, so it shows even when the triggering handler
        # ended in `continue` (e.g. creating a note from the search box).
        if launch.missing:
            push_msg(f"can't launch {launch.missing} — check default_editor / tag_editor")
            launch.missing = None

        # The status bar only rotates when its pooled messages can't all fit on
        # one line at the current width; when they fit they're shown whole and
        # statically (no rotation, no fast-poll).
        _pool = state["_msg_pool"]
        rotating = len(_pool) > 1 and disp_width(MSG_JOIN.join(_pool)) > (w - 1)

        # History (the "h/H hist" hint) is a ~100ms `git log --follow`, so don't
        # run it while moving — it would stall j/k. Use the cached count if we
        # have it; otherwise show no hint yet and compute it once we settle (an
        # idle tick below).
        cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
        if cur_path != state["_hist_path"]:
            state["_hist_path"] = cur_path
            if cur_path in state["_hist_cache"]:
                state["_hist_count"] = state["_hist_cache"][cur_path]
                state["_hist_dirty"] = False
            else:
                state["_hist_count"] = 0
                state["_hist_dirty"] = cur_path is not None

        draw(stdscr, filtered, state)

        # Poll quickly while a history lookup is pending (so the hint appears
        # soon after you stop) or while several status messages are rotating
        # through the bar; otherwise idle at the slow scan cadence.
        stdscr.timeout(120 if state["_hist_dirty"]
                       else (400 if rotating else 2000))
        t_wait = time.monotonic()
        k = stdscr.getch()

        # Dead-terminal guard: when the pty/SSH session dies, getch returns
        # ERR instantly instead of honoring the timeout, which would busy-
        # spin at 100% CPU with no UI attached. A genuine timeout takes
        # >=120ms; a run of instant ERRs means the input is gone — exit.
        if k == -1 and time.monotonic() - t_wait < 0.01:
            state["_eof_spins"] = state.get("_eof_spins", 0) + 1
            if state["_eof_spins"] > 50:
                if 0 <= state["cur"] < len(filtered):
                    save_cursor(filtered[state["cur"]]["path"])
                break
        else:
            state["_eof_spins"] = 0

        # Cross-session undo/redo prompt is armed: this keystroke either
        # confirms (y, or pressing the same undo/redo key again) or cancels
        # (anything else). Either way it is consumed here.
        if state["_xsess_armed"] is not None and k != -1:
            direction, _sess = state["_xsess_armed"]
            state["_xsess_armed"] = None
            clear_msgs()
            if k in (ord("y"), ord("Y")) or key_matches(k, KEY[direction]):
                xsess_step(direction)
            continue

        # Any real keystroke starts a new action: clear the pooled messages from
        # the previous one before this key runs (the armed-prompt case above
        # already returned).
        if k != -1:
            clear_msgs()

        # ----------------------------
        # Quit
        # ----------------------------

        if k == -1:
            # Rotate the status bar to the next pooled message once its beat
            # elapses, wrapping around (only while it can't be shown whole).
            if rotating and time.monotonic() - state["_msg_rot"] >= MSG_ROTATE_SECS:
                state["_msg_idx"] = (state["_msg_idx"] + 1) % len(state["_msg_pool"])
                state["_msg_rot"] = time.monotonic()

            # Settled on a note: now safe to compute its history count (cached).
            if state["_hist_dirty"]:
                state["_hist_dirty"] = False
                cp = state["_hist_path"]
                if cp:
                    rel = os.path.relpath(cp, NOTES_DIR)
                    r = subprocess.run(
                        ["git", "log", "--follow", "-2", "--format=%H", "--", rel],
                        cwd=NOTES_DIR, capture_output=True, text=True
                    )
                    cnt = sum(1 for x in r.stdout.strip().splitlines() if x)
                    state["_hist_cache"][cp] = cnt
                    if cp == state["_hist_path"]:
                        state["_hist_count"] = cnt

            # Scan for external changes / Syncthing conflicts at most every 2s
            # (the adaptive timeout can fire this branch as often as 120ms).
            if time.monotonic() - last_scan >= SCAN_EVERY:
                last_scan = time.monotonic()
                state["_trash"] = None   # pick up external trash changes too
                new_snap = file_snapshot(NOTES_DIR)
                notes, changed = incremental_update(notes, snap, new_snap)
                state["_conflicts"] = find_conflicts()
                if changed:
                    snap = file_snapshot(NOTES_DIR)
                    state["_dups"] = find_duplicates(notes)
                    state["_review"] = load_review()   # inline scheduling may have written it
                    state["_hist_cache"].clear()
                    if state["dup_mode"] is not None:
                        state["dup_mode"] = state["_dups"]
                    cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
                    state["_restore_path"] = cur_path
                    git_commit("sync: external changes")
                # Recompute the due-loop badge on every idle tick, not just on
                # file changes: in a long tmux session a loop can come due
                # purely by time passing.
                state["_loops_due"] = len(find_loops(notes, state["_review"]))

        # ----------------------------
        # Tag prompt mode (intercepts all keys while active)
        # ----------------------------

        elif state["tag_mode"]:
            if k == 27:  # ESC — cancel
                state["tag_mode"] = False
                state["tag_input"] = ""

            elif k in [10, 13]:  # Enter — apply
                if filtered and 0 <= state["cur"] < len(filtered):
                    note = filtered[state["cur"]]
                    new_tags = parse_tag_input(state["tag_input"])
                    mod_ts = note.get("modificationDate")
                    added = add_tags_keep_date(note["path"], new_tags) if new_tags else []
                    if added:
                        record({"kind": "tags", "path": note["path"],
                                "added": added, "mod": mod_ts})
                        state["_last_tags"] = state["tag_input"].strip()
                        git_commit(f"tag: {_stem(note['path'])}")
                        refresh_notes()
                        state["_restore_path"] = note["path"]
                state["tag_mode"] = False
                state["tag_input"] = ""

            elif k in [curses.KEY_BACKSPACE, 127, 8]:
                state["tag_input"] = state["tag_input"][:-1]

            else:
                ch = typed_char(stdscr, k)
                if ch:
                    state["tag_input"] += ch

            continue

        # ----------------------------
        # Schedule prompt mode (intercepts all keys while active)
        # ----------------------------

        elif state["sched_mode"]:
            if k == 27:  # ESC — cancel
                state["sched_mode"] = False
                state["sched_input"] = ""

            elif k in [10, 13]:  # Enter — apply
                if filtered and 0 <= state["cur"] < len(filtered):
                    note = filtered[state["cur"]]
                    due = parse_when(state["sched_input"])
                    if due is not None:
                        nid = note["id"]
                        before = state["_review"].get(nid)
                        schedule_loop(state["_review"], nid, due)
                        save_review(state["_review"])
                        record({"kind": "defer", "id": nid, "path": note["path"],
                                "before": before, "after": state["_review"][nid]})
                        refresh_notes()
                state["sched_mode"] = False
                state["sched_input"] = ""

            elif k in [curses.KEY_BACKSPACE, 127, 8]:
                state["sched_input"] = state["sched_input"][:-1]

            else:
                ch = typed_char(stdscr, k)
                if ch:
                    state["sched_input"] += ch

            continue

        # ----------------------------
        # Quit
        # ----------------------------

        elif key_matches(k, KEY["quit"]) and not state["search_mode"]:
            if 0 <= state["cur"] < len(filtered):
                save_cursor(filtered[state["cur"]]["path"])
            break

        # ----------------------------
        # Open note
        # ----------------------------

        elif key_matches(k, KEY["open"]) and filtered and not state["search_mode"]:
            open_selected(filtered[state["cur"]])

        elif key_matches(k, KEY["open_end"]) and filtered and not state["search_mode"]:
            open_selected(filtered[state["cur"]], end=True)

        # ----------------------------
        # Incremental search mode
        # ----------------------------

        elif k == 27 and not state["search_mode"] and (state["q"] or state["dup_mode"] is not None or state["trash_mode"] or state["review_mode"] or state["tagf"] is not None):
            cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
            if state["q"]:
                # First ESC: clear the search filter, stay in the current view
                # and fall back to its natural order (relevance with no query).
                state["q"] = ""
                state["sort"] = "relevance"
                if cur_path:
                    state["_restore_path"] = cur_path
            else:
                # Second ESC: leave the duplicates / trash / resurface /
                # tag-filter view for the notes list. (Trash paths don't exist
                # there, so don't try to keep the cursor on one.) A tag filter
                # entered from the tags view goes back there instead, with the
                # cursor on the tag it came from.
                was_trash = state["trash_mode"]
                reopen_focus = None
                if state["tagf"] is not None and state["tagf"].get("from_T"):
                    reopen_focus = state["tagf"]["tags"][0]
                state["dup_mode"] = None
                state["trash_mode"] = False
                state["review_mode"] = False
                state["tagf"] = None
                state["sort"] = "relevance"
                if cur_path and not was_trash:
                    state["_restore_path"] = cur_path
                if reopen_focus is not None:
                    sel = tags_view(stdscr, notes, focus=reopen_focus,
                                    ui=state["_tags_ui"])
                    if sel is MODAL_QUIT:
                        if cur_path:
                            save_cursor(cur_path)
                        break
                    if sel:
                        state["tagf"] = {"tags": [sel], "idx": -1, "from_T": True}
                        state.pop("_restore_path", None)
            state["cur"] = 0
            state["off"] = 0
            state["p_scroll"] = 0

        elif state["search_mode"]:
            # The filter field is editable text with an insertion cursor
            # (state["q_pos"], an index into state["q"]). Clamp it first so it
            # can't dangle past the query if q was reset elsewhere.
            state["q_pos"] = min(state.get("q_pos", len(state["q"])), len(state["q"]))

            if k == 27:  # ESC — bare ESC exits; ESC+letter is a Meta (Alt) chord.
                # A real Alt-key sends ESC and the letter back-to-back, so the
                # follow-up is already buffered after set_escdelay; peek for it
                # with a short window (the loop resets the timeout next iter).
                stdscr.timeout(25)
                nxt = stdscr.getch()
                q, p = state["q"], state["q_pos"]
                if nxt in (ord("b"), ord("B")):        # Alt-b — back one word
                    state["q_pos"] = word_boundary(q, p, forward=False)
                elif nxt in (ord("f"), ord("F")):      # Alt-f — forward one word
                    state["q_pos"] = word_boundary(q, p, forward=True)
                elif nxt in (ord("d"), ord("D")):      # Alt-d — delete word ahead
                    end = word_boundary(q, p, forward=True)
                    if end > p:
                        state["q"] = q[:p] + q[end:]
                        state["cur"] = 0
                        state["off"] = 0
                elif nxt in (curses.KEY_BACKSPACE, 127, 8):  # Alt-⌫ — delete word back
                    start = word_boundary(q, p, forward=False)
                    if start < p:
                        state["q"] = q[:start] + q[p:]
                        state["q_pos"] = start
                        state["cur"] = 0
                        state["off"] = 0
                else:
                    # Nothing followed (-1) = bare ESC -> leave search. A stray
                    # non-Meta key is dropped; ESC's exit takes precedence.
                    state["search_mode"] = False

            elif k in [10, 13]:
                state["search_mode"] = False
                if filtered:
                    open_selected(filtered[state["cur"]])
                elif state["q"].strip() and not (
                        state["review_mode"] or state["dup_mode"] is not None
                        or state["trash_mode"] or state["tagf"] is not None):
                    # "no match -> create a note from the query" only makes
                    # sense in the plain notes view, not while filtering a
                    # loops / duplicates / trash subset.
                    dest = new_note_with_title(state["q"].strip())
                    refresh_notes()
                    state["q"] = ""
                    state["q_pos"] = 0
                    state["cur"] = 0
                    state["off"] = 0
                    state["p_scroll"] = 0
                    if dest:
                        state["_restore_path"] = dest

            elif k == curses.KEY_DOWN:
                state["cur"] += 1
                state["p_scroll"] = 0

            elif k == curses.KEY_UP:
                state["cur"] -= 1
                state["p_scroll"] = 0

            elif k in (curses.KEY_LEFT, 2):    # ←, Ctrl-b — back one char
                state["q_pos"] = max(0, state["q_pos"] - 1)

            elif k in (curses.KEY_RIGHT, 6):   # →, Ctrl-f — forward one char
                state["q_pos"] = min(len(state["q"]), state["q_pos"] + 1)

            elif k in (curses.KEY_HOME, 1):    # Home, Ctrl-a — start of line
                state["q_pos"] = 0

            elif k in (curses.KEY_END, 5):     # End, Ctrl-e — end of line
                state["q_pos"] = len(state["q"])

            elif k in [curses.KEY_BACKSPACE, 127, 8]:
                # Delete the character before the cursor, not just the last one.
                p = state["q_pos"]
                if p > 0:
                    state["q"] = state["q"][:p - 1] + state["q"][p:]
                    state["q_pos"] = p - 1
                    state["cur"] = 0
                    state["off"] = 0

            elif k == 4:    # Ctrl-d — delete the char under the cursor
                p = state["q_pos"]
                if p < len(state["q"]):
                    state["q"] = state["q"][:p] + state["q"][p + 1:]
                    state["cur"] = 0
                    state["off"] = 0

            elif k == 23:   # Ctrl-w — delete the word before the cursor
                p = state["q_pos"]
                start = word_boundary(state["q"], p, forward=False)
                if start < p:
                    state["q"] = state["q"][:start] + state["q"][p:]
                    state["q_pos"] = start
                    state["cur"] = 0
                    state["off"] = 0

            elif k == 21:   # Ctrl-u — delete from the cursor to the start
                p = state["q_pos"]
                if p > 0:
                    state["q"] = state["q"][p:]
                    state["q_pos"] = 0
                    state["cur"] = 0
                    state["off"] = 0

            elif k == 11:   # Ctrl-k — delete from the cursor to the end
                p = state["q_pos"]
                if p < len(state["q"]):
                    state["q"] = state["q"][:p]
                    state["cur"] = 0
                    state["off"] = 0

            else:
                ch = typed_char(stdscr, k)
                if ch:
                    p = state["q_pos"]
                    state["q"] = state["q"][:p] + ch + state["q"][p:]
                    state["q_pos"] = p + len(ch)
                    state["cur"] = 0
                    state["off"] = 0

            continue

        # ----------------------------
        # Enter search mode
        # ----------------------------

        elif key_matches(k, KEY["search"]):
            # `/` filters the current view (notes, trash, duplicates, or loops);
            # it no longer drops you out of the special views. Searching selects
            # the relevance sort (best matches first) until you pick another.
            state["search_mode"] = True
            state["q"] = ""
            state["q_pos"] = 0
            state["cur"] = 0
            state["off"] = 0
            state["sort"] = "relevance"

        # ----------------------------
        # Navigation
        # ----------------------------

        elif k in NAV_KEYS:
            d = nav_delta(k, h - 2)
            if d == NAV_BOTTOM:
                state["cur"] = len(filtered) - 1
            else:
                state["cur"] += d
            state["p_scroll"] = 0
            clamp_scroll(state, filtered, h)

        elif k in CHORD_PREFIXES:
            stdscr.timeout(1000)   # fixed window for the chord's second key
            nxt = stdscr.getch()   # (the loop resets the timeout next iteration)
            act = CHORDS.get((k, nxt))

            if act == "goto_top":
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                clamp_scroll(state, filtered, h)

            elif act == "dups_view":
                if state["dup_mode"] is not None:
                    state["dup_mode"] = None
                elif state["_dups"]:
                    state["dup_mode"] = state["_dups"]
                state["tagf"] = None
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                state["sort"] = "relevance"

            elif act == "trash_view":
                state["trash_mode"] = not state["trash_mode"]
                state["_trash"] = None
                state["dup_mode"] = None
                state["review_mode"] = False
                state["tagf"] = None
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                state["sort"] = "relevance"

            elif act == "resurface":
                state["review_mode"] = not state["review_mode"]
                state["dup_mode"] = None
                state["trash_mode"] = False
                state["tagf"] = None
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                state["sort"] = "relevance"

        # ----------------------------
        # Preview scrolling
        # ----------------------------

        elif k == curses.KEY_NPAGE:
            state["p_scroll"] += 5

        elif k == curses.KEY_PPAGE:
            state["p_scroll"] = max(0, state["p_scroll"] - 5)

        # ----------------------------
        # Trash note
        # ----------------------------

        elif key_matches(k, KEY["trash"]) and filtered and not state["trash_mode"]:
            cur = state["cur"]
            note = filtered[cur]
            orig = note["path"]
            dest = trash_note(note)
            record({"kind": "trash", "orig": orig, "trash": dest})
            refresh_notes()
            state["cur"] = cur
            state["p_scroll"] = 0

        # ----------------------------
        # Resurface actions: snooze / mark done
        # ----------------------------

        elif key_matches(k, KEY["snooze"]) and state["review_mode"] and filtered:
            note = filtered[state["cur"]]
            nid = note["id"]
            before = state["_review"].get(nid)
            snooze_loop(state["_review"], nid)
            save_review(state["_review"])
            record({"kind": "defer", "id": nid, "path": note["path"],
                    "before": before, "after": state["_review"][nid]})
            refresh_notes()
            state["p_scroll"] = 0

        elif key_matches(k, KEY["schedule"]) and state["review_mode"] and filtered:
            state["sched_mode"] = True
            state["sched_input"] = ""

        elif key_matches(k, KEY["loop_done"]) and state["review_mode"] and filtered:
            note = filtered[state["cur"]]
            mod_ts = note.get("modificationDate")
            if remove_tag(note["path"], LOOP_TAG):
                git_commit(f"close loop: {title(note)}")
                record({"kind": "loop", "path": note["path"], "mod": mod_ts})
                refresh_notes()
            state["p_scroll"] = 0

        # ----------------------------
        # Tag note ( # to enter tags, . to repeat last addition )
        # ----------------------------

        elif key_matches(k, KEY["tag"]) and filtered and not state["trash_mode"]:
            state["tag_mode"] = True
            state["tag_input"] = ""

        elif key_matches(k, KEY["tag_repeat"]) and filtered and state["_last_tags"] and not state["trash_mode"]:
            note = filtered[state["cur"]]
            new_tags = parse_tag_input(state["_last_tags"])
            mod_ts = note.get("modificationDate")
            added = add_tags_keep_date(note["path"], new_tags) if new_tags else []
            if added:
                record({"kind": "tags", "path": note["path"],
                        "added": added, "mod": mod_ts})
                git_commit(f"tag: {_stem(note['path'])}")
                refresh_notes()
                state["_restore_path"] = note["path"]
                state["p_scroll"] = 0

        # ----------------------------
        # Tag filter ( t = notes sharing the selected note's tags, ⇥ cycles
        # all -> each single tag; T = browse all tags )
        # ----------------------------

        elif key_matches(k, KEY["tag_filter"]) and filtered and not state["trash_mode"]:
            note = filtered[state["cur"]]
            ntags = list(note.get("tags") or [])
            if ntags:
                state["tagf"] = {"tags": ntags, "idx": -1}
                state["dup_mode"] = None
                state["review_mode"] = False
                state["sort"] = "relevance"
                state["q"] = ""
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                # The source note matches its own tag set, so keep it selected.
                state["_restore_path"] = note["path"]

        elif k == 9 and state["tagf"] is not None:  # Tab — cycle active tag
            tf = state["tagf"]
            tf["idx"] = tf["idx"] + 1 if tf["idx"] + 1 < len(tf["tags"]) else -1
            cur_path = filtered[state["cur"]]["path"] if 0 <= state["cur"] < len(filtered) else None
            state["cur"] = 0
            state["off"] = 0
            state["p_scroll"] = 0
            if cur_path:
                state["_restore_path"] = cur_path   # keep selection if it still matches

        elif key_matches(k, KEY["help"]):
            if help_view(stdscr) is MODAL_QUIT:
                if filtered and 0 <= state["cur"] < len(filtered):
                    save_cursor(filtered[state["cur"]]["path"])
                break

        elif key_matches(k, KEY["backlinks"]) and filtered and not state["trash_mode"]:
            sel = backlinks_view(stdscr, notes, filtered[state["cur"]])
            if sel is MODAL_QUIT:
                if 0 <= state["cur"] < len(filtered):
                    save_cursor(filtered[state["cur"]]["path"])
                break
            if sel:
                # Jump to the chosen note in the plain notes list (it may not
                # be visible in the current view/filter).
                state["dup_mode"] = None
                state["review_mode"] = False
                state["trash_mode"] = False
                state["tagf"] = None
                state["q"] = ""
                state["sort"] = "relevance"
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0
                state["_restore_path"] = sel

        elif key_matches(k, KEY["tag_browse"]) and not state["trash_mode"]:
            sel = tags_view(stdscr, notes, ui=state["_tags_ui"])
            if sel is MODAL_QUIT:
                if filtered and 0 <= state["cur"] < len(filtered):
                    save_cursor(filtered[state["cur"]]["path"])
                break
            if sel:
                # from_T: ESC from this filter goes back to the tags view
                # (cursor on the tag) rather than to the notes list.
                state["tagf"] = {"tags": [sel], "idx": -1, "from_T": True}
                state["dup_mode"] = None
                state["review_mode"] = False
                state["sort"] = "relevance"
                state["q"] = ""
                state["cur"] = 0
                state["off"] = 0
                state["p_scroll"] = 0

        # ----------------------------
        # Sort mode
        # ----------------------------

        elif key_matches(k, KEY["sort"]):
            if state["sort"] in SORTS:
                idx = SORTS.index(state["sort"])
                state["sort"] = SORTS[(idx + 1) % len(SORTS)]
            else:  # leaving the default "relevance" sort
                state["sort"] = SORTS[0]

        # reverse sort
        elif key_matches(k, KEY["sort_reverse"]):
            state["rev"] = not state["rev"]

        # undo: reverse most-recent recorded action (trash, loop-close, edit,
        # tag, or defer — snooze/schedule)
        elif key_matches(k, KEY["undo"]):
            if state["trash_mode"] and filtered and 0 <= state["cur"] < len(filtered):
                restore_note(filtered[state["cur"]])
                refresh_notes()
                state["cur"] = max(0, state["cur"] - 1)
            elif state["_undo"]:
                nxt = state["_undo"][-1]
                foreign = nxt.get("sess") and nxt["sess"] != SESSION_ID
                if foreign and state["_xsess_armed"] != ("undo", nxt["sess"]):
                    xsess_arm("undo", nxt["sess"])
                else:
                    state["_xsess_armed"] = None
                    undo_step()
            elif not state["trash_mode"]:
                push_msg("nothing to undo")

        # redo: re-apply most-recently-undone action (Ctrl-R by default)
        elif key_matches(k, KEY["redo"]):
            if state["_redo"]:
                nxt = state["_redo"][-1]
                foreign = nxt.get("sess") and nxt["sess"] != SESSION_ID
                if foreign and state["_xsess_armed"] != ("redo", nxt["sess"]):
                    xsess_arm("redo", nxt["sess"])
                else:
                    state["_xsess_armed"] = None
                    redo_step()
            else:
                push_msg("nothing to redo")

        # new note
        elif key_matches(k, KEY["new"]):
            dest = new_note()
            refresh_notes()
            state["cur"] = 0
            state["off"] = 0
            state["p_scroll"] = 0
            if dest:
                state["_restore_path"] = dest

        # resolve conflict
        elif key_matches(k, KEY["conflict"]):
            conflicts = find_conflicts()
            if conflicts:
                original, conflict = conflicts[0]
                resolve_conflict(original, conflict)
                refresh_notes()
            else:
                push_msg("no conflicts to resolve")

        # history
        elif key_matches(k, KEY["hist_diff"]) and filtered:
            if not open_hist_last(filtered[state["cur"]]):
                push_msg("no earlier version of this note")
            refresh_notes()

        elif key_matches(k, KEY["hist_browse"]) and filtered:
            hist_view(stdscr, filtered[state["cur"]])
            refresh_notes()


def load_notes_dir():
    v = config_get("notes_dir")
    return os.path.expanduser(v) if v else None


def save_notes_dir(path):
    global _config_cache
    os.makedirs(os.path.dirname(CONFIG_FILE), exist_ok=True)
    # Preserve any other config lines (e.g. tag_editor.* rules); only replace
    # the notes_dir line.
    lines = []
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as f:
            lines = [ln for ln in f if not ln.strip().startswith("notes_dir=")]
    except FileNotFoundError:
        pass
    if lines and not lines[-1].endswith("\n"):
        lines[-1] += "\n"
    lines.append(f"notes_dir={path}\n")
    with open(CONFIG_FILE, "w", encoding="utf-8") as f:
        f.writelines(lines)
    _config_cache = None   # written file differs from any cached parse


def prompt_notes_dir(current=None):
    default = current or os.path.expanduser("~/notes")
    if current:
        print(f"notoj: notes directory not found: {current}")
    else:
        print("notoj: no notes directory configured.")
    while True:
        print(f"Notes directory [{default}]: ", end="", flush=True)
        ans = input().strip()
        path = os.path.expanduser(ans if ans else default)
        if os.path.isdir(path):
            return path
        print(f"  '{path}' does not exist. Create it? [y/N] ", end="", flush=True)
        if input().strip().lower() == "y":
            os.makedirs(path)
            return path


def offer_simplenote_import(notes_dir):
    if glob.glob(os.path.join(notes_dir, "*.md")):
        return

    script = os.path.join(SCRIPT_DIR, "simplenote_convert_to_md.py")
    if not os.path.exists(script):
        return

    print("Notes directory is empty. Import from a Simplenote export? [y/N] ", end="", flush=True)
    if input().strip().lower() != "y":
        return

    print("Path to Simplenote export directory: ", end="", flush=True)
    export_dir = os.path.expanduser(input().strip())
    if not os.path.isdir(export_dir):
        print(f"  '{export_dir}' not found, skipping import.")
        return

    subprocess.run([sys.executable, script, export_dir, notes_dir])


if __name__ == "__main__":
    # Honor the user's locale so curses decodes/encodes UTF-8: without this,
    # multibyte input (Arabic, accents, emoji) and output are mishandled.
    locale.setlocale(locale.LC_ALL, "")

    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print(HELP)
        sys.exit(0)

    saved = load_notes_dir()
    if saved and os.path.isdir(saved):
        NOTES_DIR = saved
    else:
        NOTES_DIR = prompt_notes_dir(saved)
        save_notes_dir(NOTES_DIR)

    TRASH_DIR = os.path.join(NOTES_DIR, ".trash")
    STATE_FILE = os.path.join(NOTES_DIR, ".notoj_state")
    REVIEW_FILE = os.path.join(NOTES_DIR, ".notoj_review.json")
    os.environ["NOTOJ_NOTES_DIR"] = NOTES_DIR

    # Undo journal: local to this machine (NEVER the synced tree), keyed by
    # notes dir; session id stamps each persisted action with its origin.
    UNDO_LOG = undo_log_path()
    SESSION_ID = f"{os.getpid()}-{int(time.time())}"
    if config_bool("undo.persist", True):
        try:
            os.makedirs(os.path.dirname(UNDO_LOG), exist_ok=True)
        except OSError:
            pass

    offer_simplenote_import(NOTES_DIR)

    try:
        curses.wrapper(run)
    finally:
        set_cursor_style(0)  # don't leave a blinking block in the shell
        log_event({"t": "session", "ev": "quit", "sess": SESSION_ID})
