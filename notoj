def fmt(ts):
    if not ts:
        return "-"
    return datetime.fromtimestamp(float(ts)).strftime("%Y-%m-%d %H:%M")


def ago(ts):
    if not ts:
        return "-"

    diff = int(datetime.now().timestamp() - float(ts))

    if diff < 60:
        return f"{diff}s"
    if diff < 3600:
        return f"{diff // 60}m"
    if diff < 86400:
        return f"{diff // 3600}h"

    days = diff // 86400
    if days < 90:
        return f"{days}d"

    months = days // 30
    if months < 24:
        return f"{months}mo"

    years, rem_months = divmod(months, 12)
    return f"{years}y{rem_months}mo" if rem_months else f"{years}y"


