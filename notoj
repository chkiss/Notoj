def sort_notes(notes, key, rev):
    def k(n):
        if key == "title":
            return title(n).lower()

        if key == "created":
            return n.get("creationDate", 0)

        return n.get("modificationDate", 0)

    return sorted(notes, key=k, reverse=rev)



def _edit_dist(a, b):
    if abs(len(a) - len(b)) > 2:
        return 99
    dp = list(range(len(b) + 1))
    for ca in a:
        ndp = [dp[0] + 1]
        for j, cb in enumerate(b):
            ndp.append(min(dp[j] + (ca != cb), dp[j + 1] + 1, ndp[j] + 1))
        dp = ndp
    return dp[-1]


def save_cursor(path):
    try:
        with open(STATE_FILE, "w", encoding="utf-8") as f:
            f.write(path + "\n")
    except Exception:
        pass


def load_cursor():
    try:
        with open(STATE_FILE, "r", encoding="utf-8") as f:
            return f.read().strip()
    except Exception:
        return ""


def set_cursor_style(code):
    """Emit a DECSCUSR cursor-style escape (e.g. 1 = blinking block, 0 = reset).

    curses' curs_set(2) only requests "very visible", which is no-op-ish under
    tmux and renders steady under mosh. DECSCUSR sends an explicit blink request
    that tmux forwards and mosh honors, so the blink survives a mosh session.
    """
    try:
        sys.stdout.write("\033[%d q" % code)
        sys.stdout.flush()
    except (OSError, ValueError):
        pass


def suspend_curses():
    """Leave curses to shell out (e.g. to $EDITOR).

    Resets the DECSCUSR cursor style before endwin() so the external program
    starts from a neutral cursor — curses' endwin() doesn't track the style we
    set in search mode, so without this a blinking block could leak into vim.
    """
    set_cursor_style(0)
    curses.endwin()


def file_snapshot(directory):
    snap = {}
    for f in glob.glob(os.path.join(directory, "*.md")):
        if CONFLICT_RE.match(os.path.basename(f)):
            continue  # conflict copies must not enter the reload snapshot, or normalize_external_note would rename them
        try:
            snap[f] = os.path.getmtime(f)
        except OSError:
            pass
    return snap


def normalize_external_note(path):
    """Fix stale title: and modified: frontmatter after an external edit."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return

    if not text.startswith("---\n"):
        return

    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return

    def restore_mtime(p):
        try:
            os.utime(p, (mtime, mtime))
        except OSError:
            pass

    meta = parse_frontmatter(text[4:fm_end])
    body = text[fm_end + 5:]
    if body.startswith("\n"):
        body = body[1:]

    new_title = derive_title(body)

    file_mtime_iso = datetime.fromtimestamp(
        mtime, tz=timezone.utc
    ).strftime("%Y-%m-%dT%H:%M:%SZ")

    old_title = meta.get("title") or ""
    old_modified = meta.get("modified") or ""

    title_changed = bool(new_title) and new_title != old_title
    modified_changed = file_mtime_iso != old_modified

    if not title_changed and not modified_changed:
        sync_hashtags(path)
        schedule_inline_loop(path)
        restore_mtime(path)
        return path

    new_yaml_lines = []
    title_written = False
    for line in text[4:fm_end].splitlines():
        if line.startswith("title:") and title_changed:
            new_yaml_lines.append(f"title: {yaml_scalar(new_title)}")
            title_written = True
        elif line.startswith("modified:"):
            new_yaml_lines.append(f"modified: {file_mtime_iso}")
        # NB: version is deliberately left untouched here — the editing device
        # already incremented it (see check_rename); preserving it on adoption
        # keeps the edit count from being double-bumped on sync.
        else:
            new_yaml_lines.append(line)
            if line.startswith("id:") and title_changed and not title_written:
                new_yaml_lines.append(f"title: {yaml_scalar(new_title)}")
                title_written = True

    atomic_write(path, "---\n" + "\n".join(new_yaml_lines) + text[fm_end:])

    final_path = path
    if title_changed and new_title:
        new_stem = slugify(new_title)
        current_stem = os.path.splitext(os.path.basename(path))[0]
        if new_stem != current_stem:
            new_path = os.path.join(NOTES_DIR, new_stem + ".md")
            if os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(path):
                i = 2
                while os.path.exists(new_path):
                    new_path = os.path.join(NOTES_DIR, f"{new_stem} ({i}).md")
                    i += 1
            os.rename(path, new_path)
            final_path = new_path

    sync_hashtags(final_path)
    schedule_inline_loop(final_path)
    restore_mtime(final_path)
    return final_path


def incremental_update(notes, snap_old, snap_new):
    added_or_modified = {
        p for p, m in snap_new.items()
        if p not in snap_old or snap_old[p] != m
    }
    deleted = set(snap_old) - set(snap_new)

    if not added_or_modified and not deleted:
        return notes, False

    result = [n for n in notes if n["path"] not in deleted and n["path"] not in added_or_modified]
    for path in added_or_modified:
        ensure_frontmatter(path)
        ensure_id(path)
        final_path = normalize_external_note(path) or path
        n = load_md(final_path)
        if n:
            result.append(n)

    return result, True


def rank_notes(notes, q):
    q = q.strip()
    if not q:
        return notes

    if q.startswith('"') and q.endswith('"') and len(q) > 2:
        phrase = q[1:-1].lower()
        if not phrase:
            return notes
        matches = [n for n in notes if phrase in title(n).lower() or phrase in content(n).lower()]
        # Input order is load order (arbitrary after incremental updates), so
        # give phrase results a deterministic newest-first order like tokens get.
        matches.sort(key=lambda n: -(n.get("modificationDate") or 0))
        return matches

    tokens = q.lower().split()
    q_lower = q.lower()
    now = datetime.now().timestamp()
    results = []

    for n in notes:
        t = title(n).lower()
        body = content(n).lower()
        tag_str = tags(n).lower()
        t_words = t.split()

        score = 0

        if t == q_lower:
            score += 1000
        elif t.startswith(q_lower):
            score += 500
        elif q_lower in t:
            score += 200

        for tok in tokens:
            if tok in t:
                score += 100
            if tok in tag_str:
                score += 80
            if tok in body:
                score += 20

            if len(tok) >= 4:
                for word in t_words:
                    if _edit_dist(tok, word) <= 1:
                        score += 30
                        break

        if score > 0:
            age = now - (n.get("modificationDate") or 0)
            if age < 7 * 86400:
                score += 15
            elif age < 30 * 86400:
                score += 5
            results.append((score, n))

    results.sort(key=lambda x: (-x[0], -(x[1].get("modificationDate") or 0)))
    return [n for _, n in results]


def search_subset(notes, q, *, preserve_order):
    """Notes matching `q`. With preserve_order, keep the input order (just
    filter — for views with a meaningful order like loops/dups); otherwise
    return rank_notes' relevance order. Empty query -> the list unchanged."""
    if not q.strip():
        return notes
    ranked = rank_notes(notes, q)
    if not preserve_order:
        return ranked
    keep = {id(n) for n in ranked}
    return [n for n in notes if id(n) in keep]


def order_notes(base, sort, rev, q, keep):
    """Order one view's list: filter by `q`, then apply the chosen `sort`.

    `sort == "relevance"` is the smart default — best matches first while
    searching, otherwise the view's own order (`keep`: the base order as-is,
    for loops/dups; else modified-newest-first for the plain notes/trash).
    The field sorts (title/created/modified) always apply, in every view."""
    if sort == "relevance":
        if q.strip():
            return search_subset(base, q, preserve_order=keep)
        return base if keep else sort_notes(base, "modified", True)
    matches = search_subset(base, q, preserve_order=True) if q.strip() else base
    return sort_notes(matches, sort, rev)


def sort_label(sort, rev, q, natural, keep):
    """Human label for the active sort, shown in every view's header. `natural`
    is what "relevance" means at rest for this view. Only the plain views rank
    by relevance while searching; keep-views (loops/dups) just filter and so
    retain their natural order, which the label reflects."""
    if sort == "relevance":
        return "relevance" if (q.strip() and not keep) else natural
    return f"{sort} {'🞃' if rev else '🞁'}"


