def yaml_scalar(value):
    if not value:
        return '""'
    need_quote = any(c in value for c in ':#{}[]|>&*!,')
    need_quote = need_quote or value[0] in '"\'%@`'
    need_quote = need_quote or value.lower() in ('true', 'false', 'yes', 'no', 'null', '~')
    if need_quote:
        return '"' + value.replace('\\', '\\\\').replace('"', '\\"') + '"'
    return value


def slugify(title):
    safe = re.sub(r'[/\\:\0]', '-', title)
    safe = re.sub(r'\s+', ' ', safe).strip().lstrip('.').rstrip('-')
    return safe or 'untitled'


def iso_to_ts(s):
    if not s:
        return 0.0
    try:
        dt = datetime.strptime(s, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
        return dt.timestamp()
    except Exception:
        return 0.0


def _parse_flow_list(inner):
    """Parse the inside of a YAML flow sequence (e.g. 'a, b, "c, d"') into a
    list of strings, respecting quotes so commas inside a quoted item don't
    split it. Inside double quotes a backslash escapes the next character, so
    '"a \\"b\\" c"' stays one item. Blank items (a trailing comma) are dropped."""
    items = []
    buf = ""
    quote = None
    escaped = False
    for ch in inner:
        if quote:
            buf += ch
            if escaped:
                escaped = False
            elif ch == "\\" and quote == '"':
                escaped = True
            elif ch == quote:
                quote = None
        elif ch in ('"', "'"):
            quote = ch
            buf += ch
        elif ch == ",":
            items.append(buf)
            buf = ""
        else:
            buf += ch
    if buf.strip() or items:
        items.append(buf)

    cleaned = []
    for it in items:
        it = it.strip()
        if not it:
            continue
        if len(it) >= 2 and it[0] == '"' and it[-1] == '"':
            it = it[1:-1].replace('\\"', '"').replace("\\\\", "\\")
        elif len(it) >= 2 and it[0] == "'" and it[-1] == "'":
            it = it[1:-1].replace("''", "'")
        if it:
            cleaned.append(it)
    return cleaned


def parse_frontmatter(text):
    result = {}
    lines = text.splitlines()
    i = 0
    current_list_key = None

    while i < len(lines):
        line = lines[i]

        if line.startswith("  - ") and current_list_key is not None:
            item = line[4:]
            if item.startswith('"') and item.endswith('"'):
                item = item[1:-1].replace('\\"', '"').replace("\\\\", "\\")
            result[current_list_key].append(item)
            i += 1
            continue

        current_list_key = None

        if ":" not in line:
            i += 1
            continue

        key, _, raw = line.partition(":")
        key = key.strip()
        raw = raw.strip()

        if raw == "":
            result[key] = []
            current_list_key = key
        elif len(raw) >= 2 and raw[0] == "[" and raw[-1] == "]":
            result[key] = _parse_flow_list(raw[1:-1])
        else:
            if raw.startswith('"') and raw.endswith('"'):
                raw = raw[1:-1].replace('\\"', '"').replace("\\\\", "\\")
            result[key] = raw

        i += 1

    return result


def derive_title(body):
    """First non-empty line of the body, with a leading markdown heading
    marker (#, ##, ...) stripped, capped at TITLE_MAX."""
    for line in body.split("\n"):
        s = line.strip()
        if s:
            s = re.sub(r"^#{1,6}\s+", "", s)
            return s[:TITLE_MAX]
    return ""


def load_md(path):
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()

        if not text.startswith("---\n"):
            return None

        end = text.find("\n---\n", 4)
        if end == -1:
            return None

        meta = parse_frontmatter(text[4:end])
        body = text[end + 5:]
        if body.startswith("\n"):
            body = body[1:]

        body_title = derive_title(body)

        return {
            "path": path,
            "content": body,
            "title": body_title or meta.get("title") or "",
            "tags": meta.get("tags") or [],
            "system_tags": meta.get("system_tags") or [],
            "modificationDate": iso_to_ts(meta.get("modified")),
            "creationDate": iso_to_ts(meta.get("created")),
            "id": meta.get("id") or "",
            "version": meta.get("version"),
        }
    except Exception:
        return None


def ensure_frontmatter(path):
    """Adopt an external .md file that has no frontmatter by prepending a
    minimal block, so it shows up in notoj. Files that already start with a
    frontmatter marker are left untouched."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return

    if text.startswith("---\n"):
        return

    try:
        ts_iso = datetime.fromtimestamp(
            os.path.getmtime(path), tz=timezone.utc
        ).strftime("%Y-%m-%dT%H:%M:%SZ")
    except OSError:
        ts_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    frontmatter = (
        f"---\n"
        f"id: {uuid.uuid4().hex}\n"
        f"created: {ts_iso}\n"
        f"modified: {ts_iso}\n"
        f"version: 1\n"
        f"tags: []\n"
        f"---\n"
    )
    try:
        st = os.stat(path)
        atomic_write(path, frontmatter + "\n" + text)
        # Keep the original mtime: created/modified above are derived from it,
        # and mtime == modified means adoption never reads as a fresh edit.
        os.utime(path, (st.st_atime, st.st_mtime))
    except Exception:
        pass


def ensure_id(path):
    """Guarantee a non-empty id: in the frontmatter (insert one if missing).

    Per-note state is keyed by id — loop snoozes in the review file — so notes
    with an empty id would silently share state. Preserves the file mtime so
    the insertion doesn't read as an edit."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return

    if not text.startswith("---\n"):
        return
    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return

    meta = parse_frontmatter(text[4:fm_end])
    if meta.get("id"):
        return

    fm_lines = [
        line for line in text[4:fm_end].splitlines()
        if not (line.startswith("id:") and not line.split(":", 1)[1].strip())
    ]
    fm_lines.insert(0, f"id: {uuid.uuid4().hex}")
    try:
        st = os.stat(path)
        atomic_write(path, "---\n" + "\n".join(fm_lines) + text[fm_end:])
        os.utime(path, (st.st_atime, st.st_mtime))
    except Exception:
        pass


def load():
    notes = []

    for f in glob.glob(os.path.join(NOTES_DIR, "*.md")):
        if CONFLICT_RE.match(os.path.basename(f)):
            continue  # Syncthing conflict copy — handled by find_conflicts()/`c`, never adopted as a note
        n = load_md(f)
        if n is None:
            ensure_frontmatter(f)
            n = load_md(f)
        if n and not n.get("id"):
            ensure_id(f)
            n = load_md(f)
        if n:
            notes.append(n)

    return notes


