def sort_notes(notes, key, rev):
    def k(n):
        if key == "title":
            return title(n).lower()

        if key == "created":
            return n.get("creationDate", 0)

        return n.get("modificationDate", 0)

    return sorted(notes, key=k, reverse=rev)



def _edit_dist(a, b):
    if abs(len(a) - len(b)) > 2:
        return 99
    dp = list(range(len(b) + 1))
    for ca in a:
        ndp = [dp[0] + 1]
        for j, cb in enumerate(b):
            ndp.append(min(dp[j] + (ca != cb), dp[j + 1] + 1, ndp[j] + 1))
        dp = ndp
    return dp[-1]


def save_cursor(path):
    try:
        with open(STATE_FILE, "w", encoding="utf-8") as f:
            f.write(path + "\n")
    except Exception:
        pass


def load_cursor():
    try:
        with open(STATE_FILE, "r", encoding="utf-8") as f:
            return f.read().strip()
    except Exception:
        return ""


def set_cursor_style(code):
    """Emit a DECSCUSR cursor-style escape (e.g. 1 = blinking block, 0 = reset).

    curses' curs_set(2) only requests "very visible", which is no-op-ish under
    tmux and renders steady under mosh. DECSCUSR sends an explicit blink request
    that tmux forwards and mosh honors, so the blink survives a mosh session.
    """
    try:
        sys.stdout.write("\033[%d q" % code)
        sys.stdout.flush()
    except (OSError, ValueError):
        pass


def suspend_curses():
    """Leave curses to shell out (e.g. to $EDITOR).

    Resets the DECSCUSR cursor style before endwin() so the external program
    starts from a neutral cursor — curses' endwin() doesn't track the style we
    set in search mode, so without this a blinking block could leak into vim.
    """
    set_cursor_style(0)
    curses.endwin()


def launch(cmd):
    """Run an interactive external command (the editor, vimdiff) after
    suspend_curses(). Returns True, or False if the program isn't installed —
    recording its name in launch.missing so the caller can report it on the
    status bar instead of crashing out of the TUI with the screen suspended."""
    try:
        subprocess.call(cmd)
        return True
    except (FileNotFoundError, PermissionError) as e:
        launch.missing = f"{cmd[0]}: {e.strerror}" if cmd else "editor not found"
        return False


launch.missing = None


def file_snapshot(directory):
    """Map of path -> (mtime, size). Size is included so writes that preserve
    mtime on purpose — tagging from the list keeps the modified date — are
    still detected and reloaded."""
    snap = {}
    for f in glob.glob(os.path.join(directory, "*.md")):
        if CONFLICT_RE.match(os.path.basename(f)):
            continue  # conflict copies must not enter the reload snapshot, or normalize_external_note would rename them
        try:
            st = os.stat(f)
            snap[f] = (st.st_mtime, st.st_size)
        except OSError:
            pass
    return snap


def normalize_external_note(path):
    """Fix stale title: and modified: frontmatter after an external edit.

    modified: is set from the file's mtime — the time of the edit on whatever
    device made it — not the adoption time here. The mtime is then restored
    after rewriting, which keeps mtime == modified: that way the rewrite
    itself never reads as yet another external change, locally or (once
    Syncthing has carried the mtime across) on any other device."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
        mtime = os.path.getmtime(path)
    except Exception:
        return

    if not text.startswith("---\n"):
        return

    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return

    def restore_mtime(p):
        try:
            os.utime(p, (mtime, mtime))
        except OSError:
            pass

    meta = parse_frontmatter(text[4:fm_end])
    body = text[fm_end + 5:]
    if body.startswith("\n"):
        body = body[1:]

    new_title = derive_title(body)

    file_mtime_iso = datetime.fromtimestamp(
        mtime, tz=timezone.utc
    ).strftime("%Y-%m-%dT%H:%M:%SZ")

    old_title = meta.get("title") or ""
    old_modified = meta.get("modified") or ""

    fm_lines = text[4:fm_end].splitlines()
    has_created = any(line.startswith("created:") for line in fm_lines)
    has_modified = any(line.startswith("modified:") for line in fm_lines)
    has_version = any(line.startswith("version:") for line in fm_lines)

    title_changed = bool(new_title) and new_title != old_title
    modified_changed = file_mtime_iso != old_modified
    # Externally-produced files often arrive with only a partial frontmatter
    # block — e.g. an id/title/tags header and none of the housekeeping dates.
    # Backfill whatever is missing so the note sorts, dedupes, and resurfaces
    # like any other instead of carrying empty created/modified/version through
    # every load (which also left modified_changed permanently true, rewriting
    # the file on every scan).
    needs_backfill = not (has_created and has_modified and has_version)

    if not title_changed and not modified_changed and not needs_backfill:
        sync_hashtags(path)
        canonicalize_wikilinks(path)
        schedule_inline_loop(path)
        restore_mtime(path)
        return path

    new_yaml_lines = []
    title_written = False
    for line in fm_lines:
        if line.startswith("title:"):
            # Collapse any duplicate title lines to a single one; rewrite it
            # when the derived title changed, else keep the line verbatim.
            if title_written:
                continue
            new_yaml_lines.append(
                f"title: {yaml_scalar(new_title)}" if title_changed else line
            )
            title_written = True
        elif line.startswith("modified:"):
            new_yaml_lines.append(f"modified: {file_mtime_iso}")
        # NB: an existing version is deliberately left untouched here — the
        # editing device already incremented it (see check_rename); preserving
        # it on adoption keeps the edit count from being double-bumped on sync.
        else:
            new_yaml_lines.append(line)
            if line.startswith("id:") and title_changed and not title_written:
                new_yaml_lines.append(f"title: {yaml_scalar(new_title)}")
                title_written = True

    # Append any housekeeping field the external file never carried. created has
    # no better source than the same mtime; version starts at 1. (mtime is
    # restored below, so these inserts never read as a fresh edit on sync.)
    if not has_created:
        new_yaml_lines.append(f"created: {file_mtime_iso}")
    if not has_modified:
        new_yaml_lines.append(f"modified: {file_mtime_iso}")
    if not has_version:
        new_yaml_lines.append("version: 1")

    atomic_write(path, "---\n" + "\n".join(new_yaml_lines) + text[fm_end:])

    final_path = path
    if title_changed and new_title:
        new_stem = slugify(new_title)
        current_stem = os.path.splitext(os.path.basename(path))[0]
        if new_stem != current_stem:
            new_path = os.path.join(NOTES_DIR, new_stem + ".md")
            if os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(path):
                i = 2
                while os.path.exists(new_path):
                    new_path = os.path.join(NOTES_DIR, f"{new_stem} ({i}).md")
                    i += 1
            os.rename(path, new_path)
            final_path = new_path

    sync_hashtags(final_path)
    canonicalize_wikilinks(final_path)
    schedule_inline_loop(final_path)
    restore_mtime(final_path)
    return final_path


def incremental_update(notes, snap_old, snap_new):
    added_or_modified = {
        p for p, m in snap_new.items()
        if p not in snap_old or snap_old[p] != m
    }
    deleted = set(snap_old) - set(snap_new)

    if not added_or_modified and not deleted:
        return notes, False

    result = [n for n in notes if n["path"] not in deleted and n["path"] not in added_or_modified]
    for path in added_or_modified:
        ensure_canonical(path)
        ensure_frontmatter(path)
        ensure_id(path)
        final_path = normalize_external_note(path) or path
        n = load_md(final_path)
        if n:
            result.append(n)

    return result, True


def rank_notes(notes, q):
    q = q.strip()
    if not q:
        return notes

    if q.startswith('"') and q.endswith('"') and len(q) > 2:
        # Quoted = strict contiguous phrase. Case-insensitive, and each run of
        # whitespace in the query matches any whitespace in the note (\s+), so
        # "cat food" still hits when the words straddle a line break. It stays a
        # substring of the running text, so "CAT foods" matches but "food cat"
        # and "catch the food" (reordered / extra words) do not.
        words = q[1:-1].split()
        if not words:
            return notes
        phrase_re = re.compile(r"\s+".join(map(re.escape, words)), re.IGNORECASE)
        matches = [n for n in notes if phrase_re.search(title(n)) or phrase_re.search(content(n))]
        # Input order is load order (arbitrary after incremental updates), so
        # give phrase results a deterministic newest-first order like tokens get.
        matches.sort(key=lambda n: -(n.get("modificationDate") or 0))
        return matches

    tokens = q.lower().split()
    q_lower = q.lower()
    now = datetime.now().timestamp()
    results = []

    for n in notes:
        t = title(n).lower()
        body = content(n).lower()
        tag_str = tags(n).lower()
        t_words = t.split()

        score = 0

        if t == q_lower:
            score += 1000
        elif t.startswith(q_lower):
            score += 500
        elif q_lower in t:
            score += 200

        for tok in tokens:
            if tok in t:
                score += 100
            if tok in tag_str:
                score += 80
            if tok in body:
                score += 20

            if len(tok) >= 4:
                for word in t_words:
                    if _edit_dist(tok, word) <= 1:
                        score += 30
                        break

        if score > 0:
            age = now - (n.get("modificationDate") or 0)
            if age < 7 * 86400:
                score += 15
            elif age < 30 * 86400:
                score += 5
            results.append((score, n))

    results.sort(key=lambda x: (-x[0], -(x[1].get("modificationDate") or 0)))
    return [n for _, n in results]


def search_subset(notes, q, *, preserve_order):
    """Notes matching `q`. With preserve_order, keep the input order (just
    filter — for views with a meaningful order like loops/dups); otherwise
    return rank_notes' relevance order. Empty query -> the list unchanged."""
    if not q.strip():
        return notes
    ranked = rank_notes(notes, q)
    if not preserve_order:
        return ranked
    keep = {id(n) for n in ranked}
    return [n for n in notes if id(n) in keep]


def order_notes(base, sort, rev, q, keep):
    """Order one view's list: filter by `q`, then apply the chosen `sort`.

    `sort == "relevance"` is the smart default — best matches first while
    searching, otherwise the view's own order (`keep`: the base order as-is,
    for loops/dups; else modified-newest-first for the plain notes/trash).
    The field sorts (title/created/modified) always apply, in every view."""
    if sort == "relevance":
        if q.strip():
            return search_subset(base, q, preserve_order=keep)
        return base if keep else sort_notes(base, "modified", True)
    matches = search_subset(base, q, preserve_order=True) if q.strip() else base
    return sort_notes(matches, sort, rev)


def frame_cache(store, key, compute):
    """Memoize one per-frame computation so holding j/k doesn't rebuild it.

    The list and modal-preview loops redraw on every keystroke with no input
    coalescing, so derived data keyed only by what the user actually changed —
    the search query while filtering, the selected row for a preview pane —
    must not be recomputed while merely scrolling. (Re-ranking every note, or
    re-filtering the whole set by tag, per j/k is what made search and the tag
    browser lag.) Recompute only when `key` differs from the previous frame;
    otherwise return the cached value. `store` is any dict that lives across
    frames (the loop's state); give each cached computation its own store."""
    if "key" not in store or store["key"] != key:
        store["key"] = key
        store["val"] = compute()
    return store["val"]


def sort_label(sort, rev, q, natural, keep):
    """Human label for the active sort, shown in every view's header. `natural`
    is what "relevance" means at rest for this view. Only the plain views rank
    by relevance while searching; keep-views (loops/dups) just filter and so
    retain their natural order, which the label reflects."""
    if sort == "relevance":
        return "relevance" if (q.strip() and not keep) else natural
    return f"{sort} {'🞃' if rev else '🞁'}"


# ----------------------------
# Hashtag sync
# ----------------------------

HASHTAG_RE = re.compile(r'(?<![/\w])#([a-zA-Z][a-zA-Z0-9_-]*)')
STRAY_HASH_RE = re.compile(r'#(?![A-Za-z0-9])')
INLINE_CODE_RE = re.compile(r'`[^`]*`')


def notag(meta):
    """True if the note opts out of body->frontmatter hashtag sync, via a
    `notag: true` frontmatter line. For wholesale reference notes (pasted
    configs, IRC channel lists, hex colors) where every inline '#' is a
    literal, not a tag. Manual tagging (the # key) still works on them."""
    return str(meta.get("notag", "")).strip().lower() in ("true", "yes", "1")


def extract_hashtags(text):
    """Extract inline #hashtags, ignoring ASCII-art rows, fenced code blocks,
    and inline `code` spans (a #literal inside backticks is content, not a tag).

    A line is treated as art (and skipped) if it contains a "stray" '#': one not
    immediately followed by a letter or digit. Box-drawing / map rows such as
    "#w...gw...#", "#c#", "############" or "#g...#.#g.#" all have border '#'
    before spaces, dots, another '#' or end-of-line, so they are skipped. Clean
    lines keep working, including score/year tags like "#Worldle #144 1/6" or
    "#nye #2019 #bhangra" where the '#' is followed by a digit. Fenced ``` / ~~~
    code blocks are skipped entirely.

    Per-token filtering (keeping pattern-valid tags from lines that also have
    a stray '#') was considered and rejected: real art rows in the corpus
    yield pattern-valid matches, including multi-char ones like "gw" in
    "#g...#.#g.#...gw...#", so the whole line must be treated as art. The
    cost is that a real tag sharing a line with a stray '#' is dropped.
    """
    raw = []
    in_fence = False
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("```") or stripped.startswith("~~~"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue
        # Drop inline code spans before the stray-'#' check, so backticking a
        # literal both untags it and stops it poisoning the rest of the line.
        line = INLINE_CODE_RE.sub("", line)
        if STRAY_HASH_RE.search(line):
            continue
        raw.extend(HASHTAG_RE.findall(line))
    return list(dict.fromkeys(raw))


def sync_hashtags(path):
    """Add any inline #hashtags found in the note body to the YAML tags field.

    Returns True if the file was rewritten (new tags adopted), else False."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return False

    if not text.startswith("---\n"):
        return False
    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return False

    meta = parse_frontmatter(text[4:fm_end])
    if notag(meta):
        return False

    existing = meta.get("tags") or []
    if isinstance(existing, str):
        existing = [existing] if existing else []

    body = text[fm_end + 5:]
    if body.startswith("\n"):
        body = body[1:]

    new_tags = [t for t in extract_hashtags(body) if t not in existing]
    if not new_tags:
        return False

    all_tags = existing + new_tags
    new_fm_lines = []
    skip_items = False
    for line in text[4:fm_end].splitlines():
        if line.startswith("tags:"):
            new_fm_lines.append("tags:")
            for t in all_tags:
                new_fm_lines.append(f"  - {yaml_scalar(t)}")
            skip_items = True
            continue
        if skip_items:
            if line.startswith("  - "):
                continue
            skip_items = False
        new_fm_lines.append(line)

    new_text = "---\n" + "\n".join(new_fm_lines) + text[fm_end:]
    try:
        atomic_write(path, new_text)
        return True
    except Exception:
        return False


def sync_hashtags_keep_date(path):
    """sync_hashtags, preserving the file's mtime so a newly-adopted inline tag
    doesn't read as a fresh edit — which would float the note in date-sorted
    views and later bump its `modified:` during normalization (same reasoning as
    add_tags_keep_date). Used by the initial load() to catch notes that already
    existed, with un-synced body hashtags, before notoj started: the incremental
    rescan only normalizes files that appear or change while running, so without
    this their body tags would never reach the YAML tags field. Returns True if
    the file changed."""
    try:
        mtime = os.path.getmtime(path)
    except OSError:
        mtime = None
    changed = sync_hashtags(path)
    if changed and mtime is not None:
        try:
            os.utime(path, (mtime, mtime))
        except OSError:
            pass
    return changed


def parse_tag_input(s):
    """Split a space-separated tag string into clean tag names.

    Tolerates a leading '#' on each token so "#work urgent" and
    "work urgent" behave the same."""
    return [t.lstrip("#") for t in s.split() if t.strip("#").strip()]


def add_tags(path, new_tags):
    """Merge the given tag names into the note's YAML tags field.

    Returns the list of tags actually added (those not already present)."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return []

    if not text.startswith("---\n"):
        return []
    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return []

    meta = parse_frontmatter(text[4:fm_end])
    existing = meta.get("tags") or []
    if isinstance(existing, str):
        existing = [existing] if existing else []

    added = [t for t in new_tags if t and t not in existing]
    if not added:
        return []

    all_tags = existing + added
    has_tags_field = False
    new_fm_lines = []
    skip_items = False
    for line in text[4:fm_end].splitlines():
        if line.startswith("tags:"):
            has_tags_field = True
            new_fm_lines.append("tags:")
            for t in all_tags:
                new_fm_lines.append(f"  - {yaml_scalar(t)}")
            skip_items = True
            continue
        if skip_items:
            if line.startswith("  - "):
                continue
            skip_items = False
        new_fm_lines.append(line)

    if not has_tags_field:
        new_fm_lines.append("tags:")
        for t in all_tags:
            new_fm_lines.append(f"  - {yaml_scalar(t)}")

    new_text = "---\n" + "\n".join(new_fm_lines) + text[fm_end:]
    try:
        atomic_write(path, new_text)
    except Exception:
        return []
    return added


def add_tags_keep_date(path, new_tags):
    """add_tags, but keep the note's modified date: tagging from the list
    (#, ., redo) is metadata grooming, not an edit, so it must not float the
    note to the top of date-sorted views. Restoring the mtime keeps it equal
    to the frontmatter modified:, so the normalize pass leaves both alone."""
    try:
        mod_ts = os.path.getmtime(path)
    except OSError:
        mod_ts = None
    added = add_tags(path, new_tags)
    if added and mod_ts is not None:
        try:
            os.utime(path, (mod_ts, mod_ts))
        except OSError:
            pass
    return added


def remove_tag(path, tag):
    """Remove a tag from a note: drop it from the YAML tags field and strip any
    matching inline #hashtag from the body (so sync_hashtags won't re-add it).

    Returns True if the file changed."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return False

    if not text.startswith("---\n"):
        return False
    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return False

    meta = parse_frontmatter(text[4:fm_end])
    existing = meta.get("tags") or []
    if isinstance(existing, str):
        existing = [existing] if existing else []

    body = text[fm_end + 5:]
    pat = r'(?<![/\w])#' + re.escape(tag) + r'(?![\w-])'
    if tag == LOOP_TAG:
        # Also take a scheduled date pinned after the inline tag ("#loop
        # 2026-06-12", see schedule_inline_loop), so closing the loop doesn't
        # strand an orphaned date in the prose.
        pat += r'([ \t]+\d{4}-\d{2}-\d{2}(?![\w-]))?'
    body_stripped = re.sub(pat, '', body)

    new_tags = [t for t in existing if t != tag]
    if new_tags == existing and body_stripped == body:
        return False

    new_fm_lines = []
    skip_items = False
    for line in text[4:fm_end].splitlines():
        if line.startswith("tags:"):
            if new_tags:
                new_fm_lines.append("tags:")
                for t in new_tags:
                    new_fm_lines.append(f"  - {yaml_scalar(t)}")
            else:
                new_fm_lines.append("tags: []")
            skip_items = True
            continue
        if skip_items:
            if line.startswith("  - "):
                continue
            skip_items = False
        new_fm_lines.append(line)

    new_text = "---\n" + "\n".join(new_fm_lines) + "\n---\n" + body_stripped
    try:
        atomic_write(path, new_text)
    except Exception:
        return False
    return True


def remove_tags_frontmatter(path, tags):
    """Drop the given tags from a note's YAML tags field only; the body is
    left untouched (unlike remove_tag, which also strips matching inline
    #hashtags). For undoing a #-key addition, which never writes to the body.
    Returns True if the file changed."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return False
    if not text.startswith("---\n"):
        return False
    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return False

    meta = parse_frontmatter(text[4:fm_end])
    existing = meta.get("tags") or []
    if isinstance(existing, str):
        existing = [existing] if existing else []
    drop = set(tags)
    new_tags = [t for t in existing if t not in drop]
    if new_tags == existing:
        return False

    new_fm_lines = []
    skip_items = False
    for line in text[4:fm_end].splitlines():
        if line.startswith("tags:"):
            if new_tags:
                new_fm_lines.append("tags:")
                for t in new_tags:
                    new_fm_lines.append(f"  - {yaml_scalar(t)}")
            else:
                new_fm_lines.append("tags: []")
            skip_items = True
            continue
        if skip_items:
            if line.startswith("  - "):
                continue
            skip_items = False
        new_fm_lines.append(line)

    new_text = "---\n" + "\n".join(new_fm_lines) + text[fm_end:]
    try:
        atomic_write(path, new_text)
    except Exception:
        return False
    return True


def reopen_loop(path, mod_ts=None):
    """Undo a loop-close: re-add the #loop tag, keeping the original modified
    date (and file mtime) so the staleness clock is not reset."""
    if not os.path.exists(path):
        return False
    added = add_tags(path, [LOOP_TAG])
    if mod_ts:
        try:
            os.utime(path, (mod_ts, mod_ts))
        except OSError:
            pass
    return bool(added)


# ----------------------------
# Note links / backlinks (b view)
# ----------------------------

# The same link forms the embedded vimscript's NotojFollow makes gf follow:
# [[Note title]] wikilinks and [text](target) markdown links resolving to
# $NOTOJ_NOTES_DIR/<name>.md. This is the Python half of that feature.
WIKILINK_RE = re.compile(r'\[\[([^][]+)\]\]')
MDLINK_RE = re.compile(r'\[[^][]*\]\(([^()]+)\)')


def resolve_link_target(target):
    """Normalize a link target the way NotojFollow does: trim whitespace,
    strip surrounding <>, append .md when missing. Returns the note filename
    it points at, or None for external (URL-ish) or empty targets."""
    t = target.strip()
    if t.startswith("<") and t.endswith(">"):
        t = t[1:-1].strip()
    if not t or "://" in t:
        return None
    if not t.lower().endswith(".md"):
        t += ".md"
    return t


def line_link_targets(line):
    """Note filenames linked from one line ([[wikilinks]] + markdown links)."""
    out = []
    for rx in (WIKILINK_RE, MDLINK_RE):
        for m in rx.finditer(line):
            t = resolve_link_target(m.group(1))
            if t:
                out.append(t)
    return out


def extract_links(text):
    """Outgoing note links in a body, as .md filenames, deduped in order.
    Fenced code blocks are skipped, like hashtag extraction."""
    out = []
    in_fence = False
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("```") or stripped.startswith("~~~"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue
        out.extend(line_link_targets(line))
    return list(dict.fromkeys(out))


def linking_lines(text, fname):
    """Lines of `text` that link to the note file `fname` (case-insensitive,
    so a hand-typed [[title]] doesn't miss on capitalization)."""
    fl = fname.lower()
    out = []
    in_fence = False
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("```") or stripped.startswith("~~~"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue
        if any(t.lower() == fl for t in line_link_targets(line)):
            out.append(line)
    return out


def canonicalize_wikilinks(path):
    """Rewrite [[wikilink]] bracket text to the exact on-disk filename stem
    when it matches an existing note case-insensitively.

    notoj's own resolver is lenient — linking_lines matches case-insensitively,
    so a hand-typed [[twin dome device inventory]] follows fine here. But Markor
    (and other editors) resolve a wikilink by using the bracket text verbatim as
    the path, so only an exact match opens the note on the phone. Canonicalizing
    to the real filename makes every link portable without changing which note
    it points at. Dangling or unmatched links are left untouched — we never
    invent a target. Body only (the frontmatter carries no [[ ]] links); fenced
    code blocks are skipped, like hashtag sync. Returns True if anything changed;
    the caller restores mtime so the rewrite never reads as a fresh edit."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return False

    # Confine the rewrite to the body — the frontmatter fence stays verbatim.
    head = ""
    body = text
    if text.startswith("---\n"):
        fm_end = text.find("\n---\n", 4)
        if fm_end != -1:
            head = text[:fm_end + 5]
            body = text[fm_end + 5:]

    # lowercase stem -> actual on-disk stem of every note that currently exists
    try:
        stems = {}
        for fn in os.listdir(NOTES_DIR):
            if fn.endswith(".md"):
                stems.setdefault(fn[:-3].lower(), fn[:-3])
    except OSError:
        return False

    def canon(m):
        inner = m.group(1)
        target = resolve_link_target(inner)  # '<inner>.md', or None if URL-ish
        if not target:
            return m.group(0)
        actual = stems.get(target[:-3].lower())
        if actual is None or actual == inner.strip():
            return m.group(0)
        return "[[" + actual + "]]"

    out_lines = []
    in_fence = False
    changed = False
    for line in body.splitlines(keepends=True):
        stripped = line.strip()
        if stripped.startswith("```") or stripped.startswith("~~~"):
            in_fence = not in_fence
            out_lines.append(line)
            continue
        if in_fence:
            out_lines.append(line)
            continue
        new_line = WIKILINK_RE.sub(canon, line)
        if new_line != line:
            changed = True
        out_lines.append(new_line)

    if not changed:
        return False

    atomic_write(path, head + "".join(out_lines))
    return True


def find_backlinks(notes, note):
    """Notes whose body links to `note` (matched on its current filename),
    newest first."""
    fname = os.path.basename(note["path"]).lower()
    out = []
    for m in notes:
        if m["path"] == note["path"]:
            continue
        if any(l.lower() == fname for l in extract_links(content(m))):
            out.append(m)
    return sort_notes(out, "modified", True)


# ----------------------------
# Tag filtering (t / T views)
# ----------------------------

def tag_stats(notes):
    """Per-tag usage across `notes`: {tag: (count, last_ts)}, where last_ts is
    the newest modified date among the notes carrying the tag."""
    stats = {}
    for n in notes:
        ts = n.get("modificationDate") or 0
        for t in n.get("tags") or []:
            c, last = stats.get(t, (0, 0))
            stats[t] = (c + 1, max(last, ts))
    return stats


# Sort modes for the tags view (s cycles). "recent" is the default: tag
# counts rank your history, but the newest modified date among a tag's notes
# ranks what you're actually working on now.
TAG_SORTS = ["recent", "count", "name"]


def sort_tag_stats(stats, mode):
    """[(tag, count, last_ts)] in the chosen order, with deterministic
    tie-breaks (recent -> count -> name)."""
    items = [(t, c, last) for t, (c, last) in stats.items()]
    if mode == "count":
        items.sort(key=lambda x: (-x[1], x[0]))
    elif mode == "name":
        items.sort(key=lambda x: x[0])
    else:  # recent
        items.sort(key=lambda x: (-x[2], -x[1], x[0]))
    return items


def filter_by_tags(notes, active):
    """Notes carrying every tag in `active`, input order preserved.
    An empty `active` matches everything (no constraint)."""
    need = set(active)
    if not need:
        return list(notes)
    return [n for n in notes if need <= set(n.get("tags") or [])]


def tagf_active(tagf):
    """The tags a tag-filter state actually filters on: all of them while
    idx is -1, otherwise just the cycled-to tag."""
    if tagf["idx"] < 0:
        return list(tagf["tags"])
    return [tagf["tags"][tagf["idx"]]]


def tagf_label(tagf):
    """Header label for the tag filter: active tags plain, inactive in
    parens — '(#a) #b (#c)' when cycled to #b, '#a #b #c' for all."""
    if tagf["idx"] < 0:
        return " ".join("#" + t for t in tagf["tags"])
    return " ".join(
        "#" + t if i == tagf["idx"] else "(#" + t + ")"
        for i, t in enumerate(tagf["tags"])
    )


# ----------------------------
# Duplicate detection
# ----------------------------

def find_duplicates(notes):
    groups = collections.defaultdict(list)
    for n in notes:
        key = title(n).lower().strip()
        groups[key].append(n)
    result = []
    for key in sorted(groups):
        group = groups[key]
        if len(group) >= 2:
            result.extend(sorted(group, key=lambda n: n.get("modificationDate") or 0, reverse=True))
    return result


# ----------------------------
# Resurface (open-loop review)
# ----------------------------

def load_review():
    """Snooze state for open loops, keyed by note id: {id: {"due": ts}}.
    Stored outside the notes (invisible persistence), gitignored."""
    try:
        with open(REVIEW_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def save_review(review):
    try:
        atomic_write(REVIEW_FILE, json.dumps(review, indent=0, sort_keys=True))
    except Exception:
        pass


def prune_review(review, notes, now=None):
    """Drop review entries that can no longer matter: the note is gone or no
    longer tagged #loop, or the snooze already expired (an expired entry and a
    missing one behave identically in find_loops). Keeps the review file from
    growing without bound. Mutates review; returns True if anything was
    removed."""
    if now is None:
        now = datetime.now().timestamp()
    live = {n.get("id") for n in notes if LOOP_TAG in (n.get("tags") or [])}
    stale = [k for k, v in review.items()
             if k not in live or not isinstance(v, dict) or v.get("due", 0) <= now]
    for k in stale:
        del review[k]
    return bool(stale)


def find_loops(notes, review, now=None):
    """Notes tagged #loop that are currently due (not snoozed into the future),
    most stale first so the longest-neglected loop surfaces at the top."""
    if now is None:
        now = datetime.now().timestamp()
    loops = []
    for n in notes:
        if LOOP_TAG not in (n.get("tags") or []):
            continue
        r = review.get(n.get("id"))
        if r and r.get("due", 0) > now:
            continue
        loops.append(n)
    loops.sort(key=lambda n: n.get("modificationDate") or 0)
    return loops


def snooze_loop(review, note_id, now=None):
    """Quick defer: push a loop out of view for a fixed short horizon. Mutates
    the review dict and returns the number of days snoozed."""
    if now is None:
        now = datetime.now().timestamp()
    review[note_id] = {"due": now + SNOOZE_DAYS * 86400}
    return SNOOZE_DAYS


def parse_when(s, now=None):
    """Parse a human horizon into a due timestamp, or None if unparseable.

    Accepts relative offsets (+10d, +2w, +3mo, +1y), bare day counts ("14"),
    absolute ISO dates ("2026-12-01"), and a few keywords (today, tomorrow,
    next week/month/year, someday)."""
    if now is None:
        now = datetime.now().timestamp()
    s = s.strip().lower()
    if not s:
        return None

    keywords = {
        "today": 0, "tomorrow": 1,
        "week": 7, "next week": 7,
        "month": 30, "next month": 30,
        "quarter": 90,
        "year": 365, "next year": 365,
        "someday": 365,
    }
    if s in keywords:
        return now + keywords[s] * 86400

    m = re.fullmatch(r'\+?(\d+)\s*(d|day|days|w|wk|week|weeks|mo|mon|month|months|y|yr|year|years)?', s)
    if m:
        n = int(m.group(1))
        unit = (m.group(2) or "d")[0:2]
        if unit.startswith("w"):
            days = n * 7
        elif unit == "mo":   # all month spellings slice to "mo"
            days = n * 30
        elif unit.startswith("y"):
            days = n * 365
        else:
            days = n
        return now + days * 86400

    for fmt_str in ("%Y-%m-%d", "%Y/%m/%d", "%m-%d-%Y", "%m/%d/%Y"):
        try:
            dt = datetime.strptime(s, fmt_str).replace(tzinfo=timezone.utc)
            return dt.timestamp()
        except ValueError:
            continue
    return None


def schedule_loop(review, note_id, due_ts):
    """Set an explicit resurface date for a loop (mutates the review dict)."""
    review[note_id] = {"due": due_ts}


# "#loop <when>" anywhere in a note body schedules it inline (see
# schedule_inline_loop). The lookahead keeps "#loops" etc. from matching.
LOOP_SPEC_RE = re.compile(r'(?<![/\w])#' + LOOP_TAG + r'(?![\w-])[ \t]+(\S+)')


def schedule_inline_loop(path):
    """Apply an inline "#loop <when>" horizon typed anywhere in a note (e.g.
    "#loop 3d", "#loop 2w", "#loop 2026-12-01"): set the loop's due date in
    the review file, and rewrite a relative horizon to the absolute date it
    resolved to ("#loop 3d" -> "#loop 2026-06-12") so later saves can't
    re-anchor it. An absolute date is re-applied only when it differs from
    the last one applied (the review entry's "src"), so in-app snoozes (z/S)
    survive ordinary re-saves; hand-editing the date reschedules. Fenced code
    and ASCII-art lines are skipped, like hashtag extraction; the first valid
    horizon wins. Returns True if the note body was rewritten."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return False

    if not text.startswith("---\n"):
        return False
    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return False

    note_id = parse_frontmatter(text[4:fm_end]).get("id")
    if not note_id or not isinstance(note_id, str):
        return False

    head = text[:fm_end + 5]
    body_lines = text[fm_end + 5:].split("\n")

    in_fence = False
    for i, line in enumerate(body_lines):
        stripped = line.strip()
        if stripped.startswith("```") or stripped.startswith("~~~"):
            in_fence = not in_fence
            continue
        if in_fence or STRAY_HASH_RE.search(line):
            continue
        m = LOOP_SPEC_RE.search(line)
        if not m:
            continue
        token = m.group(1).rstrip(".,;:!?)")   # tolerate trailing prose punctuation
        if not token or parse_when(token) is None:
            continue

        review = load_review()
        if re.fullmatch(r"\d{4}-\d{2}-\d{2}", token):
            # Absolute date: apply only when it changed (src guard).
            if (review.get(note_id) or {}).get("src") != token:
                review[note_id] = {"due": parse_when(token), "src": token}
                save_review(review)
            return False

        # Relative horizon: resolve to a calendar date once and pin that date
        # in the body. Due is canonicalized through the written date so a
        # reconstructed review file lands on the same timestamp.
        date_str = datetime.fromtimestamp(parse_when(token)).strftime("%Y-%m-%d")
        review[note_id] = {"due": parse_when(date_str), "src": date_str}
        save_review(review)

        start = m.start(1)
        body_lines[i] = line[:start] + date_str + line[start + len(token):]
        try:
            atomic_write(path, head + "\n".join(body_lines))
        except Exception:
            return False
        return True

    return False


# ----------------------------
# Atomic write helper
# ----------------------------

def atomic_write(path, text):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        f.write(text)
    os.replace(tmp, path)


# ----------------------------
# Undo-stack persistence
# ----------------------------
#
# The undo/redo stacks survive across sessions via an append-only JSON-lines
# journal, local to this machine and keyed by notes dir. It must NEVER live in
# the synced notes tree: O_APPEND atomicity doesn't hold over Syncthing/NFS.
#
# Each line is one event — an action ("act"), an "undo"/"redo" navigation, or a
# "session" launch/quit marker. Replaying the events reconstructs the exact
# undo/redo state (an action clears redo; undo moves undo's top to redo; redo
# moves it back), so the live stacks and the journal never diverge.
#
# Appends are written as a single os.write of one newline-terminated line,
# which O_APPEND keeps atomic between concurrent writers. They take only a
# SHARED lock on a stable .lock file; the rare launch-time compaction (which
# rewrites the journal) takes it EXCLUSIVELY, so a rewrite can never race an
# append and lose it.

UNDO_LOG_CAP = 500   # live undo entries kept when the journal is compacted


def undo_log_path():
    base = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    key = hashlib.sha1(NOTES_DIR.encode("utf-8")).hexdigest()[:12]
    return os.path.join(base, "notoj", key, "undo.jsonl")


def undo_persist_on():
    return bool(UNDO_LOG) and config_bool("undo.persist", True)


def _undo_lock(flag):
    """Take `flag` (LOCK_SH/LOCK_EX) on the journal's stable lock file. Returns
    the locked fd, or None when locking is unavailable."""
    try:
        lfd = os.open(UNDO_LOG + ".lock", os.O_RDWR | os.O_CREAT, 0o600)
    except OSError:
        return None
    try:
        fcntl.flock(lfd, flag)
    except OSError:
        os.close(lfd)
        return None
    return lfd


def _undo_unlock(lfd):
    try:
        fcntl.flock(lfd, fcntl.LOCK_UN)
    finally:
        os.close(lfd)


def log_event(rec):
    """Append one event to the undo journal (no-op when persistence is off)."""
    if not undo_persist_on():
        return
    line = (json.dumps(rec, separators=(",", ":")) + "\n").encode("utf-8")
    lfd = _undo_lock(fcntl.LOCK_SH)
    if lfd is None:
        return
    try:
        fd = os.open(UNDO_LOG, os.O_WRONLY | os.O_APPEND | os.O_CREAT, 0o600)
        try:
            os.write(fd, line)   # one write() == one atomic append under O_APPEND
        finally:
            os.close(fd)
    except OSError:
        pass
    finally:
        _undo_unlock(lfd)


def _read_undo_log():
    try:
        with open(UNDO_LOG, "r", encoding="utf-8") as f:
            raw = f.read()
    except OSError:
        return []
    recs = []
    for line in raw.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            recs.append(json.loads(line))
        except ValueError:
            # A half-written trailing line from a crash mid-append: skip it.
            continue
    return recs


def replay_log(recs):
    """Reconstruct (undo, redo) stacks from journal events, mirroring the live
    record/undo/redo semantics."""
    undo, redo = [], []
    for rec in recs:
        t = rec.get("t")
        if t == "act":
            act = rec.get("act")
            if act:
                undo.append(act)
                redo.clear()
        elif t == "undo":
            if undo:
                redo.append(undo.pop())
        elif t == "redo":
            if redo:
                undo.append(redo.pop())
        # "session" markers carry no stack effect.
    return undo, redo


def load_undo():
    """Seed the undo/redo stacks from the journal — empty when persistence is
    off or no journal exists yet."""
    if not undo_persist_on():
        return [], []
    return replay_log(_read_undo_log())


def compact_log():
    """When the journal has grown large, rewrite it down to the last
    UNDO_LOG_CAP live undo entries. Exclusive-locked so no append races the
    rewrite. The persisted redo stack is dropped — a redo across a compaction
    isn't worth the event-ordering bookkeeping. Best called once at launch."""
    if not undo_persist_on():
        return
    lfd = _undo_lock(fcntl.LOCK_EX)
    if lfd is None:
        return
    try:
        recs = _read_undo_log()
        if len(recs) <= UNDO_LOG_CAP * 4:
            return
        undo, _redo = replay_log(recs)
        undo = undo[-UNDO_LOG_CAP:]
        lines = [json.dumps({"t": "act", "act": a}, separators=(",", ":"))
                 for a in undo]
        body = "\n".join(lines) + ("\n" if lines else "")
        tmp = UNDO_LOG + ".tmp"
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(body)
        os.replace(tmp, UNDO_LOG)
    except OSError:
        pass
    finally:
        _undo_unlock(lfd)


def session_alive(sess):
    """True if `sess` ("<pid>-<ts>") names a process still running on this
    machine. Used only to word the cross-session prompt (a live other instance
    vs. a finished previous session); pid reuse can at worst mislabel the
    wording, never the action."""
    try:
        pid = int(str(sess).split("-", 1)[0])
    except (ValueError, AttributeError):
        return False
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False
    return True


# ----------------------------
# Git snapshot helpers
# ----------------------------

GITIGNORE_ENTRIES = [".trash/", ".notoj_state", ".new_*.md", ".notoj_review.json"]


def ensure_gitignore():
    """Make sure notoj's private files stay out of the snapshot history, even
    for note repos that were initialized before a given entry existed."""
    gitignore = os.path.join(NOTES_DIR, ".gitignore")
    try:
        existing = []
        if os.path.exists(gitignore):
            with open(gitignore, "r", encoding="utf-8") as f:
                existing = f.read().splitlines()
        missing = [e for e in GITIGNORE_ENTRIES if e not in existing]
        if not missing:
            return
        sep = "" if (not existing or existing[-1] == "") else "\n"
        with open(gitignore, "a", encoding="utf-8") as f:
            f.write(sep + "\n".join(missing) + "\n")
    except Exception:
        pass


def git_init():
    git_dir = os.path.join(NOTES_DIR, ".git")
    if not os.path.exists(git_dir):
        subprocess.run(["git", "init"], cwd=NOTES_DIR, capture_output=True)
        ensure_gitignore()
        subprocess.run(["git", "add", "-A"], cwd=NOTES_DIR, capture_output=True)
        subprocess.run(
            ["git", "commit", "-m", "init: notoj snapshot history"],
            cwd=NOTES_DIR, capture_output=True,
        )
    else:
        ensure_gitignore()


def git_commit(msg):
    subprocess.run(["git", "add", "-A"], cwd=NOTES_DIR, capture_output=True)
    subprocess.run(["git", "commit", "-m", msg], cwd=NOTES_DIR, capture_output=True)


# ----------------------------
# History helpers
# ----------------------------

def get_note_commits(path):
    rel = os.path.relpath(path, NOTES_DIR)
    r = subprocess.run(
        ["git", "log", "--follow", "--format=%H\t%at\t%s", "--", rel],
        cwd=NOTES_DIR, capture_output=True, text=True
    )
    commits = []
    for line in r.stdout.strip().splitlines():
        if "\t" not in line:
            continue
        h, ts, msg = line.split("\t", 2)
        commits.append({"hash": h, "ts": float(ts), "msg": msg})
    return commits


def get_diff_lines(path, commit_hash):
    rel = os.path.relpath(path, NOTES_DIR)
    r = subprocess.run(
        ["git", "diff", commit_hash, "--", rel],
        cwd=NOTES_DIR, capture_output=True, text=True
    )
    return r.stdout.splitlines()


def open_vimdiff_at(path, commit_hash):
    rel = os.path.relpath(path, NOTES_DIR)
    r = subprocess.run(
        ["git", "show", f"{commit_hash}:{rel}"],
        cwd=NOTES_DIR, capture_output=True, text=True
    )
    if r.returncode != 0:
        return
    with tempfile.NamedTemporaryFile(mode="w", suffix=".md", delete=False, encoding="utf-8") as f:
        f.write(r.stdout)
        tmp = f.name
    try:
        suspend_curses()
        launch(["vimdiff", tmp, path])
    finally:
        os.unlink(tmp)


def open_hist_last(n):
    rel = os.path.relpath(n["path"], NOTES_DIR)
    r = subprocess.run(
        ["git", "log", "--follow", "-2", "--format=%H", "--", rel],
        cwd=NOTES_DIR, capture_output=True, text=True
    )
    hashes = [h for h in r.stdout.strip().splitlines() if h]
    if len(hashes) < 2:
        return False
    open_vimdiff_at(n["path"], hashes[1])
    return True


MODAL_QUIT = object()
# Sentinel returned through a modal's on_key: the user pressed q — quit the
# whole app, like q everywhere else (ESC is the "back" key inside modals).


def modal_list(stdscr, view):
    """Run a modal list screen — the chrome shared by the history, tags,
    backlinks, and help views: erase, narrow-window bail, underlined header
    row, left list with the cursor row reversed, optional divider + right
    preview pane, footer band, and a blocking key loop speaking the shared
    nav vocabulary (nav_delta / clamp_list / gg).

    `view` is a dict of callbacks/settings:
      count()                            -> number of list rows
      header(w) / footer()               -> bar texts
      draw_row(scr, y, i, selected, lw)  -> draw row i at screen row y
      draw_preview(scr, x0, pw, ph, cur) -> right pane (omit for full-width)
      on_key(k, st) -> None to keep looping, or a 1-tuple (result,) to close
      on_move(st)                        -> selection changed (nav or gg)
      cur                                -> initial cursor index (default 0)

    st is {"cur", "off", "page_h"}; on_key may move the cursor through it.
    Returns the value from on_key's closing tuple."""
    st = {"cur": view.get("cur", 0), "off": 0, "page_h": 1}
    on_key = view["on_key"]
    eof_spins = 0
    # Tick twice a second rather than blocking: a resize is only guaranteed
    # to be noticed by the size poll below (SIGWINCH may surface as
    # KEY_RESIZE, as ERR, or not wake a blocked getch at all, depending on
    # the terminal). An idle tick redraws nothing, so it costs ~0.
    stdscr.timeout(500)

    while True:
        # Pick up resizes even when the SIGWINCH surfaced as ERR instead of
        # KEY_RESIZE (tmux): poll the real size, like the main loop does —
        # otherwise getmaxyx() stays stale and nothing reflows until cells
        # happen to change. clear() forces a full repaint at the new size.
        try:
            ts = os.get_terminal_size()
            if (ts.lines, ts.columns) != stdscr.getmaxyx():
                curses.resizeterm(ts.lines, ts.columns)
                stdscr.clear()
        except (curses.error, OSError):
            pass

        stdscr.erase()
        h, w = stdscr.getmaxyx()

        # Same narrow-window bail as draw(): below this the pane widths go
        # nonsensical and addnstr would error out. Keys still reach on_key,
        # so the view's exit keys keep working while squeezed.
        narrow = h < 5 or w < MIN_W_ERROR
        if narrow:
            addnstr_w(stdscr, 0, 0, "window too narrow", max(1, w - 1))
        else:
            page_h = st["page_h"] = h - 2   # rows 1..h-2; footer bar at h-1
            n_rows = view["count"]()
            # Per-frame clamp: covers the initial cursor, on_key cursor
            # moves, shrinking lists, and terminal resizes in one place.
            clamp_list(st, n_rows, page_h)
            list_w = min(38, w // 3) if view.get("draw_preview") else w - 1

            try:
                stdscr.hline(0, 0, ord(" ") | curses.A_UNDERLINE, w)
            except curses.error:
                pass
            addnstr_w(stdscr, 0, 0, view["header"](w), w - 1,
                      curses.A_BOLD | curses.A_UNDERLINE)

            for i in range(st["off"], min(n_rows, st["off"] + page_h)):
                view["draw_row"](stdscr, i - st["off"] + 1, i,
                                 i == st["cur"], list_w)

            if view.get("draw_preview"):
                for y in range(1, h - 1):
                    stdscr.addch(y, list_w, curses.ACS_VLINE)
                view["draw_preview"](stdscr, list_w + 1, w - list_w - 2,
                                     page_h, st["cur"])

            try:
                stdscr.hline(h - 1, 0, ord(" ") | footer_attr(), w)
            except curses.error:
                pass
            addnstr_w(stdscr, h - 1, 0, view["footer"](), w - 1, footer_attr())

        stdscr.refresh()
        t_wait = time.monotonic()
        k = stdscr.getch()

        # A terminal resize arrives as KEY_RESIZE — or as ERR (-1) when the
        # SIGWINCH interrupts the blocked getch (tmux does this). Neither is
        # a view key: just loop, redrawing at the new size.
        if k in (-1, curses.KEY_RESIZE):
            # But a *dead* terminal (closed pty, dropped SSH) also yields
            # ERR — instantly, ignoring the timeout — which would busy-spin
            # at 100% CPU. A run of instant ERRs means the input is gone:
            # unwind; the main loop's matching guard then exits the app.
            if k == -1 and time.monotonic() - t_wait < 0.01:
                eof_spins += 1
                if eof_spins > 50:
                    return None
            else:
                eof_spins = 0
            continue
        eof_spins = 0

        if not narrow and (k in NAV_KEYS or k == ord("g")):
            prev = st["cur"]
            if k == ord("g"):
                if stdscr.getch() == ord("g"):
                    st["cur"] = 0
            else:
                d = nav_delta(k, st["page_h"])
                if d == NAV_BOTTOM:
                    st["cur"] = view["count"]() - 1
                else:
                    st["cur"] += d
            clamp_list(st, view["count"](), st["page_h"])
            if st["cur"] != prev and view.get("on_move"):
                view["on_move"](st)
        else:
            r = on_key(k, st)
            if r is not None:
                return r[0]


def hist_view(stdscr, n):
    commits = get_note_commits(n["path"])
    if not commits:
        return

    vs = {"diff": [], "d_scroll": 0}

    def load_diff(cur):
        vs["diff"] = get_diff_lines(n["path"], commits[cur]["hash"])
        vs["d_scroll"] = 0

    load_diff(0)

    def draw_row(scr, y, i, selected, list_w):
        c = commits[i]
        attr = curses.color_pair(1) | curses.A_BOLD
        if selected:
            attr |= curses.A_REVERSE
        date_str = datetime.fromtimestamp(c["ts"]).strftime("%m-%d %H:%M")
        addnstr_w(scr, y, 0, f"{date_str} {c['msg']}", list_w - 1, attr)

    def draw_preview(scr, x0, pw, ph, cur):
        diff = vs["diff"]
        if not diff:
            addnstr_w(scr, 1, x0, "(no changes vs current)", pw, curses.A_DIM)
            return
        for i, line in enumerate(diff[vs["d_scroll"]:vs["d_scroll"] + ph]):
            if line.startswith("+") and not line.startswith("+++"):
                attr = curses.color_pair(3)
            elif line.startswith("-") and not line.startswith("---"):
                attr = curses.color_pair(2)
            elif line.startswith("@@"):
                attr = curses.color_pair(4)
            else:
                attr = curses.A_NORMAL
            addnstr_w(scr, i + 1, x0, line.expandtabs(4), pw, attr)

    def on_key(k, st):
        if k in [ord("q"), 27]:
            return (None,)
        if k in (10, 13):
            open_vimdiff_at(n["path"], commits[st["cur"]]["hash"])
            stdscr.refresh()
        elif k == curses.KEY_NPAGE:
            vs["d_scroll"] = min(vs["d_scroll"] + st["page_h"],
                                 max(0, len(vs["diff"]) - st["page_h"]))
        elif k == curses.KEY_PPAGE:
            vs["d_scroll"] = max(0, vs["d_scroll"] - st["page_h"])
        return None

    modal_list(stdscr, {
        "count": lambda: len(commits),
        "header": lambda w: f"history: {title(n)}",
        "footer": lambda: "j/k select  PgDn/PgUp scroll diff  ⮐ vimdiff  q back",
        "draw_row": draw_row,
        "draw_preview": draw_preview,
        "on_key": on_key,
        "on_move": lambda st: load_diff(st["cur"]),   # one git show per move
    })


def tags_view(stdscr, notes, focus=None, ui=None):
    """Full-screen browser of every tag (T): count, name, and how recently a
    note carrying it was touched. s cycles the sort (recent → count → name);
    recent is the default, and `ui` (a dict) persists the chosen mode across
    visits. `focus` preselects a tag (used when ESC from a tag filter jumps
    back here). Enter returns the chosen tag name (the caller filters the
    notes list on it); ESC returns None (back); q returns MODAL_QUIT."""
    stats = tag_stats(notes)
    if not stats:
        return None
    vs = {"mode_i": (ui or {}).get("mode_i", 0)}
    vs["items"] = sort_tag_stats(stats, TAG_SORTS[vs["mode_i"]])
    cur0 = 0
    if focus is not None:
        for i, it in enumerate(vs["items"]):
            if it[0] == focus:
                cur0 = i
                break
    count_w = max(len(str(c)) for _, c, _ in vs["items"])

    def draw_row(scr, y, i, selected, list_w):
        tag, count, last = vs["items"][i]
        attr = curses.color_pair(3)
        if selected:
            attr |= curses.A_REVERSE
        addnstr_w(scr, y, 0, f"{count:>{count_w}}  #{tag}  ({ago(last)})",
                  list_w - 1, attr)

    def draw_preview(scr, x0, pw, ph, cur):
        sel_tag = vs["items"][cur][0]
        # Filtering every note by the selected tag is too costly to redo on
        # each j/k; it only changes when the selection does.
        tagged = frame_cache(
            vs.setdefault("_prev", {}), sel_tag,
            lambda: sort_notes(filter_by_tags(notes, [sel_tag]), "modified", True))
        for i, m in enumerate(tagged[:ph]):
            line = f"{title(m)}  ({ago(m.get('modificationDate'))})"
            addnstr_w(scr, i + 1, x0, line, pw, curses.color_pair(4))

    def on_key(k, st):
        if k == 27:
            return (None,)
        if k == ord("q"):
            return (MODAL_QUIT,)
        if k == ord("s"):
            sel = vs["items"][st["cur"]][0]
            vs["mode_i"] = (vs["mode_i"] + 1) % len(TAG_SORTS)
            if ui is not None:
                ui["mode_i"] = vs["mode_i"]
            vs["items"] = sort_tag_stats(stats, TAG_SORTS[vs["mode_i"]])
            # Keep the selection on the same tag across the re-sort; the
            # scaffold's per-frame clamp re-centers the scroll window.
            for i, it in enumerate(vs["items"]):
                if it[0] == sel:
                    st["cur"] = i
                    break
        elif k in (10, 13):
            return (vs["items"][st["cur"]][0],)
        return None

    return modal_list(stdscr, {
        "cur": cur0,
        "count": lambda: len(vs["items"]),
        "header": lambda w: f"tags ({len(vs['items'])})  sort:{TAG_SORTS[vs['mode_i']]}",
        "footer": lambda: "j/k select  s sort  ⮐ filter notes by tag  ESC back  q quit",
        "draw_row": draw_row,
        "draw_preview": draw_preview,
        "on_key": on_key,
    })


def backlinks_view(stdscr, notes, note):
    """Notes linking to `note` (b): [[wikilinks]] and [text](target) links,
    the ones Vim's gf follows. The preview shows the referencing lines with
    the source title highlighted. Enter returns the chosen note's path (the
    caller jumps there); ESC returns None (back); q returns MODAL_QUIT."""
    links = find_backlinks(notes, note)
    fname = os.path.basename(note["path"])
    hi_token = title(note).lower()
    prev_cache = {}   # memoizes the preview scan across redraws (see frame_cache)

    def draw_row(scr, y, i, selected, list_w):
        m = links[i]
        attr = curses.color_pair(1)
        if selected:
            attr |= curses.A_REVERSE
        addnstr_w(scr, y, 0, f"{title(m)}  ({ago(m.get('modificationDate'))})",
                  list_w - 1, attr)

    def draw_preview(scr, x0, pw, ph, cur):
        if not links:
            addnstr_w(scr, 1, x0, "(no notes link to this one)", pw, curses.A_DIM)
            return
        # Scanning the source note for referencing lines only changes with the
        # selection, so cache it rather than re-scan on every scroll step.
        hits = frame_cache(prev_cache, cur,
                           lambda: linking_lines(content(links[cur]), fname))
        for i, line in enumerate(hits[:ph]):
            draw_line_highlighted(
                scr, i + 1, x0, line.expandtabs(4).strip(), pw,
                curses.color_pair(4),
                curses.color_pair(5) | curses.A_BOLD,
                [hi_token] if hi_token else [],
            )

    def on_key(k, st):
        if k == 27:
            return (None,)
        if k == ord("q"):
            return (MODAL_QUIT,)
        if k in (10, 13) and links:
            return (links[st["cur"]]["path"],)
        return None

    return modal_list(stdscr, {
        "count": lambda: len(links),
        "header": lambda w: f"backlinks: {title(note)} ({len(links)})",
        "footer": lambda: "j/k select  ⮐ go to note  ESC back  q quit",
        "draw_row": draw_row,
        "draw_preview": draw_preview,
        "on_key": on_key,
    })


def help_rows(width):
    """KEYMAP flattened for the ? overlay: (kind, key, text) rows — section
    headers, key entries (wrapped to `width`, continuation lines carry an
    empty key), and blank separators between sections."""
    key_w = _help_key_w()
    desc_w = max(20, width - 2 - key_w - 1)
    rows = []
    for section, entries in KEYMAP:
        if rows:
            rows.append(("blank", "", ""))
        rows.append(("section", "", section))
        for action, key, desc in entries:
            label = action_label(action, key) if action else key
            for j, part in enumerate(textwrap.wrap(desc, desc_w)):
                rows.append(("entry", label if j == 0 else "", part))
    return rows


def _help_key_w():
    """Width of the key column in the help screens, using effective bindings."""
    return max(disp_width(action_label(a, k) if a else k)
               for _, entries in KEYMAP for a, k, _ in entries) + 3


def help_view(stdscr):
    """In-app key reference (?): KEYMAP in a scrollable full-width overlay,
    keys colored apart from their meanings, descriptions wrapped to the live
    terminal width. Nav keys scroll; any other key closes it."""
    key_w = _help_key_w()
    vs = {"w": None, "rows": []}

    def rows_now():
        # Rebuilt whenever the width changes (count() runs every frame, so a
        # KEY_RESIZE rewraps before the next draw).
        w = stdscr.getmaxyx()[1]
        if w != vs["w"]:
            vs["w"] = w
            vs["rows"] = help_rows(w)
        return vs["rows"]

    def draw_row(scr, y, i, selected, list_w):
        rows = rows_now()
        if i >= len(rows):
            return
        kind, key, text = rows[i]
        if kind == "blank":
            return
        base = curses.A_REVERSE if selected else 0
        if kind == "section":
            addnstr_w(scr, y, 0, text, list_w - 1, curses.A_BOLD | base)
        else:
            # Pad the key field by display width so wide keys (←/→, ↑/↓, ⌫)
            # don't shove the description column out of alignment.
            key_field = key + " " * max(0, key_w - disp_width(key))
            addnstr_w(scr, y, 2, key_field, max(1, list_w - 3),
                      curses.color_pair(3) | base)
            addnstr_w(scr, y, 2 + key_w, text, max(1, list_w - 3 - key_w), base)

    return modal_list(stdscr, {
        "count": lambda: len(rows_now()),
        "header": lambda w: "notoj keys",
        "footer": lambda: "j/k scroll  q quit  any other key closes",
        "draw_row": draw_row,
        # q quits the app (like everywhere); any other non-nav key closes.
        "on_key": lambda k, st: (MODAL_QUIT,) if k == ord("q") else (None,),
    })


# ----------------------------
# Conflict detection / resolution
# ----------------------------

CONFLICT_RE = re.compile(r'^(.+)\.sync-conflict-[\d]+-[\d]+-[A-Z0-9]+(\.[^.]+)$')


def find_conflicts():
    """Return list of (original_path, conflict_path) pairs for Syncthing conflicts, oldest first.
    Scans NOTES_DIR recursively (including .trash) so conflicts in subdirectories aren't missed;
    skips .git and .stversions internals. The cron conflict sentinel covers other synced folders."""
    results = []
    for dirpath, dirnames, filenames in os.walk(NOTES_DIR):
        dirnames[:] = [d for d in dirnames if d not in (".git", ".stversions")]
        for fn in filenames:
            if not fn.endswith(".md"):
                continue
            m = CONFLICT_RE.match(fn)
            if m:
                conflict = os.path.join(dirpath, fn)
                original = os.path.join(dirpath, m.group(1) + m.group(2))
                results.append((original, conflict))
    return sorted(results, key=lambda t: t[1])


def resolve_conflict(original, conflict):
    # Snapshot the conflict copy into git history first: the copy is deleted
    # below regardless of what was (or wasn't) merged in vimdiff, and conflict
    # files never enter the regular snapshot commits, so without this an
    # accidental :qa would lose that version forever. -f because copies under
    # .trash/ are gitignored.
    rel = os.path.relpath(conflict, NOTES_DIR)
    subprocess.run(["git", "add", "-f", "--", rel], cwd=NOTES_DIR, capture_output=True)
    subprocess.run(["git", "commit", "-m", f"conflict copy: {_stem(conflict)}"],
                   cwd=NOTES_DIR, capture_output=True)
    suspend_curses()
    if os.path.exists(original):
        if not launch(["vimdiff", original, conflict]):
            return   # editor missing — leave both files for a later retry
    else:
        if not launch(vim_cmd() + [conflict]):
            return
        if os.path.exists(conflict):
            os.rename(conflict, original)
            conflict = None
    if conflict and os.path.exists(conflict):
        os.remove(conflict)
    stem = os.path.splitext(os.path.basename(original))[0]
    git_commit(f"resolve: {stem}")


# ----------------------------
# Actions
# ----------------------------

def check_rename(n):
    """After a content edit through notoj: bump the modified date, increment the
    version (edit counter), and rename the file if the first line changed.

    Version is incremented only here — on a local content save — so it stays a
    coherent edit count across devices: normalize_external_note preserves an
    incoming version (the editing device already bumped it), avoiding double
    counts when Syncthing delivers a change."""
    path = n["path"]
    if not os.path.exists(path):
        return

    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return

    if not text.startswith("---\n"):
        return

    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        return

    meta = parse_frontmatter(text[4:fm_end])
    body = text[fm_end + 5:]
    if body.startswith("\n"):
        body = body[1:]

    new_first_line = derive_title(body)

    title_changed = bool(new_first_line) and new_first_line != (meta.get("title") or "")
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    new_yaml_lines = []
    title_written = False
    for line in text[4:fm_end].splitlines():
        if line.startswith("title:") and title_changed:
            new_yaml_lines.append(f"title: {yaml_scalar(new_first_line)}")
            title_written = True
        elif line.startswith("modified:"):
            new_yaml_lines.append(f"modified: {now_iso}")
        elif line.startswith("version:"):
            try:
                v = int(line.split(":", 1)[1].strip()) + 1
            except ValueError:
                v = 1
            new_yaml_lines.append(f"version: {v}")
        else:
            new_yaml_lines.append(line)
            if line.startswith("id:") and title_changed and not title_written:
                new_yaml_lines.append(f"title: {yaml_scalar(new_first_line)}")
                title_written = True

    new_text = "---\n" + "\n".join(new_yaml_lines) + text[fm_end:]

    if title_changed:
        new_stem = slugify(new_first_line)
        new_path = os.path.join(NOTES_DIR, new_stem + ".md")
        if os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(path):
            i = 2
            while os.path.exists(new_path):
                new_path = os.path.join(NOTES_DIR, f"{new_stem} ({i}).md")
                i += 1
    else:
        new_path = path

    atomic_write(path, new_text)

    if new_path != path:
        os.rename(path, new_path)

    sync_hashtags(new_path)
    schedule_inline_loop(new_path)
    return new_path


# Vimscript sourced into the Vim sessions notoj spawns. In markdown buffers it:
#   - makes gf follow [[wikilinks]] and [text](target) links to other notes in
#     $NOTOJ_NOTES_DIR, falling back to built-in gf otherwise;
#   - highlights [[wikilinks]] (notojWikiLink, linked to Underlined);
#   - exposes NotojOpenAtTitle() to open a note at its title line.
# Embedded here (rather than shipped as a sibling file) so notoj stays a single
# self-contained program.
NOTOJ_VIM_SCRIPT = r"""
function! s:NotojEdit(name) abort
  let l:dir = $NOTOJ_NOTES_DIR
  if empty(l:dir)
    return 0
  endif
  let l:name = substitute(a:name, '^\s*\(.\{-}\)\s*$', '\1', '')
  let l:name = substitute(l:name, '^<\(.*\)>$', '\1', '')
  if empty(l:name)
    return 0
  endif
  if l:name !~? '\.md$'
    let l:name .= '.md'
  endif
  execute 'edit' fnameescape(l:dir . '/' . l:name)
  return 1
endfunction

function! s:NotojSpan(line, cur, pat) abort
  let l:start = 0
  while l:start <= len(a:line)
    let l:m = matchstrpos(a:line, a:pat, l:start)
    if l:m[1] < 0
      return []
    endif
    if a:cur >= l:m[1] && a:cur < l:m[2]
      return l:m
    endif
    let l:start = l:m[2] > l:m[1] ? l:m[2] : l:m[1] + 1
  endwhile
  return []
endfunction

function! NotojFollow() abort
  let l:line = getline('.')
  let l:cur = col('.') - 1

  let l:m = s:NotojSpan(l:line, l:cur, '\[\[[^][]*\]\]')
  if !empty(l:m)
    let l:name = substitute(l:m[0], '^\[\[\(.*\)\]\]$', '\1', '')
    if s:NotojEdit(l:name)
      return
    endif
  endif

  let l:m = s:NotojSpan(l:line, l:cur, '\[[^][]*\]([^()]*)')
  if !empty(l:m)
    let l:name = substitute(l:m[0], '^\[[^][]*\](\(.*\))$', '\1', '')
    if s:NotojEdit(l:name)
      return
    endif
  endif

  silent! normal! gf
endfunction

" Line number of the title: first non-blank line after the frontmatter block.
function! s:NotojTitleLine() abort
  let l:last = line('$')
  let l:start = 1
  if getline(1) ==# '---'
    let l:i = 2
    while l:i <= l:last
      if getline(l:i) ==# '---'
        let l:start = l:i + 1
        break
      endif
      let l:i += 1
    endwhile
  endif
  let l:i = l:start
  while l:i <= l:last
    if getline(l:i) !~# '^\s*$'
      return l:i
    endif
    let l:i += 1
  endwhile
  return l:start
endfunction

" Put the cursor on the title line, and if the body fills the window, pin that
" line to the top so the frontmatter scrolls off screen.
function! NotojOpenAtTitle() abort
  let l:tl = s:NotojTitleLine()
  call cursor(l:tl, 1)
  if line('$') - l:tl + 1 >= winheight(0)
    let l:v = winsaveview()
    let l:v.topline = l:tl
    call winrestview(l:v)
  endif
endfunction

function! s:NotojSetup() abort
  if !empty($NOTOJ_NOTES_DIR)
    let &l:path = $NOTOJ_NOTES_DIR
  endif
  nnoremap <buffer> <silent> gf :call NotojFollow()<CR>
  if !exists('w:notoj_wikilink_match')
    let w:notoj_wikilink_match = matchadd('notojWikiLink', '\[\[[^][]*\]\]')
  endif
endfunction

highlight default link notojWikiLink Underlined

augroup notoj_follow
  autocmd!
  autocmd FileType markdown call s:NotojSetup()
  autocmd ColorScheme * highlight default link notojWikiLink Underlined
augroup END

if &filetype ==# 'markdown'
  call s:NotojSetup()
endif
"""

_vim_helper_path = None


def load_tag_editors():
    """{tag: command} from `tag_editor.<tag> = <command>` config lines, letting
    a note open in a custom editor/terminal based on its tags. Example:

        tag_editor.arabic = mlvim

    opens any note tagged `arabic` in mlterm (where Arabic letters connect
    cursively — gnome-terminal/VTE can't, it locks every glyph to a fixed
    cell). The mapped command receives the usual vim args (sourced helper,
    cursor position, file path) appended, so it must be a vim launcher that
    forwards "$@" to vim."""
    editors = {}
    for key, val in _read_config().items():
        if key.startswith("tag_editor.") and val:
            tag = key[len("tag_editor."):].strip().lower()
            if tag:
                editors[tag] = val
    return editors


def is_vimlike(cmd):
    """Whether the editor command takes Vim's `-c` args. notoj appends Vim-only
    options (sourcing the gf helper, cursor placement, startinsert); a non-Vim
    editor (emacs/gedit/nano) would mistake those for filenames, so they're
    only added for Vim-family editors. mlvim matches via the substring."""
    if not cmd:
        return False
    base = os.path.basename(cmd[0]).lower()
    return "vim" in base or base in ("vi", "view", "ex", "nvi")


def vim_cmd(note=None):
    """Editor command for a spawned session, resolved in order: a `tag_editor`
    entry matching one of the note's tags (e.g. `arabic` -> `mlvim`), then
    $NOTOJ_VIM, then the `default_editor` config, then plain `vim`. shlex-split
    so multi-word commands work."""
    if note is not None:
        editors = load_tag_editors()
        if editors:
            for tag in (note.get("tags") or []):
                cmd = editors.get(str(tag).strip().lower())
                if cmd:
                    return shlex.split(cmd)
    return shlex.split(os.environ.get("NOTOJ_VIM", "").strip()
                       or config_get("default_editor", "").strip()
                       or "vim")


def vim_source_args():
    """Materialize the embedded notoj vimscript to a temp file (once per run)
    and return the -c args that source it, giving spawned Vim sessions
    note-link gf support."""
    global _vim_helper_path
    if _vim_helper_path is None:
        fd, path = tempfile.mkstemp(prefix="notoj-", suffix=".vim")
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(NOTOJ_VIM_SCRIPT)
        _vim_helper_path = path
        atexit.register(lambda p=path: os.path.exists(p) and os.remove(p))
    esc = _vim_helper_path.replace("\\", "\\\\").replace(" ", "\\ ")
    return ["-c", "source " + esc]


def vim_search_pattern(q):
    """Translate a notoj search query into a Vim search pattern, so opening a
    matched note can highlight the hits and drop the cursor on the first one.
    Mirrors rank_notes: a quoted phrase stays contiguous with any whitespace
    between its words (\\s\\+), while a token query ORs its terms so `n` cycles
    through every hit. Built in \\V ("very nomagic") so the typed text is taken
    literally — only backslashes need doubling — with a leading \\c for
    case-insensitivity. Returns None when there's nothing to search for."""
    q = (q or "").strip()
    if not q:
        return None
    lit = lambda s: s.replace("\\", "\\\\")
    if q.startswith('"') and q.endswith('"') and len(q) > 2:
        words = q[1:-1].split()
        if not words:
            return None
        # \_s (not \s) so the gap can span a line break, matching how the
        # quoted-phrase search joins the note's running text in rank_notes.
        body = r"\_s\+".join(lit(w) for w in words)
    else:
        toks = q.split()
        if not toks:
            return None
        body = r"\|".join(lit(t) for t in toks)
    return r"\c\V" + body


def _vim_position_args(src, end, search):
    """The -c args that place the cursor (and, with an active search, highlight
    the matches) for a spawned Vim.

    `search` is always wired in with `let @/` rather than `/pat`/`+/pat`: notoj
    ranks fuzzily (edit distance, tag and substring hits), so a note can rank
    for a query it doesn't contain verbatim. `let @/` sets the pattern (so `n`
    and 'hlsearch' use *this* query, never a stale one) without the E486 that a
    failed `/pat` would raise. Positioning: the last line (end), else the first
    literal match via the quiet search() — falling back to the title when the
    note has no verbatim hit — else the title. `src` flags that the notoj
    vimscript (with NotojOpenAtTitle) was sourced."""
    args = []
    if search:
        args += ["-c", "let @/ = '%s'" % search.replace("'", "''"),
                 "-c", "set hlsearch"]
    if end:
        args += ["-c", "normal G"]
    elif search:
        # search() (unlike /pat or `normal n`) is silent when there's no match,
        # so a fuzzy-only hit won't beep or error — it just keeps the fallback.
        jump = "silent! keepjumps call cursor(1, 1) | if search(@/, 'cw') == 0"
        jump += " | call NotojOpenAtTitle() | endif" if src else " | endif"
        args += ["-c", jump]
    elif src:
        args += ["-c", "call NotojOpenAtTitle()"]
    return args


def open_note(n, end=False, search=None):
    suspend_curses()
    path = n["path"]
    before = None
    mtime_before = None
    if os.path.exists(path):
        mtime_before = os.path.getmtime(path)
        try:
            with open(path, "r", encoding="utf-8") as f:
                before = f.read()
        except Exception:
            before = None
    ed = vim_cmd(n)
    cmd = list(ed)
    if is_vimlike(ed):
        src = vim_source_args()
        cmd += src + _vim_position_args(src, end, search)
    cmd.append(path)
    launch(cmd)   # a missing editor leaves mtime unchanged → no restore below
    if os.path.exists(path) and os.path.getmtime(path) != mtime_before:
        final = check_rename(n) or path
        git_commit(f"edit: {title(n)}")
        if before is not None and os.path.exists(final):
            try:
                with open(final, "r", encoding="utf-8") as f:
                    after = f.read()
            except Exception:
                after = None
            if after is not None and after != before:
                try:
                    mtime = os.path.getmtime(final)
                except OSError:
                    mtime = None
                return {"kind": "edit", "path": final, "before": before,
                        "after": after, "mtime": mtime}
    return None


def edit_trash_note(n, end=False, search=None):
    """Open a trashed note in Vim. Any saved change restores the note from the
    trash into the notes dir (then the usual title-rename pipeline runs);
    quitting Vim without writing leaves it in the trash. Returns the restored
    path, or None when the note stayed trashed."""
    path = n["path"]
    if not os.path.exists(path):
        return None
    mtime_before = os.path.getmtime(path)
    ed = vim_cmd(n)
    cmd = list(ed)
    if is_vimlike(ed):
        src = vim_source_args()
        cmd += src + _vim_position_args(src, end, search)
    cmd.append(path)
    suspend_curses()
    launch(cmd)   # a missing editor leaves mtime unchanged → returns None below
    if not os.path.exists(path) or os.path.getmtime(path) == mtime_before:
        return None
    restored = do_restore(path, os.path.join(NOTES_DIR, os.path.basename(path)))
    if not restored:
        return None
    final = check_rename({"path": restored}) or restored
    git_commit(f"edit: {title(n)}")
    return final



def _stem(path):
    return os.path.splitext(os.path.basename(path))[0]


def do_trash(path):
    """Move a note file into the trash, returning its trash path."""
    os.makedirs(TRASH_DIR, exist_ok=True)
    base = os.path.basename(path)
    dest = os.path.join(TRASH_DIR, base)
    if os.path.exists(dest):
        stem, ext = os.path.splitext(base)
        i = 2
        while os.path.exists(dest):
            dest = os.path.join(TRASH_DIR, f"{stem} ({i}){ext}")
            i += 1
    os.rename(path, dest)
    git_commit(f"trash: {_stem(path)}")
    return dest


def do_restore(trash_path, orig_path):
    """Move a trashed file back, preferring its original path, returning the
    path it landed at."""
    if not os.path.exists(trash_path):
        return None
    dest = orig_path
    if os.path.exists(dest):
        d = os.path.dirname(orig_path) or NOTES_DIR
        stem, ext = os.path.splitext(os.path.basename(orig_path))
        i = 2
        while os.path.exists(dest):
            dest = os.path.join(d, f"{stem} ({i}){ext}")
            i += 1
    os.rename(trash_path, dest)
    git_commit(f"restore: {_stem(dest)}")
    return dest


def trash_note(n):
    return do_trash(n["path"])


def rename_to_title(path):
    """Rename a note file so its name matches its title's slug. Undo/redo of
    an edit rewrites the content from history, which can leave the filename
    carrying the other version's title; this re-syncs them. Returns the
    resulting path (the input path when the name already agrees)."""
    n = load_md(path)
    if not n:
        return path
    stem = slugify(title(n))
    d = os.path.dirname(path) or "."
    candidate = os.path.join(d, stem + ".md")
    i = 2
    while True:
        if os.path.abspath(candidate) == os.path.abspath(path):
            return path
        if not os.path.exists(candidate):
            break
        candidate = os.path.join(d, f"{stem} ({i}).md")
        i += 1
    os.rename(path, candidate)
    return candidate


# An external edit (another machine over Syncthing, Markor on the phone) bumps
# the file's mtime; notoj's own post-edit normalization preserves it (os.utime).
# So an mtime drift beyond a second means the note changed under a stored edit
# act — replaying it would clobber that newer content, so we skip instead. The
# guard errs toward skipping: a false skip just declines an undo, never
# overwrites. Edit acts only; trash/loop/tags/defer apply safely as-is.
STALE_EPS = 1.0   # seconds; absorbs the sub-second mtime truncation a normalize


def _edit_stale(act):
    if act.get("mtime") is None:
        return False
    try:
        return abs(os.path.getmtime(act["path"]) - act["mtime"]) > STALE_EPS
    except OSError:
        return True   # file gone — can't apply the edit


def undo_action(act, review=None):
    """Reverse a recorded destructive action (mutating act with live paths so a
    later redo stays consistent). Returns the path to focus afterward, or the
    STALE sentinel when an edit's note changed underneath it.

    `review` is the live resurface dict; it is required to undo a "defer" action
    — snooze (z) or schedule (S) — (other kinds ignore it)."""
    kind = act["kind"]
    if kind == "defer":
        if review is not None:
            # Restore the prior resurface state: a missing "before" means the
            # loop had no review entry, so undo removes the one defer added.
            if act.get("before") is None:
                review.pop(act["id"], None)
            else:
                review[act["id"]] = act["before"]
            save_review(review)
        return act.get("path")
    if kind == "trash":
        restored = do_restore(act["trash"], act["orig"])
        if restored:
            act["orig"] = restored
        return restored
    if kind == "loop":
        if reopen_loop(act["path"], act.get("mod")):
            git_commit(f"reopen loop: {_stem(act['path'])}")
        return act["path"]
    if kind == "edit":
        if _edit_stale(act):
            return STALE
        atomic_write(act["path"], act["before"])
        act["path"] = rename_to_title(act["path"])
        try:
            act["mtime"] = os.path.getmtime(act["path"])
        except OSError:
            pass
        git_commit(f"undo edit: {_stem(act['path'])}")
        return act["path"]
    if kind == "tags":
        if remove_tags_frontmatter(act["path"], act["added"]):
            # Tagging bumped the modified date (via the normalize pass);
            # restore the original mtime so undo rolls that back too.
            if act.get("mod"):
                try:
                    os.utime(act["path"], (act["mod"], act["mod"]))
                except OSError:
                    pass
            git_commit(f"untag: {_stem(act['path'])}")
        return act["path"]
    return None


def redo_action(act, review=None):
    """Re-apply a previously undone action. Returns the path to focus, or None
    when the action hides the note (a re-trash).

    `review` is the live resurface dict; it is required to redo a "defer" action
    — snooze (z) or schedule (S) — (other kinds ignore it)."""
    kind = act["kind"]
    if kind == "defer":
        if review is not None:
            review[act["id"]] = act["after"]
            save_review(review)
        return act.get("path")
    if kind == "trash":
        act["trash"] = do_trash(act["orig"])
        return None
    if kind == "loop":
        if remove_tag(act["path"], LOOP_TAG):
            git_commit(f"close loop: {_stem(act['path'])}")
        return act["path"]
    if kind == "edit":
        if _edit_stale(act):
            return STALE
        atomic_write(act["path"], act["after"])
        act["path"] = rename_to_title(act["path"])
        try:
            act["mtime"] = os.path.getmtime(act["path"])
        except OSError:
            pass
        git_commit(f"redo edit: {_stem(act['path'])}")
        return act["path"]
    if kind == "tags":
        if add_tags_keep_date(act["path"], act["added"]):
            git_commit(f"retag: {_stem(act['path'])}")
        return act["path"]
    return None


def load_trash():
    notes = []
    for f in glob.glob(os.path.join(TRASH_DIR, "*.md")):
        n = load_md(f)
        if n:
            notes.append(n)
    return notes


def restore_note(n):
    src = n["path"]
    dst = os.path.join(NOTES_DIR, os.path.basename(src))
    if os.path.exists(dst):
        stem, ext = os.path.splitext(os.path.basename(src))
        i = 2
        while os.path.exists(dst):
            dst = os.path.join(NOTES_DIR, f"{stem} ({i}){ext}")
            i += 1
    os.rename(src, dst)
    git_commit(f"restore: {title(n)}")


def finalize_new_note(tmp_path):
    try:
        with open(tmp_path, "r", encoding="utf-8") as f:
            text = f.read()
    except FileNotFoundError:
        return None

    if not text.startswith("---\n"):
        os.unlink(tmp_path)
        return None

    fm_end = text.find("\n---\n", 4)
    if fm_end == -1:
        os.unlink(tmp_path)
        return None

    body = text[fm_end + 5:]
    if body.startswith("\n"):
        body = body[1:]

    first_line = derive_title(body)

    if not first_line:
        os.unlink(tmp_path)
        return None

    # Rewrite frontmatter: insert title: after id:, update modified:
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    new_yaml_lines = []
    for line in text[4:fm_end].splitlines():
        if line.startswith("modified:"):
            new_yaml_lines.append(f"modified: {now_iso}")
        else:
            new_yaml_lines.append(line)
            if line.startswith("id:"):
                new_yaml_lines.append(f"title: {yaml_scalar(first_line)}")

    new_text = "---\n" + "\n".join(new_yaml_lines) + text[fm_end:]

    stem = slugify(first_line)
    dest = os.path.join(NOTES_DIR, stem + ".md")
    if os.path.exists(dest):
        i = 2
        while os.path.exists(dest):
            dest = os.path.join(NOTES_DIR, f"{stem} ({i}).md")
            i += 1

    with open(tmp_path, "w", encoding="utf-8") as f:
        f.write(new_text)
    os.rename(tmp_path, dest)
    sync_hashtags(dest)
    schedule_inline_loop(dest)
    git_commit(f"add: {first_line}")
    return dest


def new_note():
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    key = uuid.uuid4().hex
    frontmatter = (
        f"---\n"
        f"id: {key}\n"
        f"created: {now_iso}\n"
        f"modified: {now_iso}\n"
        f"version: 1\n"
        f"tags: []\n"
        f"---\n"
    )
    tmp_path = os.path.join(NOTES_DIR, f".new_{key}.md")
    with open(tmp_path, "w", encoding="utf-8") as f:
        f.write(frontmatter + "\n")

    suspend_curses()
    ed = vim_cmd()
    cmd = list(ed)
    if is_vimlike(ed):
        cmd += vim_source_args() + ["-c", "normal G", "-c", "startinsert"]
    cmd.append(tmp_path)
    if not launch(cmd):
        try:
            os.remove(tmp_path)   # editor missing — don't leave a stub note
        except OSError:
            pass
        return None
    return finalize_new_note(tmp_path)


