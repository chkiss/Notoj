def confirm_screen(stdscr, lines):
    """Full-screen interstitial. Returns True to proceed (Enter / y), False to
    cancel (ESC / n / q)."""
    stdscr.timeout(-1)   # block for the answer; the main loop resets this
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    for i, line in enumerate(lines):
        if i + 1 >= h - 1:
            break
        addnstr_w(stdscr, i + 1, 2, line, max(1, w - 3),
                  curses.A_BOLD if i == 0 else curses.A_NORMAL)
    stdscr.refresh()
    eof_spins = 0
    while True:
        t_wait = time.monotonic()
        k = stdscr.getch()
        if k == -1:
            # Dead-terminal guard (see the main loop): a run of instant
            # ERRs means the input is gone — decline and unwind.
            if time.monotonic() - t_wait < 0.01:
                eof_spins += 1
                if eof_spins > 50:
                    return False
            else:
                eof_spins = 0
            continue
        eof_spins = 0
        if k in (10, 13, ord("y"), ord("Y")):
            return True
        if k in (27, ord("n"), ord("N"), ord("q")):
            return False



_footer_band = False   # set in init_colors when the terminal can tint the bar
_message_band = False  # set in init_colors when the status/alert bar can be tinted


_COLOR_NAMES = {"black": 0, "red": 1, "green": 2, "yellow": 3, "blue": 4,
                "magenta": 5, "cyan": 6, "white": 7, "default": -1, "none": -1}


def _color_value(v, default):
    """Resolve a color token — a name (red/green/…/default) or a 0-255 palette
    index — to a curses color number. Falls back to `default`."""
    if not v:
        return default
    v = v.strip().lower()
    if v in _COLOR_NAMES:
        return _COLOR_NAMES[v]
    if v.lstrip("-").isdigit():
        n = int(v)
        if -1 <= n < max(curses.COLORS, 16):
            return n
    return default


def _cfg_color(key, default):
    """Resolve a `color.*` config value to a curses color number."""
    return _color_value(config_get(key), default)


# Modified-date recency gradient: the date / relative-date columns fade from
# warm-bright (just edited) to dim grey (old). DATE_GRADIENT_SPANS are the
# bucket edges, ascending; DATE_GRADIENT_COLORS holds one MORE than the edges
# (the extra is the "older than the last edge" bucket). Both override via
# config (date_gradient / color.date_gradient); 256-color terminals only.
DATE_GRADIENT_SPANS = "1h,3h,6h,12h,1d,1w,1mo,1y"
DATE_GRADIENT_COLORS = "230,223,40,10,11,208,202,102,240"
DATE_RECENT_SECS = 3600     # fallback "recent" cut-off without a 256-color ramp

_date_gradient = None       # [(max_age_secs | None, attr), …] ascending; built in init_colors


def parse_span(s):
    """A recency-bucket duration in seconds, or None. Units: h(our), d(ay),
    w(eek), mo(nth)=30d, y(ear)=365d — e.g. '1h', '12h', '3d', '2w', '1mo'."""
    m = re.fullmatch(r'\s*(\d+(?:\.\d+)?)\s*'
                     r'(h|hr|hrs|hour|hours|d|day|days|w|wk|week|weeks'
                     r'|mo|mon|month|months|y|yr|year|years)\s*',
                     (s or "").lower())
    if not m:
        return None
    secs = {"h": 3600, "d": 86400, "w": 604800, "m": 2592000, "y": 31536000}
    return float(m.group(1)) * secs[m.group(2)[0]]   # only 'month' starts with m


def init_colors():
    global _footer_band, _message_band, _date_gradient
    curses.start_color()
    curses.use_default_colors()

    amber = 214 if curses.COLORS >= 256 else curses.COLOR_YELLOW
    accent = _cfg_color("color.accent", amber)
    # accent = titles, recent dates, markdown headers
    curses.init_pair(1, accent, -1)
    curses.init_pair(2, _cfg_color("color.date", curses.COLOR_RED), -1)
    curses.init_pair(3, _cfg_color("color.tag", curses.COLOR_GREEN), -1)
    curses.init_pair(4, _cfg_color("color.preview", curses.COLOR_CYAN), -1)
    curses.init_pair(5, _cfg_color("color.match", curses.COLOR_GREEN), -1)

    # Footer status bar: default fg over a gray band, distinct enough to read
    # as the screen's bottom edge so every row above it can hold content.
    if curses.COLORS >= 256:
        footer_bg = _cfg_color("color.footer_bg", 239)
        curses.init_pair(10, -1, footer_bg)
        _footer_band = True

        # Status / alert message bar (cross-session undo prompts, stale-skip
        # notices). Default is the inverse of the title look — the accent and
        # footer-band colors swapped, so amber text on default becomes default
        # text on an amber band — a clear highlighted alert. Both ends override.
        msg_fg = _cfg_color("color.message_fg", footer_bg)
        msg_bg = _cfg_color("color.message_bg", accent)
        curses.init_pair(11, msg_fg, msg_bg)
        _message_band = True

        # Modified-date recency gradient. One bucket per edge plus a final
        # "older" bucket, so len(colors) should be len(spans)+1; a short color
        # list reuses its last entry, a long one is truncated.
        spans = sorted({s for s in (parse_span(t) for t in
                        config_get("date_gradient", DATE_GRADIENT_SPANS).split(",")) if s})
        cols = [c for c in (c.strip() for c in
                config_get("color.date_gradient", DATE_GRADIENT_COLORS).split(",")) if c]
        if not cols:
            cols = DATE_GRADIENT_COLORS.split(",")
        gradient = []
        for i in range(len(spans) + 1):
            curses.init_pair(20 + i, _color_value(cols[min(i, len(cols) - 1)], 240), -1)
            gradient.append((spans[i] if i < len(spans) else None,
                             curses.color_pair(20 + i)))
        _date_gradient = gradient


def footer_attr():
    """Attr for the footer bar (row h-1): gray band, or reverse video — the
    classic status-line look — without 256 colors."""
    if _footer_band:
        return curses.color_pair(10)
    return curses.A_REVERSE


def message_attr():
    """Attr for the status/alert message bar — an amber band with the inverse
    text by default (see init_colors), set via color.message_fg/_bg; reverse
    video without 256 colors so it still stands apart from the footer."""
    if _message_band:
        return curses.color_pair(11) | curses.A_BOLD
    return curses.A_REVERSE | curses.A_BOLD


def date_attr(ts, now):
    """Curses attr for a modification timestamp, from the recency gradient
    (warm/bright = fresh → dim grey = old). Falls back to the binary
    accent/date colors where the 256-color gradient isn't available."""
    if not _date_gradient:
        recent = ts and (now - float(ts)) < DATE_RECENT_SECS
        return curses.color_pair(1) if recent else curses.color_pair(2)
    age = now - float(ts or 0)
    for thresh, attr in _date_gradient:
        if thresh is None or age < thresh:
            return attr
    return _date_gradient[-1][1]


def fit_hints(segments, width):
    """Build the footer from (priority, text) hint segments, joined by two
    spaces. When it doesn't fit, drop whole segments — highest priority
    number first, rightmost first within a tie — instead of letting the
    right edge truncate mid-hint. Empty texts are skipped."""
    segs = [(pri, txt) for pri, txt in segments if txt]
    while True:
        s = "  ".join(t for _, t in segs)
        if disp_width(s) <= width or len(segs) <= 1:
            return s
        worst = max(p for p, _ in segs)
        for i in range(len(segs) - 1, -1, -1):
            if segs[i][0] == worst:
                del segs[i]
                break


def char_width(ch):
    """Display columns a character occupies. Deliberately conservative: any
    glyph that *might* render double-width (CJK, fullwidth, ambiguous, arrows,
    symbols, emoji) counts as 2. A clipped string then never overflows its pane
    and wraps into the neighbouring column — which is what painted preview text
    over the left list. Over-truncating an accented line by a column at the far
    right edge is invisible; under-counting corrupts the screen."""
    if unicodedata.combining(ch):
        return 0
    o = ord(ch)
    if o < 0x20:
        return 0
    if o < 0x7f:                                        # ASCII printable
        return 1
    if unicodedata.east_asian_width(ch) in ("W", "F", "A"):
        return 2
    if o >= 0x2190:                                     # arrows / symbols / emoji
        return 2
    return 1


def disp_width(s):
    if s.isascii():            # fast path: plain ASCII is one column per char
        return len(s)
    return sum(char_width(c) for c in s)


def clip_to_width(s, max_w):
    """Truncate s so its display width does not exceed max_w columns."""
    if max_w <= 0:
        return ""
    if s.isascii():            # fast path: ASCII is one column per char, so a
        return s[:max_w]       # character slice is already a column slice
    w = 0
    for i, ch in enumerate(s):
        w += char_width(ch)
        if w > max_w:
            return s[:i]
    return s


# --- Arabic-script display shaping ------------------------------------------
# Terminals shape contiguous runs, but curses writes cell-by-cell, so any
# Arabic-script text (Arabic, Urdu, Persian, Pashto, …) shows isolated. We
# pre-shape to presentation forms here (display-only; the file on disk is
# never touched). Ligatures OFF keeps it 1 char -> 1 form so column widths are
# unchanged. Bidi is left to the terminal (VTE).
try:
    import arabic_reshaper as _ar
    _reshaper = _ar.ArabicReshaper(configuration={
        'delete_harakat': False,
        'support_ligatures': False,
    })

    def _reshape(s):
        # Arabic *script* (covers Urdu, Persian, Pashto, Sindhi, Uyghur,
        # Kurdish…), the only script with Unicode presentation forms to swap
        # to. Trigger ranges: Arabic, Arabic Supplement, Arabic Extended-A/B,
        # and the two presentation-form blocks.
        if not config_bool("reshape_arabic", True):
            return s
        for ch in s:
            o = ord(ch)
            if (0x600 <= o <= 0x6ff or 0x750 <= o <= 0x77f
                    or 0x870 <= o <= 0x8ff
                    or 0xfb50 <= o <= 0xfdff or 0xfe70 <= o <= 0xfeff):
                return _reshaper.reshape(s)
        return s
except Exception:
    def _reshape(s):
        return s


def addnstr_w(win, y, x, text, max_w, attr=0):
    """Display-width-aware addnstr: the single place every pane draws dynamic
    text through. Clips `text` to max_w *columns* (not characters) so wide
    glyphs (emoji, em-dash, CJK, arrows) can't overrun the budget and wrap into
    the neighbouring column, and swallows the edge-of-window curses error so
    callers don't each need their own try/except."""
    text = clip_to_width(text, max_w)
    if not text:
        return
    disp = _reshape(text)
    try:
        win.addnstr(y, x, disp, len(disp), attr)
    except curses.error:
        pass


def draw_line_highlighted(stdscr, y, x, text, max_w, base_attr, hi_attr, tokens):
    """Render text at (y, x), switching to hi_attr on token-match substrings.

    Column accounting is by display width, so wide glyphs (emoji, em-dash, CJK,
    arrows) advance the cursor by their true width and the line is clipped to
    max_w *columns* — it can't run past the pane and wrap into the next row."""
    text = clip_to_width(text, max_w)
    if not text:
        return
    if not tokens:
        addnstr_w(stdscr, y, x, text, max_w, base_attr)
        return
    pos = 0
    col = x
    rem = max_w                       # remaining budget, in display columns
    tl = text.lower()
    while pos < len(text) and rem > 0:
        best = None
        for tok in tokens:
            idx = tl.find(tok, pos)
            if idx != -1 and (best is None or idx < best[0]):
                best = (idx, tok)
        if best is None:
            addnstr_w(stdscr, y, col, text[pos:], rem, base_attr)
            break
        mi, tok = best
        if mi > pos:
            seg = text[pos:mi]
            addnstr_w(stdscr, y, col, seg, rem, base_attr)
            w = disp_width(seg)
            col += w
            rem -= w
            pos = mi
            if rem <= 0:
                break
        seg = text[mi:mi + len(tok)]
        addnstr_w(stdscr, y, col, seg, rem, hi_attr)
        w = disp_width(seg)
        col += w
        rem -= w
        pos = mi + len(tok)


# --- Markdown preview styling -----------------------------------------------
# Light inline rendering for the preview pane (display-only — the file is never
# touched). Markers are dropped; the spanned text takes a curses attribute:
#   # Heading   -> bold + amber        **bold** / ***both***  -> bold (+italic)
#   *italic*    -> italic              `code`                 -> reverse video
#   ~~strike~~  -> combining overlay (real strikethrough; curses has no attr)
# Only asterisk emphasis is honored (not _underscores_) so snake_case and
# __dunder__ identifiers in code/text aren't accidentally styled. curses
# A_ITALIC is recent; fall back to underline where it's absent.
MD_ITALIC = getattr(curses, "A_ITALIC", curses.A_UNDERLINE)
MD_STRIKE = "̶"
MD_HEADER = re.compile(r"(#{1,6})\s+(.*)$")

_md_inline_re = None


def _md_inline_pattern():
    """Compiled inline-markdown regex, assembled from config (cached). Asterisk
    emphasis is on by default; underscore emphasis is off by default so
    snake_case (_) and __dunder__ (__) identifiers aren't accidentally styled.
    `code` and ~~strike~~ are always on (no false-positive risk)."""
    global _md_inline_re
    if _md_inline_re is None:
        ast = config_bool("markdown_asterisk", True)
        parts = [r"(?P<code>`[^`]+`)"]
        if ast:
            parts.append(r"(?P<bi>\*\*\*[^*]+?\*\*\*)")
            parts.append(r"(?P<b>\*\*[^*]+?\*\*)")
        if config_bool("markdown_underscore_bold", False):
            parts.append(r"(?P<bu>__[^_]+?__)")
        parts.append(r"(?P<s>~~[^~]+?~~)")
        if ast:
            parts.append(r"(?P<i>\*[^*\s][^*]*?\*)")
        if config_bool("markdown_underscore_italic", False):
            parts.append(r"(?P<iu>_[^_\s][^_]*?_)")
        _md_inline_re = re.compile("|".join(parts))
    return _md_inline_re


def _md_entries(raw, base_attr):
    """Parse one preview line into [(logical_char, draw_string, attr)]. The
    logical char drives token-search matching and width; the draw string is
    what's painted (identical, except struck chars carry a combining overlay)."""
    m = MD_HEADER.match(raw)
    if m:
        a = base_attr | curses.A_BOLD | curses.color_pair(1)
        return [(c, c, a) for c in m.group(2)]
    out = []
    pos = 0
    for mt in _md_inline_pattern().finditer(raw):
        if mt.start() > pos:
            out += [(c, c, base_attr) for c in raw[pos:mt.start()]]
        g, s = mt.lastgroup, mt.group()
        strike = False
        if g == "code":
            inner, a = s[1:-1], base_attr | curses.A_REVERSE
        elif g == "bi":
            inner, a = s[3:-3], base_attr | curses.A_BOLD | MD_ITALIC
        elif g in ("b", "bu"):           # **bold** or __bold__
            inner, a = s[2:-2], base_attr | curses.A_BOLD
        elif g == "s":
            inner, a, strike = s[2:-2], base_attr, True
        else:                            # i (*italic*) or iu (_italic_)
            inner, a = s[1:-1], base_attr | MD_ITALIC
        out += [(c, (c + MD_STRIKE) if strike else c, a) for c in inner]
        pos = mt.end()
    if pos < len(raw):
        out += [(c, c, base_attr) for c in raw[pos:]]
    return out


def draw_markdown_line(stdscr, y, x, raw, max_w, base_attr, hi_attr, tokens):
    """Like draw_line_highlighted but renders inline markdown; token matches
    still win, overriding the markdown attribute on the matched run."""
    entries = _md_entries(raw, base_attr)
    if not entries:
        return
    if tokens:
        logical = "".join(e[0] for e in entries).lower()
        hot = [False] * len(entries)
        for tok in tokens:
            if not tok:
                continue
            start = 0
            while True:
                idx = logical.find(tok, start)
                if idx == -1:
                    break
                for j in range(idx, idx + len(tok)):
                    hot[j] = True
                start = idx + len(tok)
        entries = [(e[0], e[1], hi_attr if hot[k] else e[2])
                   for k, e in enumerate(entries)]
    col, rem, i, n = x, max_w, 0, len(entries)
    while i < n and rem > 0:
        attr = entries[i][2]
        j = i
        while j < n and entries[j][2] == attr:
            j += 1
        seg = "".join(e[1] for e in entries[i:j])
        addnstr_w(stdscr, y, col, seg, rem, attr)
        w = disp_width(seg)
        col += w
        rem -= w
        i = j


# ----------------------------
# List navigation (shared by the main list, tags view, and history view)
# ----------------------------

# Sentinel nav_delta result: G — jump to the last item. (gg is a chord and
# stays decoded per surface; only the resulting jump-to-top is trivial.)
NAV_BOTTOM = "bottom"

# Every key nav_delta understands; surfaces gate their nav branch on this.
NAV_KEYS = {ord("j"), ord("k"), ord("G"),
            curses.KEY_DOWN, curses.KEY_UP,
            4, 21, 6, 2}   # Ctrl-d, Ctrl-u, Ctrl-f, Ctrl-b


def typed_char(stdscr, k):
    """The text a printable keypress contributes to an input field, or None if
    `k` isn't printable. getch() delivers a multibyte UTF-8 character one byte
    at a time, so a lead byte (0xC0..0xF7) pulls its continuation bytes and the
    whole codepoint is decoded — that's what lets Arabic, accents and emoji be
    typed into the search / tag / schedule fields."""
    if 32 <= k <= 126:
        return chr(k)
    if 0xC0 <= k <= 0xF7:
        extra = 1 + (k >= 0xE0) + (k >= 0xF0)   # bytes that follow the lead
        buf = bytes([k] + [stdscr.getch() & 0xFF for _ in range(extra)])
        try:
            return buf.decode("utf-8")
        except UnicodeDecodeError:
            return None
    return None


def word_boundary(s, pos, forward):
    """Index of the next word boundary from `pos` in `s`, readline-style: skip
    any run of whitespace, then a run of word characters. `forward` scans right,
    otherwise left. Used by Ctrl-W (delete previous word) and, later, the
    Alt-b / Alt-f word motions."""
    i = pos
    if forward:
        n = len(s)
        while i < n and s[i].isspace():
            i += 1
        while i < n and not s[i].isspace():
            i += 1
    else:
        while i > 0 and s[i - 1].isspace():
            i -= 1
        while i > 0 and not s[i - 1].isspace():
            i -= 1
    return i


def nav_delta(k, page_h):
    """Decode a list-motion key into a cursor delta (or NAV_BOTTOM, or None
    for non-motion keys). One decoder for every list surface, so a new
    motion key lands everywhere at once: j/k/arrows one row, Ctrl-d/u half a
    page, Ctrl-f/b a full page minus one row of overlap, G the bottom."""
    if k in (ord("j"), curses.KEY_DOWN):
        return 1
    if k in (ord("k"), curses.KEY_UP):
        return -1
    if k == 4:    # Ctrl-d
        return max(1, page_h // 2)
    if k == 21:   # Ctrl-u
        return -max(1, page_h // 2)
    if k == 6:    # Ctrl-f
        return max(1, page_h - 1)
    if k == 2:    # Ctrl-b
        return -max(1, page_h - 1)
    if k == ord("G"):
        return NAV_BOTTOM
    return None


def clamp_list(state, n_items, page_h):
    """Clamp state["cur"] to the list bounds and scroll state["off"] so the
    cursor stays on screen."""
    state["cur"] = max(0, min(state["cur"], max(0, n_items - 1)))
    if state["cur"] < state["off"]:
        state["off"] = state["cur"]
    elif state["cur"] >= state["off"] + page_h:
        state["off"] = state["cur"] - page_h + 1


def clamp_scroll(state, filtered, height):
    # rows 1..h-2 hold notes; the footer bar sits at h-1
    clamp_list(state, len(filtered), height - 2)


# ----------------------------
# Drawing
# ----------------------------

MSG_ROTATE_SECS = 1.6   # how long each pooled status message shows before the
                        # one-line bar rotates to the next (only when rotating)
MSG_JOIN = "  ·  "      # separator when the whole pool fits on one line


def pool_msg(state, width=None):
    """Render the status bar from its message pool. When the messages all fit
    on the line they are shown whole, joined on one row with no counter. Only
    when that would overflow `width` do they fall back to cycling one at a time
    with an (i/n) prefix (rotation happens on the idle tick) — so nothing is
    ever truncated or wrapped off the line. A lone message always shows bare."""
    pool = state.get("_msg_pool") or []
    if not pool:
        return None
    if len(pool) == 1:
        return pool[0]
    joined = MSG_JOIN.join(pool)
    if width is None or disp_width(joined) <= width:
        return joined
    i = state.get("_msg_idx", 0) % len(pool)
    return f"({i + 1}/{len(pool)}) {pool[i]}"


def draw(stdscr, notes, state):
    stdscr.erase()

    h, w = stdscr.getmaxyx()

    if h < 3 or w < MIN_W_ERROR:
        addnstr_w(stdscr, 0, 0, "window too narrow", w)
        stdscr.refresh()
        return

    show_preview = (w - w // 2 - 5) >= MIN_PREVIEW_W
    if show_preview:
        natural_list_w = w // 2 - 2
        list_w = min(natural_list_w, LIST_MAX_W)
        mid = list_w + 2
        # Preview runs from mid+1 to the last column (w-1): no right margin,
        # mirroring the list starting flush at column 0 on the left.
        preview_w = w - (mid + 1)
    else:
        mid = None
        list_w = w - 1
        preview_w = 0

    show_date = list_w >= SHOW_DATE_MIN
    show_ago  = list_w >= SHOW_AGO_MIN

    conflicts = state.get("_conflicts", [])   # scanned on the idle tick, not per frame
    conflict_badge = f" | [{len(conflicts)} conflict(s)]" if conflicts else ""
    dup_badge = f" | [{len(state['_dups'])} dup(s) — gd]" if state.get("_dups") else ""
    loop_badge = f" | [{state['_loops_due']} loop(s) due — gr]" if state.get("_loops_due") else ""
    # The "filter:" field only shows while you're actually searching — same in
    # every view (notes / trash / duplicates / loops).
    filt = f" | filter:{state['q']}" if (state["q"] or state.get("search_mode")) else ""
    if state.get("tag_mode"):
        header = f"{TAG_PROMPT}{state['tag_input']}"
    elif state.get("sched_mode"):
        header = f"{SCHED_PROMPT}{state['sched_input']}"
    elif state.get("trash_mode"):
        sort = sort_label(state["sort"], state["rev"], state["q"], "modified 🞃", False)
        header = f"trash ({len(notes)} notes){filt} | sort:{sort}{conflict_badge}"
    elif state.get("dup_mode") is not None:
        sort = sort_label(state["sort"], state["rev"], state["q"], "grouped", True)
        header = f"duplicates ({len(notes)} notes){filt} | sort:{sort}{conflict_badge}"
    elif state.get("review_mode"):
        sort = sort_label(state["sort"], state["rev"], state["q"], "most stale first", True)
        header = f"resurface ({len(notes)} loop(s) due){filt} | sort:{sort}{conflict_badge}"
    elif state.get("tagf") is not None:
        sort = sort_label(state["sort"], state["rev"], state["q"], "modified 🞃", False)
        header = f"tagged {tagf_label(state['tagf'])} ({len(notes)} notes){filt} | sort:{sort}{conflict_badge}"
    else:
        sort = sort_label(state["sort"], state["rev"], state["q"], "modified 🞃", False)
        header = f"notes{filt} | sort:{sort}{conflict_badge}{dup_badge}{loop_badge}"

    # Header rule: underline the top row edge to edge. Unlike the content rows
    # (whose mixed colors made a row-wide underline look patchy), everything
    # here is the default color, so the underline reads as one continuous line.
    try:
        stdscr.hline(0, 0, ord(" ") | curses.A_UNDERLINE, w)
    except curses.error:
        pass
    addnstr_w(stdscr, 0, 0, header, w - 1, curses.A_UNDERLINE)

    visible = notes[state["off"]:state["off"] + h - 2]
    q_str = state["q"].strip()
    if q_str.startswith('"') and q_str.endswith('"') and len(q_str) > 2:
        tokens = [q_str[1:-1].lower()]
    else:
        tokens = q_str.lower().split() if q_str else []

    # Tags align in one column, 2 spaces past the widest date+relative-date
    # among the rows on screen (not the whole list), and appear as soon as a
    # single column of them fits.
    ago_strs = [f"({ago(n.get('modificationDate'))})" for n in visible]
    if show_ago:
        block_end = COL_AGO + max((len(a) for a in ago_strs), default=0)
    else:
        block_end = COL_DATE + 16   # date only (16-char timestamp)
    tag_col = block_end + 2

    # ----------------------------
    # LEFT PANE
    # ----------------------------

    now_ts = datetime.now().timestamp()
    for i, n in enumerate(visible):
        y = i + 1

        attr_title = curses.color_pair(1)
        attr_date = date_attr(n.get("modificationDate"), now_ts)
        attr_tag = curses.color_pair(3)

        selected = (i == state["cur"] - state["off"])
        if selected:
            attr_title |= curses.A_REVERSE

        t = title(n)
        tg = tags(n)

        hi_title = curses.color_pair(5) | (curses.A_REVERSE if selected else 0)
        title_w = min(28, list_w)
        t_clip = clip_to_width(t, title_w)
        draw_line_highlighted(stdscr, y, 0, t_clip, title_w, attr_title, hi_title, tokens)
        drawn_w = disp_width(t_clip)
        pad = title_w - drawn_w
        if pad > 0:
            try:
                stdscr.addnstr(y, drawn_w, " " * pad, pad, attr_title)
            except curses.error:
                pass

        if show_date:
            m = fmt(n.get("modificationDate"))
            # +1 budget so the zero-width LRM doesn't clip the last char.
            stdscr.addnstr(y, COL_DATE, LRM + m, min(1 + len(m), list_w - COL_DATE), attr_date)

        if show_ago:
            ago_str = ago_strs[i]
            stdscr.addnstr(y, COL_AGO, LRM + ago_str, min(1 + len(ago_str), list_w - COL_AGO), attr_date)

        if show_date and tg and tag_col < list_w:
            addnstr_w(stdscr, y, tag_col, tg, list_w - tag_col, attr_tag)

    # ----------------------------
    # RIGHT PANE (preview)
    # ----------------------------

    if show_preview:
        for y in range(1, h - 1):
            stdscr.addch(y, mid, curses.ACS_VLINE)

        cur_idx = state["cur"]

        if 0 <= cur_idx < len(notes):
            cur = notes[cur_idx]

            lines = content(cur).split("\n")

            start = state["p_scroll"]
            end = start + h - 2
            render_md = config_bool("render_markdown", True)

            for i, line in enumerate(lines[start:end]):
                if i >= h - 2:
                    break

                safe = line.expandtabs(4).replace("\n", "")
                draw_body = (draw_markdown_line if render_md
                            else draw_line_highlighted)
                draw_body(
                    stdscr, i + 1, mid + 1, safe, preview_w,
                    curses.color_pair(4),
                    curses.color_pair(5) | curses.A_BOLD,
                    tokens,
                )

    # Footer hints as (priority, text) segments: lower number = survives
    # longer as the terminal narrows. ⮐/e are one segment (e = open at end).
    hc = state.get("_hist_count", 0)
    if state.get("trash_mode"):
        segments = [
            (2, "gt exit trash"), (3, "/ search"),
            (2, "⮐/e edit (saving restores)"), (2, "u restore"),
            (4, "ESC clear/exit"), (1, "q quit"),
        ]
    elif state.get("dup_mode") is not None:
        segments = [
            (2, "gd exit dups"), (3, "/ search"), (2, "⮐/e open"),
            (3, "d trash"), (4, "ESC clear/exit"), (1, "q quit"),
        ]
    elif state.get("review_mode"):
        segments = [
            (4, "ESC clear/exit"), (5, "/ search"), (3, "⮐/e open"),
            (2, "z snooze"), (2, "S schedule"), (2, "x done"),
            (3, "d trash"), (6, "u/^R undo"), (1, "q quit"),
        ]
    elif state.get("tagf") is not None:
        many = len(state["tagf"]["tags"]) > 1
        segments = [
            (2, "⇥ cycle tag" if many else ""), (3, "/ search"),
            (2, "⮐/e open"), (4, "t refilter"), (5, "# tag"),
            (4, "d trash"), (3, "ESC clear/exit"), (1, "q quit"),
        ]
    else:
        segments = [
            (3, "n new"), (2, "/ search"), (7, "s/r sort"), (2, "⮐/e open"),
            (5, "#/. tag" if state.get("_last_tags") else "# tag"),
            (6, "t/T tags"), (10, "b backlinks"), (4, "d trash"),
            (10, "gt trash-view"), (8, "u/^R undo"),
            (9, "h/H hist" if hc >= 2 else ""),
            (2, "c conflicts" if conflicts else ""),
            (3, "? help"), (1, "q quit"),
        ]
    footer = fit_hints(segments, w - 1)

    # Footer as a full-width status bar: the tinted strip marks the bottom
    # edge, so no content row above needs sacrificing to a separator.
    try:
        stdscr.hline(h - 1, 0, ord(" ") | footer_attr(), w)
    except curses.error:
        pass
    addnstr_w(stdscr, h - 1, 0, footer, w - 1, footer_attr())

    # A transient prompt/warning (cross-session undo, stale-skip) takes over the
    # footer row in amber until the next keystroke resolves or dismisses it.
    msg = pool_msg(state, w - 1)
    if msg:
        attr = message_attr()
        try:
            stdscr.hline(h - 1, 0, ord(" ") | attr, w)
        except curses.error:
            pass
        addnstr_w(stdscr, h - 1, 0, msg, w - 1, attr)

    if state["search_mode"] or state.get("tag_mode") or state.get("sched_mode"):
        if state.get("tag_mode"):
            cursor_col = min(len(TAG_PROMPT) + len(state["tag_input"]), w - 1)
        elif state.get("sched_mode"):
            cursor_col = min(len(SCHED_PROMPT) + len(state["sched_input"]), w - 1)
        else:
            # Place the cursor right after the query in the live "filter:" field,
            # wherever it sits in this view's header (notes / trash / dup / loops).
            anchor = header.find("filter:")
            base_col = anchor + len("filter:") if anchor >= 0 else 0
            q_pos = min(state.get("q_pos", len(state["q"])), len(state["q"]))
            cursor_col = min(base_col + q_pos, w - 1)
        try:
            curses.curs_set(1)
        except curses.error:
            pass
        stdscr.move(0, cursor_col)
        stdscr.refresh()
        set_cursor_style(1)  # blinking block (DECSCUSR)
    else:
        curses.curs_set(0)
        set_cursor_style(0)  # restore terminal default
        stdscr.refresh()


